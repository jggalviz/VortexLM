{
	"version": 3,
	"routes": [
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "^\\/_server-islands\\/([^/]+?)\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/_image\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/contact\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/keystatic(?:\\/(.*?))?\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/blog\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/keystatic(?:\\/(.*?))?\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/servicios\\/desarrollo-de-apps-caracas\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/servicios\\/diseno-web-caracas\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/servicios\\/sistemas-gestion-medida\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/$",
			"dest": "_render"
		}
	]
}