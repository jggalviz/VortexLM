---
// src/components/ui/B2BBenefits.astro
// "Ventajas Corporativas B2B" section for VortexLM /precios page
// Shows corporate B2B advantages (invoicing, tax exemption, payment flexibility)
// + a welcome bonus banner (10 vCredits gratis)
// Self-contained component, no props, no external dependencies
---

<section
  class="relative w-full overflow-hidden bg-black"
  aria-label="Ventajas Corporativas B2B — Facturación, IVA y pagos internacionales"
>
  <!-- Subtle top border glow -->
  <div
    class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-white/[0.06] to-transparent pointer-events-none"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 sm:py-28 lg:py-36">
    <!-- Section header -->
    <div class="text-center mb-16 sm:mb-20 lg:mb-24">
      <!-- Pill / badge label -->
      <div class="flex items-center justify-center mb-6">
        <span
          class="inline-flex items-center gap-2 px-4 py-1.5 border border-linear-border rounded-full text-[10px] font-label-md uppercase tracking-[0.15em] text-linear-muted bg-linear-charcoal/60 backdrop-blur-sm"
        >
          <span class="w-1.5 h-1.5 rounded-full bg-linear-muted/60" aria-hidden="true"></span>
          Ventajas B2B
        </span>
      </div>

      <h2
        class="text-[clamp(1.75rem,4vw,3.25rem)] leading-[1.08] tracking-[-0.03em] font-light text-linear-text"
        style="font-family: 'Space Grotesk', sans-serif;"
      >
        Infraestructura corporativa para tu agencia
      </h2>

      <p
        class="max-w-2xl mx-auto mt-5 text-sm sm:text-base leading-relaxed text-neutral-400 font-body-md"
      >
        Facturación oficial, exención de IVA y flexibilidad internacional de pagos.
      </p>
    </div>

    <!-- ===== PART 1: 3-column benefits grid ===== -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 mb-20 sm:mb-24 lg:mb-28">
      <!-- Card 1: Facturación Corporativa -->
      <div class="benefit-card group relative p-8 sm:p-10 rounded-2xl border border-linear-border bg-linear-charcoal/80 transition-all duration-500">
        <!-- Icon container -->
        <div
          class="relative flex items-center justify-center w-14 h-14 sm:w-16 sm:h-16 mb-6 rounded-xl bg-gradient-to-br from-white/[0.04] to-white/[0.01] border border-linear-border/60 group-hover:border-linear-muted/30 transition-colors duration-500"
        >
          <!-- Document / building icon -->
          <svg
            class="w-6 h-6 sm:w-7 sm:h-7 text-linear-muted group-hover:text-linear-text transition-colors duration-500"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
          </svg>

          <!-- Hover glow ring -->
          <div
            class="absolute inset-0 rounded-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 ring-1 ring-white/10 ring-offset-1 ring-offset-transparent"
            aria-hidden="true"
          ></div>
        </div>

        <!-- Title -->
        <h3
          class="text-lg sm:text-xl font-medium text-linear-text mb-3 transition-colors duration-500"
          style="font-family: 'Space Grotesk', sans-serif;"
        >
          Facturación Corporativa
        </h3>

        <!-- Description -->
        <p class="text-sm leading-relaxed text-neutral-400">
          Emitimos facturas oficiales desde Vortex Logic LLC, registrada en EE.UU. Cumplimiento fiscal completo para tu agencia.
        </p>

        <!-- Bottom accent line -->
        <div
          class="absolute bottom-0 left-[15%] right-[15%] h-px bg-gradient-to-r from-transparent via-linear-muted/20 to-transparent scale-x-0 group-hover:scale-x-100 transition-transform duration-700 origin-center"
          aria-hidden="true"
        ></div>
      </div>

      <!-- Card 2: Exención de IVA -->
      <div class="benefit-card group relative p-8 sm:p-10 rounded-2xl border border-linear-border bg-linear-charcoal/80 transition-all duration-500">
        <!-- Icon container -->
        <div
          class="relative flex items-center justify-center w-14 h-14 sm:w-16 sm:h-16 mb-6 rounded-xl bg-gradient-to-br from-white/[0.04] to-white/[0.01] border border-linear-border/60 group-hover:border-linear-muted/30 transition-colors duration-500"
        >
          <!-- Percent / badge icon -->
          <svg
            class="w-6 h-6 sm:w-7 sm:h-7 text-linear-muted group-hover:text-linear-text transition-colors duration-500"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2zM10 8.5a.5.5 0 11-1 0 .5.5 0 011 0zm5 5a.5.5 0 11-1 0 .5.5 0 011 0z" />
          </svg>

          <!-- Hover glow ring -->
          <div
            class="absolute inset-0 rounded-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 ring-1 ring-white/10 ring-offset-1 ring-offset-transparent"
            aria-hidden="true"
          ></div>
        </div>

        <!-- Title -->
        <h3
          class="text-lg sm:text-xl font-medium text-linear-text mb-3 transition-colors duration-500"
          style="font-family: 'Space Grotesk', sans-serif;"
        >
          Exención de IVA
        </h3>

        <!-- Description -->
        <p class="text-sm leading-relaxed text-neutral-400">
          0% IVA para agencias en España bajo el mecanismo europeo de inversión del sujeto pasivo. Sin retenciones ni sobrecostes.
        </p>

        <!-- Bottom accent line -->
        <div
          class="absolute bottom-0 left-[15%] right-[15%] h-px bg-gradient-to-r from-transparent via-linear-muted/20 to-transparent scale-x-0 group-hover:scale-x-100 transition-transform duration-700 origin-center"
          aria-hidden="true"
        ></div>
      </div>

      <!-- Card 3: Flexibilidad de Pagos -->
      <div class="benefit-card group relative p-8 sm:p-10 rounded-2xl border border-linear-border bg-linear-charcoal/80 transition-all duration-500">
        <!-- Icon container -->
        <div
          class="relative flex items-center justify-center w-14 h-14 sm:w-16 sm:h-16 mb-6 rounded-xl bg-gradient-to-br from-white/[0.04] to-white/[0.01] border border-linear-border/60 group-hover:border-linear-muted/30 transition-colors duration-500"
        >
          <!-- Credit card / globe icon -->
          <svg
            class="w-6 h-6 sm:w-7 sm:h-7 text-linear-muted group-hover:text-linear-text transition-colors duration-500"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
          </svg>

          <!-- Hover glow ring -->
          <div
            class="absolute inset-0 rounded-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 ring-1 ring-white/10 ring-offset-1 ring-offset-transparent"
            aria-hidden="true"
          ></div>
        </div>

        <!-- Title -->
        <h3
          class="text-lg sm:text-xl font-medium text-linear-text mb-3 transition-colors duration-500"
          style="font-family: 'Space Grotesk', sans-serif;"
        >
          Pagos Internacionales
        </h3>

        <!-- Description -->
        <p class="text-sm leading-relaxed text-neutral-400">
          Tarjetas de crédito, transferencias bancarias directas (ACH en EE.UU. y SEPA en Europa) y pasarelas cripto/digitales como Binance Pay.
        </p>

        <!-- Bottom accent line -->
        <div
          class="absolute bottom-0 left-[15%] right-[15%] h-px bg-gradient-to-r from-transparent via-linear-muted/20 to-transparent scale-x-0 group-hover:scale-x-100 transition-transform duration-700 origin-center"
          aria-hidden="true"
        ></div>
      </div>
    </div>

    <!-- ===== PART 2: Welcome Bonus Banner (Bono de Bienvenida) ===== -->
    <div
      class="bonus-banner group relative w-full rounded-2xl border border-linear-accent/20 bg-gradient-to-r from-linear-accent/10 via-linear-charcoal to-linear-accent/5 overflow-hidden transition-all duration-500"
    >
      <!-- Subtle inner glow overlay -->
      <div
        class="absolute inset-0 bg-gradient-to-br from-white/[0.02] via-transparent to-transparent pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-500"
        aria-hidden="true"
      ></div>

      <div class="relative z-10 flex flex-col lg:flex-row items-center gap-8 lg:gap-12 p-8 sm:p-10 lg:p-14">
        <!-- Left: Large gift/star icon -->
        <div
          class="flex-shrink-0 flex items-center justify-center w-20 h-20 sm:w-24 sm:h-24 lg:w-28 lg:h-28 rounded-2xl bg-gradient-to-br from-linear-accent/20 to-linear-accent/5 border border-linear-accent/20 group-hover:border-linear-accent/40 transition-all duration-500"
        >
          <svg
            class="w-10 h-10 sm:w-12 sm:h-12 lg:w-14 lg:h-14 text-linear-accent"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
          </svg>
        </div>

        <!-- Right: Content -->
        <div class="flex-1 text-center lg:text-left">
          <!-- Small badge -->
          <div class="flex justify-center lg:justify-start mb-4">
            <span
              class="inline-flex items-center gap-2 px-3 py-1 border border-linear-accent/30 rounded-full text-[10px] font-label-md uppercase tracking-[0.15em] text-linear-accent bg-linear-accent/10 backdrop-blur-sm"
            >
              <span class="w-1.5 h-1.5 rounded-full bg-linear-accent" aria-hidden="true"></span>
              Bono de Bienvenida
            </span>
          </div>

          <!-- Heading -->
          <h3
            class="text-[clamp(1.25rem,3vw,2rem)] leading-[1.15] tracking-[-0.02em] font-light text-white mb-3"
            style="font-family: 'Space Grotesk', sans-serif;"
          >
            10 vCredits gratis para tu agencia
          </h3>

          <!-- Description -->
          <p class="text-sm sm:text-base leading-relaxed text-neutral-400 font-body-md max-w-xl mx-auto lg:mx-0 mb-6">
            Regístrate tras una llamada corta de activación y recibe 10 vCredits completamente gratis. Válidos para testear cualquier servicio del catálogo sin compromiso.
          </p>

          <!-- CTA Button -->
          <a
            href="/contacto"
            class="inline-flex items-center justify-center px-8 py-3.5 bg-linear-accent text-black font-semibold text-xs rounded-full hover:brightness-110 transition-all duration-200 active:scale-[0.97] shadow-[0_0_30px_rgba(255,255,255,0.08)]"
          >
            Solicitar Bono
            <svg class="w-3.5 h-3.5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Bottom accent line -->
      <div
        class="absolute bottom-0 left-[10%] right-[10%] h-px bg-gradient-to-r from-transparent via-linear-accent/30 to-transparent scale-x-0 group-hover:scale-x-100 transition-transform duration-700 origin-center"
        aria-hidden="true"
      ></div>
    </div>
  </div>

  <!-- Bottom border glow -->
  <div
    class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-white/[0.06] to-transparent pointer-events-none"
    aria-hidden="true"
  ></div>
</section>

<style>
  /* Benefit card hover elevation */
  .benefit-card {
    will-change: transform;
  }

  .benefit-card:hover {
    transform: translateY(-6px);
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow:
      0 20px 40px -12px rgba(0, 0, 0, 0.6),
      0 0 0 1px rgba(255, 255, 255, 0.04) inset;
    background: rgba(8, 8, 12, 0.95);
  }

  /* Bonus banner hover glow intensification */
  .bonus-banner:hover {
    border-color: rgba(255, 255, 255, 0.12);
    box-shadow:
      0 0 40px -8px rgba(255, 255, 255, 0.06),
      0 0 0 1px rgba(255, 255, 255, 0.04) inset;
  }

  /* Smooth transition for all interactive elements */
  .benefit-card * {
    transition-duration: 500ms;
    transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Responsive adjustments */
  @media (min-width: 768px) {
    .benefit-card {
      min-height: 340px;
    }
  }

  @media (max-width: 767px) {
    .benefit-card {
      min-height: auto;
    }
  }
</style>
