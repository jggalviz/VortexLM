---
// src/components/ui/B2BHero.astro
// Hero Section for VortexLM B2B landing page — targeting digital agencies in Spain & USA
// Self-contained component, no props, no external dependencies
---

<section
  class="relative w-full min-h-[85vh] flex items-center justify-center overflow-hidden bg-[#000000]"
  aria-label="Hero principal — Externaliza desarrollo frontend y WordPress"
>
  <!-- Grid pattern overlay (Linear.app inspired) -->
  <div
    class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.025)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.025)_1px,transparent_1px)] bg-[size:64px_64px] [mask-image:radial-gradient(ellipse_80%_50%_at_50%_0%,#000_70%,transparent_110%)] pointer-events-none"
    aria-hidden="true"
  ></div>

  <!-- Subtle glow orb -->
  <div
    class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[700px] h-[700px] bg-gradient-to-b from-white/[0.04] via-white/[0.015] to-transparent rounded-full blur-3xl pointer-events-none"
    aria-hidden="true"
  ></div>

  <!-- Secondary glow accent (bottom-right) -->
  <div
    class="absolute bottom-0 right-0 w-[400px] h-[400px] bg-gradient-to-tl from-white/[0.02] to-transparent rounded-full blur-3xl pointer-events-none"
    aria-hidden="true"
  ></div>

  <!-- Content container -->
  <div class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 sm:py-32 lg:py-40">
    <div class="max-w-4xl mx-auto text-center">

      <!-- Eyebrow / badge -->
      <div class="flex items-center justify-center mb-8">
        <span
          class="inline-flex items-center gap-2 px-4 py-1.5 border border-linear-border rounded-full text-[10px] font-label-md uppercase tracking-[0.15em] text-linear-muted bg-linear-charcoal/60 backdrop-blur-sm"
        >
          <span class="w-1.5 h-1.5 rounded-full bg-linear-muted/60" aria-hidden="true"></span>
          Partner Tecnológico White Label
        </span>
      </div>

      <!-- Headline -->
      <h1
        class="text-[clamp(2.25rem,5.5vw,4.5rem)] leading-[1.08] tracking-[-0.03em] font-light text-linear-text mb-6"
        style="font-family: 'Space Grotesk', sans-serif;"
      >
        Externaliza desarrollo
        <span class="block text-linear-muted">frontend y WordPress</span>
        <span class="block text-linear-muted">con tu propia marca</span>
      </h1>

      <!-- Subheadline -->
      <p
        class="max-w-2xl mx-auto text-sm sm:text-base leading-relaxed text-linear-muted font-body-md mb-10"
      >
        Sin contratos fijos ni compromisos mensuales. Nuestro modelo de 
        <strong class="text-linear-text font-medium">vCredits</strong> te permite 
        comprar horas de desarrollo en bloque y consumirlas bajo demanda. 
        Tú pones el brief, nosotros entregamos código listo para producción 
        con tu marca — 100% white label, 100% profesional.
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/contacto"
          class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-3.5 bg-white text-black font-semibold text-xs rounded-full hover:bg-neutral-200 transition-all duration-200 active:scale-[0.97] shadow-[0_0_30px_rgba(255,255,255,0.12)]"
        >
          Solicitar una Demo
          <svg class="w-3.5 h-3.5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a
          href="/como-funciona"
          class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-3.5 border border-linear-border text-linear-muted font-medium text-xs rounded-full hover:bg-linear-charcoal hover:text-linear-text transition-all duration-200"
        >
          Ver cómo funciona
          <svg class="w-3.5 h-3.5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </a>
      </div>

      <!-- Trust / social proof micro-text -->
      <p class="mt-12 text-[10px] font-label-md uppercase tracking-[0.15em] text-linear-muted/50">
        Utilizado por agencias digitales en España y Estados Unidos
      </p>

    </div>
  </div>

  <!-- Bottom glow line -->
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-white/[0.06] to-transparent pointer-events-none" aria-hidden="true"></div>
</section>

<style>
  /* Ensure Space Grotesk is applied for the heading even before full CSS loads */
  section h1 {
    font-family: 'Space Grotesk', sans-serif;
  }
</style>
