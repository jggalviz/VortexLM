---
// src/components/ui/ClientDashboardPreview.astro
// "Tu Dashboard de Cliente" — Pure CSS/Tailwind wireframe mockup of the client portal dashboard
// Self-contained component, no props, no external dependencies
---

<section
  class="relative w-full overflow-hidden bg-black"
  aria-label="Tu Dashboard de Cliente — Portal de gestión en tiempo real"
>
  <!-- Subtle top border glow -->
  <div
    class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-white/[0.06] to-transparent pointer-events-none"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 sm:py-28 lg:py-36">
    <!-- Section header -->
    <div class="text-center mb-16 sm:mb-20 lg:mb-24">
      <!-- Pill / badge label -->
      <div class="flex items-center justify-center mb-6">
        <span
          class="inline-flex items-center gap-2 px-4 py-1.5 border border-linear-border rounded-full text-[10px] font-label-md uppercase tracking-[0.15em] text-linear-muted bg-linear-charcoal/60 backdrop-blur-sm"
        >
          <span class="w-1.5 h-1.5 rounded-full bg-linear-muted/60" aria-hidden="true"></span>
          EL PORTAL
        </span>
      </div>

      <h2
        class="text-[clamp(1.75rem,4vw,3.25rem)] leading-[1.08] tracking-[-0.03em] font-light text-linear-text"
        style="font-family: 'Space Grotesk', sans-serif;"
      >
        Tu Dashboard de
        <span class="text-linear-muted">Cliente</span>
      </h2>

      <p
        class="max-w-2xl mx-auto mt-5 text-sm sm:text-base leading-relaxed text-neutral-400 font-body-md"
      >
        Gestiona proyectos, revisa consumos y controla servicios desde un solo lugar.
        <strong class="text-linear-text font-medium">En tiempo real.</strong>
      </p>
    </div>

    <!-- ===== DASHBOARD MOCKUP ===== -->
    <div class="max-w-5xl mx-auto">
      <div class="rounded-xl overflow-hidden border border-linear-border bg-linear-charcoal/80 shadow-[0_0_60px_-15px_rgba(0,0,0,0.8)]">
        
        <!-- Window chrome -->
        <div class="flex items-center gap-3 px-4 sm:px-5 py-3 border-b border-linear-border bg-linear-charcoal/60">
          <!-- Traffic light dots -->
          <div class="flex items-center gap-1.5" aria-hidden="true">
            <span class="w-2.5 h-2.5 rounded-full bg-red-500/70"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-yellow-500/70"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-green-500/70"></span>
          </div>
          <!-- Window title -->
          <div class="flex-1 text-center">
            <span class="text-[10px] font-label-md text-linear-muted/60 tracking-wider">VortexLM Dashboard</span>
          </div>
          <!-- Spacer for balance -->
          <div class="w-12"></div>
        </div>

        <!-- Dashboard body: sidebar + main content -->
        <div class="flex flex-col md:flex-row">
          
          <!-- ===== SIDEBAR ===== -->
          <aside class="w-full md:w-48 lg:w-56 shrink-0 border-b md:border-b-0 md:border-r border-linear-border bg-linear-charcoal/60" aria-label="Navegación del dashboard">
            <!-- Sidebar header -->
            <div class="px-4 py-4 border-b border-linear-border/50">
              <div class="flex items-center gap-2.5">
                <div class="w-6 h-6 rounded-md bg-linear-accent/20 border border-linear-accent/30 flex items-center justify-center">
                  <svg class="w-3.5 h-3.5 text-linear-accent/80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
                  </svg>
                </div>
                <span class="text-xs font-label-md text-linear-text/80 tracking-wide">Mi Portal</span>
              </div>
            </div>

            <!-- Sidebar nav items -->
            <nav class="p-3 space-y-1">
              <!-- Dashboard (active) -->
              <a class="flex items-center gap-3 px-3 py-2 rounded-lg bg-linear-accent/10 border border-linear-accent/20 text-[11px] font-label-md text-linear-accent tracking-wide cursor-default" aria-current="page">
                <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" />
                </svg>
                <span>Dashboard</span>
              </a>

              <!-- Proyectos -->
              <a class="flex items-center gap-3 px-3 py-2 rounded-lg text-[11px] font-label-md text-linear-muted/70 tracking-wide hover:text-linear-text hover:bg-linear-charcoal/40 transition-colors duration-200 cursor-default">
                <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z" />
                </svg>
                <span>Proyectos</span>
              </a>

              <!-- vCredits -->
              <a class="flex items-center gap-3 px-3 py-2 rounded-lg text-[11px] font-label-md text-linear-muted/70 tracking-wide hover:text-linear-text hover:bg-linear-charcoal/40 transition-colors duration-200 cursor-default">
                <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span>vCredits</span>
              </a>

              <!-- Facturación -->
              <a class="flex items-center gap-3 px-3 py-2 rounded-lg text-[11px] font-label-md text-linear-muted/70 tracking-wide hover:text-linear-text hover:bg-linear-charcoal/40 transition-colors duration-200 cursor-default">
                <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                </svg>
                <span>Facturación</span>
              </a>

              <!-- Configuración -->
              <a class="flex items-center gap-3 px-3 py-2 rounded-lg text-[11px] font-label-md text-linear-muted/70 tracking-wide hover:text-linear-text hover:bg-linear-charcoal/40 transition-colors duration-200 cursor-default">
                <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <span>Configuración</span>
              </a>
            </nav>

            <!-- Sidebar footer: user info -->
            <div class="px-4 py-3 border-t border-linear-border/50 mt-2">
              <div class="flex items-center gap-2.5">
                <div class="w-6 h-6 rounded-full bg-linear-accent/20 border border-linear-accent/30 flex items-center justify-center">
                  <span class="text-[9px] font-label-md text-linear-accent/80">VM</span>
                </div>
                <div class="min-w-0">
                  <p class="text-[10px] font-label-md text-linear-text/70 truncate">Vortex Agency</p>
                  <p class="text-[8px] font-label-md text-linear-muted/50 truncate">Plan Pro</p>
                </div>
              </div>
            </div>
          </aside>

          <!-- ===== MAIN CONTENT AREA ===== -->
          <div class="flex-1 min-w-0 p-4 sm:p-5 lg:p-6 space-y-5">
            <!-- Top bar: welcome + vCredits balance -->
            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
              <div>
                <h3 class="text-sm font-medium text-linear-text" style="font-family: 'Space Grotesk', sans-serif;">Bienvenido de vuelta</h3>
                <p class="text-[11px] text-linear-muted/70 font-body-md">Aquí está el resumen de tu actividad</p>
              </div>
              <div class="flex items-center gap-3 px-3.5 py-2 rounded-lg border border-linear-border/60 bg-linear-charcoal/40">
                <svg class="w-4 h-4 text-linear-accent/70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <div>
                  <span class="text-[10px] font-label-md text-linear-muted/60 tracking-wide">vCredits disponibles</span>
                  <p class="text-sm font-medium text-linear-accent" style="font-family: 'JetBrains Mono', monospace;">24.5</p>
                </div>
              </div>
            </div>

            <!-- 3-column grid (stacks on mobile) -->
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 lg:gap-5">
              
              <!-- ===== PANEL 1: Asignación de Tareas ===== -->
              <div class="lg:col-span-1 rounded-xl border border-linear-border bg-linear-charcoal/60 overflow-hidden">
                <!-- Card header -->
                <div class="flex items-center justify-between px-4 py-3 border-b border-linear-border/50">
                  <div class="flex items-center gap-2">
                    <svg class="w-3.5 h-3.5 text-linear-muted/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15a2.25 2.25 0 012.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" />
                    </svg>
                    <span class="text-[10px] font-label-md text-linear-muted/80 tracking-wide uppercase">Asignación de Tareas</span>
                  </div>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full border border-linear-border/50 bg-linear-charcoal/40 text-[8px] font-label-md text-linear-muted/60">4 activas</span>
                </div>

                <!-- Task list -->
                <div class="divide-y divide-linear-border/40">
                  <!-- Task 1: En progreso -->
                  <div class="px-4 py-3 hover:bg-linear-charcoal/30 transition-colors duration-200">
                    <div class="flex items-start gap-3">
                      <div class="w-4 h-4 mt-0.5 rounded border border-linear-border/60 flex items-center justify-center shrink-0">
                        <div class="w-2 h-2 rounded-sm bg-linear-accent/60"></div>
                      </div>
                      <div class="min-w-0 flex-1">
                        <p class="text-[11px] text-linear-text/90 font-body-md leading-snug truncate">Rediseño landing page — Cliente A</p>
                        <div class="flex items-center gap-2 mt-1.5">
                          <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full border border-yellow-500/20 bg-yellow-500/10 text-[8px] font-label-md text-yellow-400/80 uppercase tracking-wider">
                            <span class="w-1 h-1 rounded-full bg-yellow-400/60"></span>
                            En progreso
                          </span>
                          <span class="text-[8px] font-label-md text-linear-muted/50">vence en 3d</span>
                        </div>
                      </div>
                    </div>
                  </div>

                  <!-- Task 2: Pendiente -->
                  <div class="px-4 py-3 hover:bg-linear-charcoal/30 transition-colors duration-200">
                    <div class="flex items-start gap-3">
                      <div class="w-4 h-4 mt-0.5 rounded border border-linear-border/60 flex items-center justify-center shrink-0"></div>
                      <div class="min-w-0 flex-1">
                        <p class="text-[11px] text-linear-text/90 font-body-md leading-snug truncate">Integración API pasarela de pago</p>
                        <div class="flex items-center gap-2 mt-1.5">
                          <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full border border-blue-500/20 bg-blue-500/10 text-[8px] font-label-md text-blue-400/80 uppercase tracking-wider">
                            <span class="w-1 h-1 rounded-full bg-blue-400/60"></span>
                            Pendiente
                          </span>
                          <span class="text-[8px] font-label-md text-linear-muted/50">vence en 7d</span>
                        </div>
                      </div>
                    </div>
                  </div>

                  <!-- Task 3: Completado -->
                  <div class="px-4 py-3 hover:bg-linear-charcoal/30 transition-colors duration-200">
                    <div class="flex items-start gap-3">
                      <div class="w-4 h-4 mt-0.5 rounded border border-green-500/40 bg-green-500/20 flex items-center justify-center shrink-0">
                        <svg class="w-2.5 h-2.5 text-green-400/80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                        </svg>
                      </div>
                      <div class="min-w-0 flex-1">
                        <p class="text-[11px] text-linear-text/90 font-body-md leading-snug truncate">Optimización SEO blog</p>
                        <div class="flex items-center gap-2 mt-1.5">
                          <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full border border-green-500/20 bg-green-500/10 text-[8px] font-label-md text-green-400/80 uppercase tracking-wider">
                            <span class="w-1 h-1 rounded-full bg-green-400/60"></span>
                            Completado
                          </span>
                          <span class="text-[8px] font-label-md text-linear-muted/50">entregado</span>
                        </div>
                      </div>
                    </div>
                  </div>

                  <!-- Task 4: En progreso -->
                  <div class="px-4 py-3 hover:bg-linear-charcoal/30 transition-colors duration-200">
                    <div class="flex items-start gap-3">
                      <div class="w-4 h-4 mt-0.5 rounded border border-linear-border/60 flex items-center justify-center shrink-0">
                        <div class="w-2 h-2 rounded-sm bg-linear-accent/60"></div>
                      </div>
                      <div class="min-w-0 flex-1">
                        <p class="text-[11px] text-linear-text/90 font-body-md leading-snug truncate">Migración WordPress — Cliente B</p>
                        <div class="flex items-center gap-2 mt-1.5">
                          <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full border border-yellow-500/20 bg-yellow-500/10 text-[8px] font-label-md text-yellow-400/80 uppercase tracking-wider">
                            <span class="w-1 h-1 rounded-full bg-yellow-400/60"></span>
                            En progreso
                          </span>
                          <span class="text-[8px] font-label-md text-linear-muted/50">vence en 5d</span>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <!-- ===== PANEL 2: Historial de Consumos ===== -->
              <div class="lg:col-span-1 rounded-xl border border-linear-border bg-linear-charcoal/60 overflow-hidden">
                <!-- Card header -->
                <div class="flex items-center justify-between px-4 py-3 border-b border-linear-border/50">
                  <div class="flex items-center gap-2">
                    <svg class="w-3.5 h-3.5 text-linear-muted/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
                    </svg>
                    <span class="text-[10px] font-label-md text-linear-muted/80 tracking-wide uppercase">Historial de Consumos</span>
                  </div>
                  <span class="text-[8px] font-label-md text-linear-muted/50">últimos 30 días</span>
                </div>

                <!-- Mini table -->
                <div class="overflow-x-auto">
                  <table class="w-full text-[10px]">
                    <thead>
                      <tr class="border-b border-linear-border/30">
                        <th class="text-left px-4 py-2 text-[8px] font-label-md text-linear-muted/50 uppercase tracking-wider">Fecha</th>
                        <th class="text-left px-4 py-2 text-[8px] font-label-md text-linear-muted/50 uppercase tracking-wider">Proyecto</th>
                        <th class="text-right px-4 py-2 text-[8px] font-label-md text-linear-muted/50 uppercase tracking-wider">Horas</th>
                        <th class="text-right px-4 py-2 text-[8px] font-label-md text-linear-muted/50 uppercase tracking-wider">vCredits</th>
                      </tr>
                    </thead>
                    <tbody class="divide-y divide-linear-border/30">
                      <tr class="hover:bg-linear-charcoal/30 transition-colors duration-200">
                        <td class="px-4 py-2.5 text-linear-text/70 font-body-md whitespace-nowrap">15 May</td>
                        <td class="px-4 py-2.5 text-linear-text/80 font-body-md whitespace-nowrap">Rediseño Cliente A</td>
                        <td class="px-4 py-2.5 text-right font-label-md text-linear-text/70 whitespace-nowrap">3.5</td>
                        <td class="px-4 py-2.5 text-right font-label-md text-linear-accent whitespace-nowrap">-3.5</td>
                      </tr>
                      <tr class="hover:bg-linear-charcoal/30 transition-colors duration-200">
                        <td class="px-4 py-2.5 text-linear-text/70 font-body-md whitespace-nowrap">12 May</td>
                        <td class="px-4 py-2.5 text-linear-text/80 font-body-md whitespace-nowrap">API Pasarela Pago</td>
                        <td class="px-4 py-2.5 text-right font-label-md text-linear-text/70 whitespace-nowrap">2.0</td>
                        <td class="px-4 py-2.5 text-right font-label-md text-linear-accent whitespace-nowrap">-2.0</td>
                      </tr>
                      <tr class="hover:bg-linear-charcoal/30 transition-colors duration-200">
                        <td class="px-4 py-2.5 text-linear-text/70 font-body-md whitespace-nowrap">10 May</td>
                        <td class="px-4 py-2.5 text-linear-text/80 font-body-md whitespace-nowrap">SEO Blog</td>
                        <td class="px-4 py-2.5 text-right font-label-md text-linear-text/70 whitespace-nowrap">1.0</td>
                        <td class="px-4 py-2.5 text-right font-label-md text-linear-accent whitespace-nowrap">-1.0</td>
                      </tr>
                      <tr class="hover:bg-linear-charcoal/30 transition-colors duration-200">
