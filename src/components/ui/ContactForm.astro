---
// src/components/ui/ContactForm.astro
interface Props {
  buttonText?: string;
  buttonClass?: string;
  inputBgClass?: string;
  inputBorderClass?: string;
}

const { 
  buttonText = "Iniciar mi Proyecto en Caracas", 
  buttonClass = "w-full py-4 mt-2 bg-gradient-to-r from-cyan-600 to-blue-600 hover:from-cyan-500 hover:to-blue-500 text-white font-bold rounded-lg transition-all shadow-lg shadow-cyan-600/30",
  inputBgClass = "bg-slate-900",
  inputBorderClass = "border-slate-700 focus:border-cyan-500 focus:ring-cyan-500"
} = Astro.props;
---
<form action="/api/contact" method="POST" class="space-y-4">
  <div>
    <label for="name" class="block text-sm font-medium text-slate-300 mb-1">Nombre Completo</label>
    <input 
      type="text" 
      id="name" 
      name="name" 
      required 
      class={`w-full px-4 py-3 border rounded-lg text-white focus:outline-none focus:ring-1 transition-all duration-200 ${inputBgClass} ${inputBorderClass}`}
      placeholder="Ej. Carlos Mendoza"
    />
  </div>
  
  <div>
    <label for="email" class="block text-sm font-medium text-slate-300 mb-1">Correo Corporativo</label>
    <input 
      type="email" 
      id="email" 
      name="email" 
      required 
      class={`w-full px-4 py-3 border rounded-lg text-white focus:outline-none focus:ring-1 transition-all duration-200 ${inputBgClass} ${inputBorderClass}`}
      placeholder="carlos@tuempresa.com"
    />
  </div>

  <div>
    <label for="service" class="block text-sm font-medium text-slate-300 mb-1">Servicio de Interés</label>
    <select 
      id="service" 
      name="service" 
      required
      class={`w-full px-4 py-3 border rounded-lg text-white focus:outline-none focus:ring-1 transition-all duration-200 appearance-none ${inputBgClass} ${inputBorderClass}`}
    >
      <option value="" disabled selected>Selecciona un servicio</option>
      <option value="desarrollo-web">Diseño y Desarrollo Web</option>
      <option value="app-movil">Desarrollo de App Móvil</option>
      <option value="software">Software a Medida</option>
    </select>
  </div>

  <button 
    type="submit" 
    class={buttonClass}
  >
    {buttonText}
  </button>
  
  <p class="text-xs text-slate-500 text-center mt-4">
    Tus datos están protegidos. Sin spam, garantizado.
  </p>
</form>

