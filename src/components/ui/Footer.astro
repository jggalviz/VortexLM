---
interface Props {
  isLanding?: boolean;
}
const { isLanding = false } = Astro.props;
---

<footer class="w-full py-16 px-6 md:px-12 bg-black border-t border-[#1f1f24] relative overflow-hidden mt-0">
  <div class="max-w-container-max mx-auto grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-8 mb-12 relative z-10">
    <div class="col-span-1 md:col-span-5">
      <!-- Footer Logo -->
      <a href="/" class="flex items-center gap-2 group focus:outline-none mb-4 inline-flex" aria-label="VortexLM Home">
        <svg class="w-5 h-5 text-white transition-transform duration-300 group-hover:rotate-45 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10" class="stroke-neutral-800" />
          <circle cx="12" cy="12" r="5" />
          <circle cx="12" cy="12" r="1" fill="currentColor" />
          <path d="M12 2v3M12 19v3M2 12h3M19 12h3" />
          <circle cx="12" cy="5" r="0.75" fill="currentColor" />
          <circle cx="12" cy="19" r="0.75" fill="currentColor" />
          <circle cx="5" cy="12" r="0.75" fill="currentColor" />
          <circle cx="19" cy="12" r="0.75" fill="currentColor" />
        </svg>

        <span class="font-sans text-base font-semibold tracking-[0.15em] text-white uppercase transition-colors duration-200">
          Vortex<span class="font-light tracking-normal text-neutral-500 group-hover:text-neutral-400 ml-0.5">LM</span>
        </span>
      </a>
      <p class="text-xs text-[#8a8a93] leading-relaxed max-w-sm">
        Desarrollo de software robusto, aplicaciones web escalables y plataformas de alta velocidad. Implementamos ingeniería frontend de última generación para transformar el rendimiento digital de tu negocio.      </p>
    </div>
    
    {!isLanding && (
      <div class="col-span-1 md:col-span-3 md:col-start-7">
        <h3 class="text-white text-xs font-normal mb-5">Soluciones</h3>
        <ul class="space-y-3 text-xs text-[#8a8a93]">
          <li><a href="/soluciones/diseno-web-velocidad" class="hover:text-white transition-colors duration-200">Diseño Web de Alta Velocidad</a></li>
          <li><a href="/soluciones/desarrollo-apps-moviles" class="hover:text-white transition-colors duration-200">Desarrollo de Apps Móviles iOS/Android</a></li>
          <li><a href="/soluciones/desarrollo-astro-nextjs" class="hover:text-white transition-colors duration-200">Desarrollo Web con Astro y Next.js</a></li>
          <li><a href="/soluciones/sistemas-erp-software-medida" class="hover:text-white transition-colors duration-200">Sistemas ERP y Software a Medida</a></li>
        </ul>
      </div>
    )}
    
    <div class="col-span-1 md:col-span-2 md:col-start-11">
      <h3 class="text-white text-xs font-normal mb-5">Plataforma</h3>
      <ul class="space-y-3 text-xs text-[#8a8a93]">
        <li><a href="/blog" class="hover:text-white transition-colors duration-200">Blog Técnico</a></li>
        <li><a href="/contacto" class="hover:text-white transition-colors duration-200">Contacto</a></li>
      </ul>
    </div>
  </div>
  
  <div class="max-w-container-max mx-auto pt-8 border-t border-[#1f1f24] flex flex-col md:flex-row items-center justify-between text-[11px] text-[#8a8a93]/60 relative z-10 font-mono">
    <p>&copy; {new Date().getFullYear()} VortexLM. Todos los derechos reservados.</p>
  </div>
</footer>
