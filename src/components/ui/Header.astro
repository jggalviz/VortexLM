---
<header class="fixed top-0 left-0 right-0 z-50 bg-surface/80 backdrop-blur-md border-b border-outline-variant/30">
  <nav class="flex justify-between items-center w-full px-margin-mobile md:px-margin-desktop h-20 max-w-container-max mx-auto">
    <a href="/" class="font-display-lg text-headline-md tracking-tighter text-on-surface hover:text-primary transition-colors flex items-center gap-2 group">
      Vortex<span class="text-primary">LM</span>
    </a>
    
    <div class="hidden md:flex items-center gap-8">
      <a href="/" class="font-label-md text-label-md text-on-surface-variant hover:text-primary transition-colors duration-300">Inicio</a>
      
      <div class="relative group py-4">
        <span class="font-label-md text-label-md text-on-surface-variant hover:text-primary transition-colors flex items-center gap-1 cursor-pointer">
          Servicios
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" /></svg>
        </span>
        
        <div class="absolute top-[100%] left-1/2 -translate-x-1/2 mt-2 w-64 glass-card rounded-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 flex flex-col z-[100] overflow-hidden shadow-2xl">
          <a href="/servicios/diseno-web-caracas" class="px-6 py-4 font-label-md text-sm text-on-surface hover:bg-surface-container-high hover:text-primary border-b border-outline-variant/30">
            Diseño Web
          </a>
          <a href="/servicios/desarrollo-de-apps-caracas" class="px-6 py-4 font-label-md text-sm text-on-surface hover:bg-surface-container-high hover:text-primary border-b border-outline-variant/30">
            Apps Móviles
          </a>
          <a href="/servicios/sistemas-gestion-medida" class="px-6 py-4 font-label-md text-sm text-on-surface hover:bg-surface-container-high hover:text-primary">
            Sistemas Pro
          </a>
        </div>
      </div>

      <a href="/blog" class="font-label-md text-label-md text-on-surface-variant hover:text-primary transition-colors duration-300">Blog</a>
      
      <a href="/#contacto" class="bg-primary-container text-on-primary-container px-6 py-2 rounded-none font-label-md text-label-md active:scale-95 transition-transform hover:opacity-90 shadow-[0_0_15px_rgba(138,43,226,0.3)]">
        Contactar
      </a>
    </div>
    
    <!-- Mobile menu button (Zero JS CSS Only) -->
    <details class="md:hidden group relative">
      <summary class="list-none cursor-pointer text-on-surface-variant hover:text-primary p-2">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </summary>
      <div class="absolute right-0 top-full mt-4 w-64 glass-card rounded-lg shadow-2xl overflow-hidden flex flex-col z-50 max-h-[80vh] overflow-y-auto">
        <a href="/" class="px-5 py-4 font-label-md text-sm text-on-surface-variant hover:bg-surface-container-high hover:text-primary border-b border-outline-variant/30">Inicio</a>
        <div class="px-5 py-2 font-label-sm text-xs text-outline uppercase tracking-wider bg-surface-container/50">Servicios</div>
        <a href="/servicios/diseno-web-caracas" class="px-5 py-4 pl-8 font-label-md text-sm text-on-surface-variant hover:bg-surface-container-high hover:text-primary border-b border-outline-variant/30">↳ Diseño Web</a>
        <a href="/servicios/desarrollo-de-apps-caracas" class="px-5 py-4 pl-8 font-label-md text-sm text-on-surface-variant hover:bg-surface-container-high hover:text-primary border-b border-outline-variant/30">↳ Apps Móviles</a>
        <a href="/servicios/sistemas-gestion-medida" class="px-5 py-4 pl-8 font-label-md text-sm text-on-surface-variant hover:bg-surface-container-high hover:text-primary border-b border-outline-variant/30">↳ Software a Medida</a>
        <a href="/blog" class="px-5 py-4 font-label-md text-sm text-on-surface-variant hover:bg-surface-container-high hover:text-primary border-b border-outline-variant/30">Blog Técnico</a>
        <a href="/#contacto" class="px-5 py-4 font-label-md text-sm text-primary hover:bg-surface-container-high">Contactar a Ventas</a>
      </div>
    </details>
