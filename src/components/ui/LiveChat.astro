---
// LiveChat.astro - Floating AI Chat Component
---

<div id="live-chat" class="fixed bottom-6 right-6 z-50">
  <!-- Chat Toggle Button -->
  <button id="chat-toggle" class="w-14 h-14 rounded-full bg-white text-black shadow-lg hover:shadow-[0_0_20px_rgba(255,255,255,0.15)] transition-all duration-300 flex items-center justify-center group" aria-label="Abrir chat">
    <svg id="chat-icon" class="w-6 h-6 transition-transform duration-300 group-hover:scale-110" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
    </svg>
    <svg id="close-icon" class="w-6 h-6 hidden transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <line x1="18" y1="6" x2="6" y2="18" />
      <line x1="6" y1="6" x2="18" y2="18" />
    </svg>
  </button>

  <!-- Chat Panel -->
  <div id="chat-panel" class="hidden fixed bottom-24 right-6 w-[380px] h-[520px] bg-neutral-950/90 backdrop-blur-xl border border-neutral-800 rounded-2xl shadow-2xl flex flex-col overflow-hidden animate-in">
    <!-- Header -->
    <div class="flex items-center justify-between px-5 py-4 border-b border-neutral-800">
      <div class="flex items-center gap-2.5">
        <div class="w-7 h-7 rounded-full bg-white/10 flex items-center justify-center">
          <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10" />
            <circle cx="12" cy="12" r="5" />
            <circle cx="12" cy="12" r="1" fill="currentColor" />
          </svg>
        </div>
        <div>
          <span class="text-sm font-medium text-white">VortexLM</span>
          <span class="text-[10px] text-neutral-500 font-mono uppercase tracking-widest ml-1.5">AI</span>
        </div>
      </div>
      <button id="chat-close" class="text-neutral-500 hover:text-white transition-colors duration-200">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>
    </div>

    <!-- Messages Area -->
    <div id="chat-messages" class="flex-1 overflow-y-auto px-5 py-4 space-y-4 scroll-smooth">
      <!-- Messages will be rendered here by JavaScript -->
    </div>

    <!-- Quick Actions (shown initially) -->
    <div id="quick-actions" class="px-5 pb-3 space-y-2">
      <button class="quick-btn w-full text-left px-4 py-2.5 rounded-xl bg-neutral-900/50 border border-neutral-800 text-sm text-neutral-300 hover:bg-neutral-800 hover:text-white hover:border-neutral-700 transition-all duration-200" data-message="Aplicación Web / SaaS">
        <span class="text-neutral-500 mr-2">→</span> Aplicación Web / SaaS
      </button>
      <button class="quick-btn w-full text-left px-4 py-2.5 rounded-xl bg-neutral-900/50 border border-neutral-800 text-sm text-neutral-300 hover:bg-neutral-800 hover:text-white hover:border-neutral-700 transition-all duration-200" data-message="Sitio Web Corporativo Premium">
        <span class="text-neutral-500 mr-2">→</span> Sitio Web Corporativo Premium
      </button>
      <button class="quick-btn w-full text-left px-4 py-2.5 rounded-xl bg-neutral-900/50 border border-neutral-800 text-sm text-neutral-300 hover:bg-neutral-800 hover:text-white hover:border-neutral-700 transition-all duration-200" data-message="Optimización de velocidad / Core Web Vitals">
        <span class="text-neutral-500 mr-2">→</span> Optimización de velocidad / Core Web Vitals
      </button>
    </div>

    <!-- Input Area -->
    <div class="px-5 py-4 border-t border-neutral-800">
      <div class="flex items-center gap-2">
        <input id="chat-input" type="text" placeholder="Escribe tu mensaje..." class="flex-1 bg-neutral-900 border border-neutral-800 rounded-xl px-4 py-2.5 text-sm text-white placeholder-neutral-600 outline-none focus:border-neutral-700 transition-all duration-200" />
        <button id="chat-send" class="w-10 h-10 rounded-xl bg-white text-black flex items-center justify-center hover:bg-neutral-200 transition-all duration-200 flex-shrink-0 disabled:opacity-50 disabled:cursor-not-allowed">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="22" y1="2" x2="11" y2="13" />
            <polygon points="22 2 15 22 11 13 2 9 22 2" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</div>

<style>
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(10px) scale(0.98); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }
  .animate-in { animation: fadeInUp 0.2s ease-out; }
  
  @keyframes pulse-dot {
    0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
    40% { transform: scale(1); opacity: 1; }
  }
  .typing-dot { animation: pulse-dot 1.4s infinite ease-in-out; }
  .typing-dot:nth-child(2) { animation-delay: 0.2s; }
  .typing-dot:nth-child(3) { animation-delay: 0.4s; }
  
  #chat-messages::-webkit-scrollbar { width: 4px; }
  #chat-messages::-webkit-scrollbar-track { background: transparent; }
  #chat-messages::-webkit-scrollbar-thumb { background: #333; border-radius: 2px; }
</style>

<script>
  const toggle = document.getElementById('chat-toggle');
  const panel = document.getElementById('chat-panel');
  const closeBtn = document.getElementById('chat-close');
  const chatIcon = document.getElementById('chat-icon');
  const closeIcon = document.getElementById('close-icon');
  const messagesContainer = document.getElementById('chat-messages');
  const input = document.getElementById('chat-input');
  const sendBtn = document.getElementById('chat-send');
  const quickActions = document.getElementById('quick-actions');

  let isOpen = false;
  let hasStarted = false;
  let messages = [];

  function toggleChat() {
    isOpen = !isOpen;
    panel.classList.toggle('hidden', !isOpen);
    chatIcon.classList.toggle('hidden', isOpen);
    closeIcon.classList.toggle('hidden', !isOpen);
    
    if (isOpen && !hasStarted) {
      hasStarted = true;
      showWelcome();
    }
    
    if (isOpen) {
      setTimeout(() => scrollToBottom(), 100);
    }
  }

  function showWelcome() {
    addMessage('Hola, bienvenido a VortexLM. ¿Qué tipo de software o plataforma web tienes en mente desarrollar?', 'assistant');
  }

  function addMessage(content, role, isStreaming = false) {
    const div = document.createElement('div');
    div.className = `flex ${role === 'user' ? 'justify-end' : 'justify-start'}`;
    
    const bubble = document.createElement('div');
    bubble.className = `max-w-[85%] px-4 py-2.5 text-sm leading-relaxed ${
      role === 'user'
        ? 'bg-neutral-800 text-white rounded-2xl rounded-br-md'
        : 'bg-neutral-900/50 text-neutral-200 rounded-2xl rounded-bl-md'
    }`;
    
    if (role === 'user' || !isStreaming) {
      bubble.textContent = content;
      div.appendChild(bubble);
      messagesContainer.appendChild(div);
      scrollToBottom();
      return;
    }
    
    // Typewriter mode for AI responses
    div.appendChild(bubble);
    messagesContainer.appendChild(div);
    
    let index = 0;
    const charsPerTick = 2; // Characters revealed per interval tick
    
    function typeNext() {
      if (index < content.length) {
        const nextIndex = Math.min(index + charsPerTick, content.length);
        bubble.textContent = content.substring(0, nextIndex);
        index = nextIndex;
        scrollToBottom();
        // Dynamic speed: faster for spaces/punctuation, slower for regular chars
        const char = content[index - 1] || '';
        const delay = (char === ' ' || char === '.' || char === ',' || char === '!' || char === '?') ? 15 : 25;
        setTimeout(typeNext, delay);
      }
    }
    
    typeNext();
  }

  function showTypingIndicator() {
    const div = document.createElement('div');
    div.id = 'typing-indicator';
    div.className = 'flex justify-start';
    div.innerHTML = `
      <div class="bg-neutral-900/50 rounded-2xl rounded-bl-md px-5 py-3 flex items-center gap-1.5">
        <span class="typing-dot w-1.5 h-1.5 bg-neutral-400 rounded-full inline-block"></span>
        <span class="typing-dot w-1.5 h-1.5 bg-neutral-400 rounded-full inline-block"></span>
        <span class="typing-dot w-1.5 h-1.5 bg-neutral-400 rounded-full inline-block"></span>
      </div>
    `;
    messagesContainer.appendChild(div);
    scrollToBottom();
  }

  function removeTypingIndicator() {
    const indicator = document.getElementById('typing-indicator');
    if (indicator) indicator.remove();
  }

  function scrollToBottom() {
    messagesContainer.scrollTop = messagesContainer.scrollHeight;
  }

  async function sendMessage(text) {
    if (!text.trim()) return;
    
    // Hide quick actions after first message
    quickActions.classList.add('hidden');
    
    // Add user message
    addMessage(text, 'user');
    messages.push({ role: 'user', content: text });
    
    // Clear input
    input.value = '';
    sendBtn.disabled = true;
    
    // Show typing indicator
    showTypingIndicator();
    
    try {
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages })
      });
      
      const data = await res.json();
      removeTypingIndicator();
      
      if (data.choices && data.choices[0]) {
        const reply = data.choices[0].message.content;
        addMessage(reply, 'assistant', true); // true = enable typewriter
        messages.push({ role: 'assistant', content: reply });
      } else {
        addMessage('Lo siento, ocurrió un error al procesar tu mensaje. Por favor, intenta de nuevo.', 'assistant');
      }
    } catch (err) {
      removeTypingIndicator();
      addMessage('Lo siento, ocurrió un error de conexión. Por favor, intenta de nuevo.', 'assistant');
    } finally {
      sendBtn.disabled = false;
    }
  }

  // Event Listeners
  toggle.addEventListener('click', toggleChat);
  closeBtn.addEventListener('click', toggleChat);

  sendBtn.addEventListener('click', () => sendMessage(input.value));
  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') sendMessage(input.value);
  });

  // Quick action buttons
  document.querySelectorAll('.quick-btn').forEach(btn => {
    btn.addEventListener('click', () => sendMessage(btn.dataset.message));
  });
</script>
