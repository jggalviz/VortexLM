---
interface Props {
  isLanding?: boolean;
}
const { isLanding = false } = Astro.props;
---
<header class="fixed top-0 left-0 w-full z-50 bg-black/80 backdrop-blur-md border-b border-[#171717]">
  <nav class="max-w-7xl mx-auto flex items-center justify-between px-6 py-4">
    <!-- Logo -->
    {
      isLanding ? (
        <a href="/" class="flex items-center gap-2 group focus:outline-none" aria-label="VortexLM Home">
          <svg class="w-6 h-6 text-white transition-transform duration-300 group-hover:rotate-45 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10" class="stroke-neutral-800" />
            <circle cx="12" cy="12" r="5" />
            <circle cx="12" cy="12" r="1" fill="currentColor" />
            <path d="M12 2v3M12 19v3M2 12h3M19 12h3" />
            <circle cx="12" cy="5" r="0.75" fill="currentColor" />
            <circle cx="12" cy="19" r="0.75" fill="currentColor" />
            <circle cx="5" cy="12" r="0.75" fill="currentColor" />
            <circle cx="19" cy="12" r="0.75" fill="currentColor" />
          </svg>

          <span class="font-sans text-lg font-semibold tracking-[0.15em] text-white uppercase transition-colors duration-200">
            Vortex<span class="font-light tracking-normal text-neutral-300 group-hover:text-neutral-400 ml-0.5">LM</span>
          </span>
        </a>
      ) : (
        <a href="/" class="flex items-center gap-2 group focus:outline-none" aria-label="VortexLM Home">
          <svg class="w-6 h-6 text-white transition-transform duration-300 group-hover:rotate-45 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10" class="stroke-neutral-800" />
            <circle cx="12" cy="12" r="5" />
            <circle cx="12" cy="12" r="1" fill="currentColor" />
            <path d="M12 2v3M12 19v3M2 12h3M19 12h3" />
            <circle cx="12" cy="5" r="0.75" fill="currentColor" />
            <circle cx="12" cy="19" r="0.75" fill="currentColor" />
            <circle cx="5" cy="12" r="0.75" fill="currentColor" />
            <circle cx="19" cy="12" r="0.75" fill="currentColor" />
          </svg>

          <span class="font-sans text-lg font-semibold tracking-[0.15em] text-white uppercase transition-colors duration-200">
            Vortex<span class="font-light tracking-normal text-neutral-300 group-hover:text-neutral-400 ml-0.5">LM</span>
          </span>
        </a>
      )
    }

    <!-- Desktop Nav Links (hidden on landing pages) -->
    {
      !isLanding && (
        <div class="hidden md:flex items-center gap-7">
          <a href="/" class="text-xs font-normal text-[#a3a3a3] hover:text-white transition-colors duration-300">Inicio</a>
          <a href="/servicios" class="text-xs font-normal text-[#a3a3a3] hover:text-white transition-colors duration-300">Servicios</a>
          <a href="/servicios/desarrollo-web-astro-react-nextjs" class="text-xs font-normal text-[#a3a3a3] hover:text-white transition-colors duration-300">Stack Moderno</a>
          <a href="/contacto" class="text-xs font-normal text-[#a3a3a3] hover:text-white transition-colors duration-300">Contacto</a>
          <!-- WhatsApp CTA -->
          <a
            href="https://wa.me/15072190951"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-4 py-2 bg-[#25D366] text-black text-xs font-semibold rounded-full hover:brightness-110 transition-all duration-200 active:scale-[0.97]"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Contacta con nuestro equipo
          </a>
        </div>
      )
    }

    <!-- CTA Button -->
    <div class="hidden md:flex items-center">
      {
        isLanding ? (
          <a href="#contacto-form" class="bg-white text-black text-xs font-medium px-4 py-2 rounded-md hover:bg-neutral-200 transition-all shadow-[0_0_15px_rgba(255,255,255,0.1)]">
            Cotizar Proyecto
          </a>
        ) : (
          <a href="/contacto" class="bg-white text-black text-xs font-medium px-4 py-2 rounded-md hover:bg-neutral-200 transition-all">
            Hablemos
          </a>
        )
      }
    </div>

    <!-- Mobile Menu (only for non-landing pages) -->
    {
      !isLanding && (
        <details class="md:hidden group relative">
          <summary class="list-none cursor-pointer text-[#a3a3a3] hover:text-white p-2">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
            </svg>
          </summary>
          <div class="absolute right-0 top-full mt-3 w-56 rounded-md shadow-2xl overflow-hidden flex flex-col z-50 bg-[#08080c]/95 border border-[#1f1f24]">
            <a href="/" class="px-5 py-3.5 text-xs text-[#a3a3a3] hover:bg-[#121216] hover:text-white border-b border-[#1f1f24] transition-colors">Inicio</a>
            <a href="/servicios" class="px-5 py-3.5 text-xs text-[#a3a3a3] hover:bg-[#121216] hover:text-white border-b border-[#1f1f24] transition-colors">Servicios</a>
            <a href="/servicios/desarrollo-web-astro-react-nextjs" class="px-5 py-3.5 text-xs text-[#a3a3a3] hover:bg-[#121216] hover:text-white border-b border-[#1f1f24] transition-colors">Stack Moderno</a>
            <a href="/contacto" class="px-5 py-3.5 text-xs text-[#a3a3a3] hover:bg-[#121216] hover:text-white border-b border-[#1f1f24] transition-colors">Contacto</a>
            <a
              href="https://wa.me/15072190951"
              target="_blank"
              rel="noopener noreferrer"
              class="px-5 py-3.5 text-xs text-white bg-[#25D366] hover:brightness-110 text-center font-semibold transition-all flex items-center justify-center gap-2"
            >
              <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Contacta con nuestro equipo
            </a>
          </div>
        </details>
      )
    }
  </nav>
</header>

<!-- Spacer to prevent content from hiding behind fixed header -->
<div class="h-[68px]"></div>
