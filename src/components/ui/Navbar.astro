---
// src/components/ui/Navbar.astro
// Global navigation — SSR-renders logged-out state by default; client script hydrates auth state

interface Props {
  isLanding?: boolean;
}
const { isLanding = false } = Astro.props;

// NOTE: We intentionally do NOT call supabase.auth.getSession() here in SSR.
// Doing so would make the entire Navbar (and thus every page) dependent on Supabase
// being reachable during SSR. If Supabase is unreachable, the page would fail to render.
// Instead, we always render the logged-out state from the server, and a lightweight
// client-side script (<script> below) reads the Supabase session cookie directly
// from the browser and updates the button text/link/href accordingly.
// This is more robust: the Navbar always renders, and the correct auth state appears
// immediately after the page loads in the browser.
const isLoggedIn = false;
---
<header class="fixed top-0 left-0 w-full z-50 bg-black/80 backdrop-blur-md border-b border-[#171717]">
  <nav class="max-w-7xl mx-auto flex items-center justify-between px-6 py-4">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 group focus:outline-none" aria-label="VortexLM Home">
      <svg class="w-6 h-6 text-white transition-transform duration-300 group-hover:rotate-45 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10" class="stroke-neutral-800" />
        <circle cx="12" cy="12" r="5" />
        <circle cx="12" cy="12" r="1" fill="currentColor" />
        <path d="M12 2v3M12 19v3M2 12h3M19 12h3" />
        <circle cx="12" cy="5" r="0.75" fill="currentColor" />
        <circle cx="12" cy="19" r="0.75" fill="currentColor" />
        <circle cx="5" cy="12" r="0.75" fill="currentColor" />
        <circle cx="19" cy="12" r="0.75" fill="currentColor" />
      </svg>

      <span class="font-sans text-lg font-semibold tracking-[0.15em] text-white uppercase transition-colors duration-200">
        Vortex<span class="font-light tracking-normal text-neutral-300 group-hover:text-neutral-400 ml-0.5">LM</span>
      </span>
    </a>

    <!-- Desktop Nav Links (visible on all pages) -->
    <div class="hidden md:flex items-center gap-7">
      <a href="/" class="text-xs font-normal text-[#a3a3a3] hover:text-white transition-colors duration-300">Inicio</a>
      <a href="/servicios" class="text-xs font-normal text-[#a3a3a3] hover:text-white transition-colors duration-300">Servicios</a>
      <a href="/servicios/desarrollo-web-astro-react-nextjs" class="text-xs font-normal text-[#a3a3a3] hover:text-white transition-colors duration-300">Stack Moderno</a>
      <a href="/contacto" class="text-xs font-normal text-[#a3a3a3] hover:text-white transition-colors duration-300">Contacto</a>
      <!-- WhatsApp CTA — premium dark theme style -->
      <a
        href="https://wa.me/15072190951"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-4 py-2 border border-white/20 text-white text-xs font-medium rounded-full hover:bg-white/10 hover:border-white/40 transition-all duration-300 active:scale-[0.97]"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Contacta con nuestro equipo
      </a>
    </div>

    <!-- Auth Button — visible on all screen sizes -->
    <div class="flex items-center gap-3">
      {
        isLoggedIn ? (
          <a
            data-auth-btn
            href="/dashboard"
            class="inline-flex items-center gap-2 px-4 py-2 bg-white text-black text-xs font-medium rounded-md hover:bg-neutral-200 transition-all shadow-[0_0_15px_rgba(255,255,255,0.1)] active:scale-[0.97]"
          >
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955a1.126 1.126 0 011.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
            </svg>
            Ir a mi Escritorio
          </a>
        ) : (
          <a
            data-auth-btn
            href="/login"
            class="inline-flex items-center gap-2 px-4 py-2 border border-white/20 text-white text-xs font-medium rounded-full hover:bg-white/10 hover:border-white/40 transition-all duration-300 active:scale-[0.97]"
          >
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15m3 0l3-3m0 0l-3-3m3 3H9" />
            </svg>
            Iniciar Sesión
          </a>
        )
      }
      {
        !isLoggedIn && isLanding ? (
          <a href="#contacto-form" class="hidden md:inline-flex bg-white text-black text-xs font-medium px-4 py-2 rounded-md hover:bg-neutral-200 transition-all shadow-[0_0_15px_rgba(255,255,255,0.1)]">
            Cotizar Proyecto
          </a>
        ) : !isLoggedIn ? (
          <a href="/contacto" class="hidden md:inline-flex bg-white text-black text-xs font-medium px-4 py-2 rounded-md hover:bg-neutral-200 transition-all">
            Hablemos
          </a>
        ) : null
      }
    </div>

    <!-- Mobile Menu (visible on all pages) -->
    <details class="md:hidden group relative">
      <summary class="list-none cursor-pointer text-[#a3a3a3] hover:text-white p-2">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </summary>
      <div class="absolute right-0 top-full mt-3 w-56 rounded-md shadow-2xl overflow-hidden flex flex-col z-50 bg-[#08080c]/95 border border-[#1f1f24]">
        <a href="/" class="px-5 py-3.5 text-xs text-[#a3a3a3] hover:bg-[#121216] hover:text-white border-b border-[#1f1f24] transition-colors">Inicio</a>
        <a href="/servicios" class="px-5 py-3.5 text-xs text-[#a3a3a3] hover:bg-[#121216] hover:text-white border-b border-[#1f1f24] transition-colors">Servicios</a>
        <a href="/servicios/desarrollo-web-astro-react-nextjs" class="px-5 py-3.5 text-xs text-[#a3a3a3] hover:bg-[#121216] hover:text-white border-b border-[#1f1f24] transition-colors">Stack Moderno</a>
        <a href="/contacto" class="px-5 py-3.5 text-xs text-[#a3a3a3] hover:bg-[#121216] hover:text-white border-b border-[#1f1f24] transition-colors">Contacto</a>
        <!-- WhatsApp CTA — premium dark theme style -->
        <a
          href="https://wa.me/15072190951"
          target="_blank"
          rel="noopener noreferrer"
          class="px-5 py-3.5 text-xs text-white border-t border-[#1f1f24] hover:bg-[#121216] transition-colors flex items-center justify-center gap-2 font-medium"
        >
          <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Contacta con nuestro equipo
        </a>
        <!-- Mobile auth link -->
        {
          isLoggedIn ? (
            <a
              data-auth-mobile
              href="/dashboard"
              class="px-5 py-3.5 text-xs text-white bg-white/10 hover:bg-white/20 text-center font-medium transition-colors border-t border-[#1f1f24] flex items-center justify-center gap-2"
            >
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955a1.126 1.126 0 011.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
              </svg>
              Ir a mi Escritorio
            </a>
          ) : (
            <a
              data-auth-mobile
              href="/login"
              class="px-5 py-3.5 text-xs text-white bg-white/10 hover:bg-white/20 text-center font-medium transition-colors border-t border-[#1f1f24] flex items-center justify-center gap-2"
            >
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15m3 0l3-3m0 0l-3-3m3 3H9" />
              </svg>
              Iniciar Sesión
            </a>
          )
        }
      </div>
    </details>
  </nav>
</header>

<!-- Spacer to prevent content from hiding behind fixed header -->
<div class="h-[68px]"></div>

<script>
  /**
   * Client-side hydration script for auth-aware navigation button.
   *
   * WHY THIS IS NEEDED:
   * Even though the site runs in SSR mode (output: 'server'), Vercel's Edge CDN
   * may cache the HTML response for the home page and other public routes. This means
   * the server-side `supabase.auth.getSession()` check in the frontmatter might not
   * run on every request if the response is served from a cached edge node.
   *
   * This script runs in the browser after the page loads, reads the Supabase session
   * cookie directly, and updates the button text/link/href accordingly. This ensures
   * the correct auth state is always displayed, even if the SSR-rendered HTML was cached.
   *
   * The script targets the auth button by its data attribute (data-auth-btn) and the
   * mobile auth link by its data attribute (data-auth-mobile), avoiding conflicts with
   * any other elements on the page.
   */
  (function() {
    // Check if there's a Supabase session by looking for the auth cookie
    // Supabase stores the session in a cookie named 'sb-<project-ref>-auth-token'
    // We check for any cookie starting with 'sb-'
    const hasSession = document.cookie
      .split('; ')
      .some(cookie => cookie.startsWith('sb-'));

    const authBtn = document.querySelector('[data-auth-btn]');
    const authMobile = document.querySelector('[data-auth-mobile]');

    if (hasSession) {
      // User is logged in — show "Ir a mi Escritorio"
      if (authBtn) {
        authBtn.setAttribute('href', '/dashboard');
        authBtn.innerHTML = `<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955a1.126 1.126 0 011.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" /></svg> Ir a mi Escritorio`;
        authBtn.className = 'inline-flex items-center gap-2 px-4 py-2 bg-white text-black text-xs font-medium rounded-md hover:bg-neutral-200 transition-all shadow-[0_0_15px_rgba(255,255,255,0.1)] active:scale-[0.97]';
      }
      if (authMobile) {
        authMobile.setAttribute('href', '/dashboard');
        authMobile.innerHTML = `<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955a1.126 1.126 0 011.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" /></svg> Ir a mi Escritorio`;
        authMobile.className = 'px-5 py-3.5 text-xs text-white bg-white/10 hover:bg-white/20 text-center font-medium transition-colors border-t border-[#1f1f24] flex items-center justify-center gap-2';
      }
    } else {
      // User is logged out — show "Iniciar Sesión"
      if (authBtn) {
        authBtn.setAttribute('href', '/login');
        authBtn.innerHTML = `<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15m3 0l3-3m0 0l-3-3m3 3H9" /></svg> Iniciar Sesión`;
        authBtn.className = 'inline-flex items-center gap-2 px-4 py-2 border border-white/20 text-white text-xs font-medium rounded-full hover:bg-white/10 hover:border-white/40 transition-all duration-300 active:scale-[0.97]';
      }
      if (authMobile) {
        authMobile.setAttribute('href', '/login');
        authMobile.innerHTML = `<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15m3 0l3-3m0 0l-3-3m3 3H9" /></svg> Iniciar Sesión`;
        authMobile.className = 'px-5 py-3.5 text-xs text-white bg-white/10 hover:bg-white/20 text-center font-medium transition-colors border-t border-[#1f1f24] flex items-center justify-center gap-2';
      }
    }
  })();
</script>
