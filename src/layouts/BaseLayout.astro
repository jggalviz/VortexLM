---
import SEO from '../components/seo/SEO.astro';
import Header from '../components/ui/Header.astro';
import Footer from '../components/ui/Footer.astro';

export interface Props {
  title: string;
  description: string;
  isLocalBusiness?: boolean;
  type?: 'website' | 'article';
}

const { title, description, isLocalBusiness, type = 'website' } = Astro.props;
---
<html lang="es" class="scroll-smooth dark">
  <head>
    <SEO title={title} description={description} isLocalBusiness={isLocalBusiness} type={type} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <style is:global>
      /* Main theme setup for Linear.app style */
      html {
          background-color: #000000;
          color: #f7f7f8;
      }
      .linear-card {
          background: rgba(8, 8, 12, 0.4);
          backdrop-filter: blur(20px);
          border: 1px solid rgba(255, 255, 255, 0.05);
          box-shadow: 0 30px 60px -15px rgba(0, 0, 0, 0.9), inset 0 1px 0 rgba(255, 255, 255, 0.05);
          position: relative;
          overflow: hidden;
      }
      .linear-card::before {
          content: '';
          position: absolute;
          top: 0;
          left: 0;
          right: 0;
          height: 1px;
          background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
          pointer-events: none;
      }
      .glow-hover:hover {
          border-color: rgba(255, 255, 255, 0.15) !important;
          box-shadow: 0 0 30px rgba(255, 255, 255, 0.03), inset 0 1px 0 rgba(255, 255, 255, 0.1);
      }
      .linear-grid {
          background-image: radial-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px);
          background-size: 32px 32px;
      }
      .glow-line {
          height: 1px;
          background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.08), transparent);
      }
      .linear-gradient-bg {
          background: radial-gradient(circle at top center, rgba(255, 255, 255, 0.03) 0%, rgba(0, 0, 0, 1) 70%);
      }
      .material-symbols-outlined {
          font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
      }
    </style>
  </head>
  <body class="bg-[#000000] text-[#f7f7f8] font-body-md linear-grid min-h-screen overflow-x-hidden flex flex-col">
    <Header />
    <main class="flex-grow">
      <slot />
    </main>
    <Footer />
  </body>
</html>
