---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export const prerender = true;

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// Fallback image in case the local one is broken during dev
const imageUrl = entry.data.image || "https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&fit=crop&w=1200&q=80";
---
<BaseLayout 
  title={entry.data.title} 
  description={entry.data.description}
  type="article"
>
  <article class="pt-10 pb-20 px-4 md:px-8 max-w-3xl mx-auto">
    <div class="mb-12 text-center">
      <div class="inline-block px-3 py-1 mb-6 rounded-full bg-blue-900/30 border border-blue-800 text-xs font-semibold text-blue-400 uppercase tracking-wider">
        {entry.data.category}
      </div>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white mb-6 leading-[1.1]">{entry.data.title}</h1>
      <div class="flex items-center justify-center space-x-4 text-sm text-slate-400">
        <span class="font-medium text-slate-300 flex items-center gap-2">
          <div class="w-6 h-6 rounded-full bg-gradient-to-tr from-blue-600 to-indigo-600"></div>
          {entry.data.author || 'VortexLM'}
        </span>
        <span>&bull;</span>
        <time>{entry.data.pubDate.toLocaleDateString('es-VE', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
      </div>
    </div>
    
    <div class="w-full aspect-[21/9] rounded-3xl overflow-hidden mb-16 shadow-2xl shadow-blue-900/20 border border-slate-800">
      <img 
        src={imageUrl} 
        alt={entry.data.title} 
        class="w-full h-full object-cover" 
        onerror="this.src='https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&fit=crop&w=1200&q=80'"
      />
    </div>
    
    <div class="prose prose-invert prose-lg prose-blue max-w-none 
                prose-headings:font-bold prose-headings:tracking-tight
                prose-h2:text-3xl prose-h2:mt-12 prose-h2:mb-6 prose-h2:text-white
                prose-h3:text-2xl prose-h3:mt-8 prose-h3:text-slate-200
                prose-p:text-slate-300 prose-p:leading-relaxed
                prose-a:text-blue-400 hover:prose-a:text-blue-300 prose-a:decoration-blue-500/30 prose-a:underline-offset-4
                prose-strong:text-white prose-strong:font-bold
                prose-ul:text-slate-300 prose-li:marker:text-blue-500
                prose-img:rounded-2xl prose-img:border prose-img:border-slate-800
                prose-hr:border-slate-800">
      <Content />
    </div>
  </article>
</BaseLayout>
