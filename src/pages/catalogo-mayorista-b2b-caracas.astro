---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import dashboardMockup from '../assets/images/dashboard-saas.jpg';

const isLanding = true;
---

<BaseLayout
  title="Catálogo Mayorista B2B | Automatiza tus Ventas al por Mayor"
  description="Automatiza tus ventas al mayor con un catálogo web ultra rápido. Ideal para distribuidoras, importadoras y ventas de repuestos en Caracas."
  isLanding={isLanding}
>
  <!-- ===== 1. HERO SECTION ===== -->
  <section class="relative pt-36 pb-32 overflow-hidden bg-black border-b border-[#1f1f24] px-6 md:px-12">
    <!-- Grid Overlay sutil -->
    <div class="absolute inset-0 linear-grid opacity-30 pointer-events-none"></div>
    
    <!-- Background decoration -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-white/[0.015] blur-[120px] rounded-full"></div>
      <div class="absolute -top-40 -right-40 w-96 h-96 bg-white/[0.02] blur-[100px] rounded-full"></div>
      <div class="absolute -bottom-40 -left-40 w-96 h-96 bg-white/[0.02] blur-[100px] rounded-full"></div>
    </div>
    
    <div class="max-w-[1200px] mx-auto text-center relative z-10">
      <!-- Cintillo superior -->
      <div class="mb-8">
        <span class="inline-block text-[10px] font-mono text-[#cbd5e1] uppercase tracking-widest font-medium bg-[#08080c]/60 px-4 py-2 rounded-full border border-[#1f1f24]">
          SOLUCIONES DIGITALES B2B PARA DISTRIBUIDORAS
        </span>
      </div>
      
      <!-- Título Principal H1 -->
      <h1 class="text-4xl md:text-7xl font-extralight tracking-tight text-white mb-8 leading-[1.08] max-w-4xl mx-auto opacity-95">
        Automatiza tus Ventas al Mayor con un Catálogo Web Ultra Rápido
      </h1>
      
      <!-- Subtítulo -->
      <p class="text-base md:text-lg text-[#cbd5e1] font-light mb-12 max-w-3xl mx-auto leading-relaxed">
        Elimina los PDFs pesados y las notas de voz eternas. Permite que tus clientes corporativos y tiendas aliadas consulten tu stock en tiempo real y armen sus pedidos en segundos, optimizado para las conexiones móviles de Caracas.
      </p>
      
      <!-- CTA Button -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
        <a
          href="#contacto"
          class="w-full sm:w-auto px-8 py-3 bg-white text-black font-semibold text-xs rounded-full hover:bg-neutral-200 transition-all duration-200 active:scale-95 shadow-[0_0_25px_rgba(255,255,255,0.15)] text-center"
        >
          Digitalizar mi Catálogo
        </a>
        <a
          href="#solucion"
          class="w-full sm:w-auto px-6 py-3 text-white/90 font-medium text-xs rounded-full hover:text-white flex items-center justify-center gap-1.5 group transition-colors"
        >
          Ver solución <span class="group-hover:translate-x-1 transition-transform">➔</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== 2. AGITACIÓN (El Dolor) ===== -->
  <section class="py-36 px-6 md:px-12 bg-black relative border-b border-[#1f1f24]">
    <div class="max-w-[1200px] mx-auto relative z-10">
      <h2 class="text-2xl md:text-4xl font-light text-white tracking-tight leading-snug text-center mb-24">
        ¿Sigue tu distribuidora levantando pedidos de forma manual?
      </h2>
      
      <div class="grid md:grid-cols-3 gap-8 lg:gap-12">
        <!-- Card 1: PDFs obsoletos -->
        <div class="linear-card rounded-lg border border-[#1f1f24] bg-[#08080c]/30 p-8 glow-hover transition-all group">
          <div class="w-14 h-14 bg-red-500/10 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
          </div>
          <h3 class="text-sm font-medium text-white mb-2.5">PDFs obsoletos</h3>
          <p class="text-xs text-[#cbd5e1] leading-relaxed">
            Mandas un catálogo digital en la mañana y al mediodía ya cambió el stock o el precio.
          </p>
        </div>
        
        <!-- Card 2: Caos en WhatsApp -->
        <div class="linear-card rounded-lg border border-[#1f1f24] bg-[#08080c]/30 p-8 glow-hover transition-all group">
          <div class="w-14 h-14 bg-orange-500/10 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
            </svg>
          </div>
          <h3 class="text-sm font-medium text-white mb-2.5">Caos en WhatsApp</h3>
          <p class="text-xs text-[#cbd5e1] leading-relaxed">
            Horas perdidas transcribiendo códigos de repuestos o SKUs mal dictados.
          </p>
        </div>
        
        <!-- Card 3: Páginas lentas -->
        <div class="linear-card rounded-lg border border-[#1f1f24] bg-[#08080c]/30 p-8 glow-hover transition-all group">
          <div class="w-14 h-14 bg-yellow-500/10 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h3 class="text-sm font-medium text-white mb-2.5">Páginas lentas</h3>
          <p class="text-xs text-[#cbd5e1] leading-relaxed">
            Sitios web pesados que no abren en la calle con datos móviles locales, espantando a los compradores.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 3. LA SOLUCIÓN TÉCNICA ===== -->
  <section id="solucion" class="py-36 px-6 md:px-12 bg-black relative border-b border-[#1f1f24]">
    <div class="max-w-[1200px] mx-auto relative z-10">
      <h2 class="text-2xl md:text-4xl font-light text-white tracking-tight leading-snug text-center mb-24">
        Tu inventario y tus pedidos bajo control en una sola plataforma
      </h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 items-center">
        <!-- Dashboard SaaS Image -->
        <div>
          <Image
            src={dashboardMockup}
            alt="Dashboard del Sistema Administrativo SaaS - Vortex LM"
            format="webp"
            quality={85}
            class="rounded-lg border border-[#1f1f24] shadow-[0_0_50px_rgba(0,0,0,0.8)] w-full h-auto object-cover"
            loading="lazy"
          />
        </div>
        
        <!-- Beneficios -->
        <div class="space-y-8">
          <!-- Beneficio 1 -->
          <div class="flex gap-4">
            <div class="flex-shrink-0 w-12 h-12 bg-white/5 rounded-lg flex items-center justify-center">
              <svg class="w-6 h-6 text-[#cbd5e1]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
            </div>
            <div>
              <h3 class="text-sm font-medium text-white mb-1">Carga Récord en Datos Móviles</h3>
              <p class="text-xs text-[#cbd5e1] leading-relaxed">Programado en Astro para garantizar carga instantánea en zonas industriales (La Yaguara, Boleíta, Los Ruices).</p>
            </div>
          </div>
          
          <!-- Beneficio 2 -->
          <div class="flex gap-4">
            <div class="flex-shrink-0 w-12 h-12 bg-white/5 rounded-lg flex items-center justify-center">
              <svg class="w-6 h-6 text-[#cbd5e1]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
              </svg>
            </div>
            <div>
              <h3 class="text-sm font-medium text-white mb-1">Buscador Inteligente de Piezas</h3>
              <p class="text-xs text-[#cbd5e1] leading-relaxed">Búsqueda exacta por número de parte, código de barra, SKU o marca.</p>
            </div>
          </div>
          
          <!-- Beneficio 3 -->
          <div class="flex gap-4">
            <div class="flex-shrink-0 w-12 h-12 bg-white/5 rounded-lg flex items-center justify-center">
              <svg class="w-6 h-6 text-[#cbd5e1]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"/>
              </svg>
            </div>
            <div>
              <h3 class="text-sm font-medium text-white mb-1">Carrito a WhatsApp o Admin</h3>
              <p class="text-xs text-[#cbd5e1] leading-relaxed">Pedidos masivos desglosados directo al equipo de ventas o al panel interno.</p>
            </div>
          </div>
          
          <!-- Beneficio 4 -->
          <div class="flex gap-4">
            <div class="flex-shrink-0 w-12 h-12 bg-white/5 rounded-lg flex items-center justify-center">
              <svg class="w-6 h-6 text-[#cbd5e1]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/>
              </svg>
            </div>
            <div>
              <h3 class="text-sm font-medium text-white mb-1">Métodos de Pago Flexibles</h3>
              <p class="text-xs text-[#cbd5e1] leading-relaxed">Toggles manuales para Zelle, Pago Móvil, Binance o transferencias en el checkout.</p>
            </div>
          </div>
          
          <!-- Beneficio 5 -->
          <div class="flex gap-4">
            <div class="flex-shrink-0 w-12 h-12 bg-white/5 rounded-lg flex items-center justify-center">
              <svg class="w-6 h-6 text-[#cbd5e1]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
              </svg>
            </div>
            <div>
              <h3 class="text-sm font-medium text-white mb-1">Portal de Cliente en Vortex LM</h3>
              <p class="text-xs text-[#cbd5e1] leading-relaxed">Acceso privado para monitorear el avance del proyecto, soporte, facturación y datos técnicos de su cuenta las 24 horas.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 4. PRECIOS ===== -->
  <section class="py-36 px-6 md:px-12 bg-black relative border-b border-[#1f1f24]">
    <div class="max-w-[1200px] mx-auto relative z-10">
      <div class="text-center max-w-2xl mx-auto mb-20">
        <span class="text-[10px] font-mono text-[#cbd5e1] uppercase tracking-widest block mb-3 font-semibold">Inversión</span>
        <h2 class="text-3xl md:text-5xl font-light text-white tracking-tight">
          Inversión transparente, sin sorpresas
        </h2>
        <p class="text-sm text-[#cbd5e1] font-light leading-relaxed mt-4 max-w-xl mx-auto">
          Despliegue robusto utilizando infraestructura serverless de alta gama (Vercel + Supabase) para garantizar cero caídas.
        </p>
      </div>
      
      <div class="max-w-lg mx-auto">
        <div class="linear-card rounded-lg border border-[#1f1f24] bg-[#08080c]/40 p-8 relative">
          <!-- Badge "Más Popular" -->
          <div class="absolute -top-3 left-1/2 -translate-x-1/2">
            <span class="text-[10px] font-mono text-[#cbd5e1] uppercase tracking-widest bg-[#08080c] border border-[#1f1f24] text-white text-xs font-medium px-4 py-1 rounded-full">
              PLAN ÚNICO
            </span>
          </div>
          
          <div class="mt-4">
            <h3 class="text-sm font-medium text-white mb-2">Desarrollo de Catálogo Mayorista B2B</h3>
            <div class="mb-6">
              <span class="text-4xl font-light text-white tracking-tight">Desde $850 USD</span>
              <p class="text-xs text-[#cbd5e1] font-light mt-1">Pago fraccionado: 50% inicial / 50% contra entrega</p>
            </div>
            
            <ul class="space-y-3 mb-8">
              <li class="flex items-start gap-3 text-xs text-[#cbd5e1]">
                <svg class="w-4 h-4 text-[#cbd5e1] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                Base de datos Supabase integrada
              </li>
              <li class="flex items-start gap-3 text-xs text-[#cbd5e1]">
                <svg class="w-4 h-4 text-[#cbd5e1] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                Front-end en Vercel
              </li>
              <li class="flex items-start gap-3 text-xs text-[#cbd5e1]">
                <svg class="w-4 h-4 text-[#cbd5e1] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                Buscador indexado
              </li>
              <li class="flex items-start gap-3 text-xs text-[#cbd5e1]">
                <svg class="w-4 h-4 text-[#cbd5e1] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                Carrito automatizado
              </li>
              <li class="flex items-start gap-3 text-xs text-[#cbd5e1]">
                <svg class="w-4 h-4 text-[#cbd5e1] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                Soporte multi-moneda
              </li>
              <li class="flex items-start gap-3 text-xs text-[#cbd5e1]">
                <svg class="w-4 h-4 text-[#cbd5e1] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                Acceso privado al Portal de Cliente en vortexlm.com
              </li>
            </ul>
            
            <div class="border-t border-[#1f1f24] pt-6">
              <p class="text-xs font-medium text-[#cbd5e1] mb-2">Mantenimiento mensual:</p>
              <p class="text-xs text-[#cbd5e1] font-light">
                <span class="text-white font-medium">$80 USD/mes</span>
              </p>
              <p class="text-[10px] text-[#cbd5e1]/40 mt-1">Incluye optimización de Supabase, monitoreo en Vercel y soporte prioritario ante cambios de API.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 5. FORMULARIO DE CIERRE ===== -->
  <section id="contacto" class="py-36 px-6 md:px-12 bg-black relative">
    <div class="max-w-[600px] mx-auto text-center relative z-10 space-y-8">
      <span class="text-[10px] font-mono text-[#cbd5e1] uppercase tracking-widest block font-medium">Inicia hoy</span>
      <h2 class="text-3xl md:text-5xl font-light text-white tracking-tight leading-tight">
        Moderniza la logística de tus ventas hoy mismo
      </h2>
      <p class="text-sm text-[#cbd5e1] font-light leading-relaxed">
        Agenda una sesión técnica de 15 minutos y te mostramos cómo adaptar nuestro sistema a tu modelo de negocio.
      </p>
      
      <div class="linear-card p-8 rounded-lg border border-[#1f1f24] bg-[#08080c]/40 text-left space-y-6">
        <form id="contact-form-b2b" class="space-y-4" action="/api/contact" method="POST">
          <div>
            <label for="nombre" class="block text-[10px] font-mono text-[#cbd5e1] uppercase tracking-wider mb-2 font-medium">Nombre del Contacto</label>
            <input type="text" id="nombre" name="name" required
              class="w-full bg-black border border-[#1f1f24] rounded px-4 py-3 text-xs text-white placeholder-neutral-800 focus:outline-none focus:border-white transition-colors"
              placeholder="Tu nombre completo">
          </div>
          
          <div>
            <label for="empresa" class="block text-[10px] font-mono text-[#cbd5e1] uppercase tracking-wider mb-2 font-medium">Nombre de la Distribuidora / Importadora</label>
            <input type="text" id="empresa" name="empresa" required
              class="w-full bg-black border border-[#1f1f24] rounded px-4 py-3 text-xs text-white placeholder-neutral-800 focus:outline-none focus:border-white transition-colors"
              placeholder="Nombre de tu empresa">
          </div>
          
          <div>
            <label for="whatsapp" class="block text-[10px] font-mono text-[#cbd5e1] uppercase tracking-wider mb-2 font-medium">WhatsApp de Contacto</label>
            <input type="tel" id="whatsapp" name="whatsapp" required
              class="w-full bg-black border border-[#1f1f24] rounded px-4 py-3 text-xs text-white placeholder-neutral-800 focus:outline-none focus:border-white transition-colors"
              placeholder="+58 412 123 4567">
          </div>
          
          <div>
            <label for="productos" class="block text-[10px] font-mono text-[#cbd5e1] uppercase tracking-wider mb-2 font-medium">¿Qué tipo de productos distribuyes?</label>
            <textarea id="productos" name="message" rows="3" required
              class="w-full bg-black border border-[#1f1f24] rounded px-4 py-3 text-xs text-white placeholder-neutral-800 focus:outline-none focus:border-white transition-colors min-h-[100px] resize-none"
              placeholder="Ej: Repuestos automotrices, equipos industriales, ferretería..."></textarea>
          </div>

          <input type="hidden" name="service" value="catalogo-mayorista-b2b-caracas" />
          
          <button type="submit"
            class="w-full py-3 bg-white text-black font-semibold text-xs rounded hover:bg-neutral-200 transition-colors duration-200">
            Solicitar Demo de Catálogo B2B
          </button>

          <p id="form-status-b2b" class="text-sm text-center hidden"></p>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  document.getElementById('contact-form-b2b')?.addEventListener('submit', async function(e) {
    e.preventDefault();
    const form = e.target;
    const status = document.getElementById('form-status-b2b');
    const btn = form.querySelector('button[type="submit"]');
    const originalText = btn.textContent;
    btn.textContent = 'Enviando...';
    btn.disabled = true;
    status.classList.add('hidden');
    try {
      const formData = new FormData(form);
      const res = await fetch('/api/contact', { method: 'POST', body: formData });
      const data = await res.json();
      if (res.ok) {
        status.textContent = '✅ ¡Mensaje enviado! Te contactaremos pronto.';
        status.classList.remove('hidden', 'text-red-400');
        status.classList.add('text-green-400');
        form.reset();
      } else {
        throw new Error(data.error || 'Error al enviar');
      }
    } catch (err) {
      status.textContent = '❌ Error al enviar. Intenta de nuevo o escríbenos a info@vortexlm.com';
      status.classList.remove('hidden', 'text-green-400');
      status.classList.add('text-red-400');
    }
    btn.textContent = originalText;
    btn.disabled = false;
  });
</script>
