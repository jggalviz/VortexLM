---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/seo/SEO.astro';
import FAQSchema from '../components/seo/FAQSchema.astro';
import VCreditsExplanation from '../components/ui/VCreditsExplanation.astro';
import ClientDashboardPreview from '../components/ui/ClientDashboardPreview.astro';
import TransparencyTracking from '../components/ui/TransparencyTracking.astro';
import B2BExpandLinks from '../components/ui/B2BExpandLinks.astro';

const isLanding = true;
const pageTitle = '¿Cómo funciona VortexLM? — vCredits, Dashboard y Transparencia Total';
const pageDescription =
  'Descubre el modelo vCredits de VortexLM: pago por consumo real de desarrollo frontend y WordPress. Dashboard en tiempo real, transparencia total y sin contratos fijos.';
const canonicalURL = 'https://vortexlm.com/como-funciona';

const faqItems = [
  {
    question: '¿Qué es un vCredit?',
    answer:
      'Un vCredit equivale a una hora de desarrollo especializado. Compras paquetes de vCredits y se descuentan en tiempo real según el consumo de tu agencia.',
  },
  {
    question: '¿Cómo asigno tareas?',
    answer:
      'Desde tu dashboard publicas proyectos con el alcance, prioridad y tecnologías requeridas. Nuestro equipo se activa automáticamente.',
  },
  {
    question: '¿Puedo ver el progreso en tiempo real?',
    answer:
      'Sí. Cada tarea registra el tiempo exacto de desarrollo y puedes consultar el avance, horas invertidas y vCredits consumidos desde tu dashboard.',
  },
  {
    question: '¿Hay contrato mínimo?',
    answer:
      'No. Compras vCredits sin compromiso mensual. El saldo no caduca y solo pagas por el desarrollo que realmente consumes.',
  },
];
---

<BaseLayout title={pageTitle} description={pageDescription} isLanding={isLanding} type="website">
  <SEO title={pageTitle} description={pageDescription} canonicalURL={canonicalURL} type="website" />
  <FAQSchema faqs={faqItems} />

  <main class="bg-neutral-950 text-white">
    <!-- HERO SECTION -->
    <section aria-label="Introducción">
      <div class="relative">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 sm:py-32">
          <div class="flex justify-center mb-6">
            <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-linear-border bg-linear-charcoal/50 backdrop-blur-sm text-xs font-label-md tracking-wider uppercase text-linear-muted">
              <span class="w-1.5 h-1.5 rounded-full bg-linear-accent"></span>
              GUÍA COMPLETA
            </span>
          </div>
          <h1 class="text-center font-heading text-[clamp(2rem,5vw,4rem)] font-light tracking-tight text-white leading-[1.1] max-w-4xl mx-auto">
            ¿Cómo funciona <span class="text-linear-accent">VortexLM</span>?
          </h1>
          <p class="text-center text-neutral-400 font-body-md text-lg max-w-2xl mx-auto mt-6">
            Todo lo que tu agencia necesita saber sobre el modelo vCredits: desde la compra de créditos hasta la entrega de proyectos white label.
          </p>
        </div>
        <div class="absolute bottom-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-white/[0.06] to-transparent" aria-hidden="true"></div>
      </div>
    </section>

    <!-- VCREDITS EXPLANATION -->
    <VCreditsExplanation />

    <!-- CLIENT DASHBOARD PREVIEW -->
    <ClientDashboardPreview />

    <!-- TRANSPARENCY TRACKING -->
    <TransparencyTracking />

    <!-- FAQ SECTION -->
    <section aria-label="Preguntas frecuentes" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 sm:py-32">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-center font-heading text-[clamp(1.5rem,3vw,2.5rem)] font-light tracking-tight text-white mb-4">
          Preguntas frecuentes
        </h2>
        <p class="text-center text-neutral-400 font-body-md text-lg mb-12">
          Resolvemos tus dudas sobre el modelo vCredits
        </p>
        <FAQSchema faqs={faqItems} />
      </div>
    </section>

    <!-- B2B EXPAND LINKS — Semantic navigation cards -->
    <B2BExpandLinks />
  </main>
</BaseLayout>
