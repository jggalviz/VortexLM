---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contacta con Nuestros Especialistas en Software y Web | Vortex"
  description="¿Tienes una idea o proyecto en mente? Contacta con los especialistas en software y desarrollo web de Vortex. Diseñamos sistemas escalables y páginas web de alto rendimiento."
>
  <!-- SPLIT-SCREEN CONTACT SECTION -->
  <section class="min-h-screen py-36 px-6 md:px-12 bg-black border-b border-[#1f1f24]">
    <div class="max-w-[1200px] mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-start">
      
      <!-- LEFT COLUMN: Contact Info + Copy -->
      <div class="relative z-10">
        <div class="absolute top-0 left-0 w-[400px] h-[400px] bg-white/[0.015] blur-[120px] rounded-full pointer-events-none -z-10"></div>
        
        <p class="font-mono text-[10px] uppercase tracking-widest text-[#94a3b8] mb-6">CONTACTO</p>
        
        <h1 class="font-extralight text-4xl md:text-5xl lg:text-6xl tracking-tight text-white mb-6">
          Hablemos de tu próximo proyecto tecnológico.
        </h1>
        
        <p class="font-light text-[#94a3b8] text-lg leading-relaxed max-w-xl mb-12">
          Estamos listos para escuchar tu idea, resolver tus dudas y convertir tu visión en una solución digital robusta y escalable.
        </p>
        
        <!-- Contact Info Block (text only, NO icons) -->
        <div class="space-y-6">
          <div>
            <p class="font-mono text-[10px] uppercase tracking-widest text-[#94a3b8] mb-1">EMAIL</p>
            <a href="mailto:info@vortexlm.com" class="font-light text-white text-lg hover:text-[#94a3b8] transition-colors">info@vortexlm.com</a>
          </div>
          <div>
            <p class="font-mono text-[10px] uppercase tracking-widest text-[#94a3b8] mb-1">UBICACIÓN</p>
            <p class="font-light text-white text-lg">Caracas, Venezuela</p>
          </div>
          <div>
            <p class="font-mono text-[10px] uppercase tracking-widest text-[#94a3b8] mb-1">HORARIO</p>
            <p class="font-light text-white text-lg">Lun — Vie, 9:00 AM — 6:00 PM (AST, UTC-4)</p>
          </div>
        </div>
      </div>
      
      <!-- RIGHT COLUMN: Contact Form -->
      <div class="w-full">
        <div class="linear-card p-8 rounded-lg border border-[#1f1f24] bg-[#08080c]/40">
          <form action="/api/contact" method="POST" class="space-y-5">
            <!-- Name / Company -->
            <div>
              <label class="block font-mono text-[10px] uppercase tracking-widest text-[#94a3b8] mb-2" for="name">Nombre / Empresa</label>
              <input
                type="text"
                id="name"
                name="name"
                autocomplete="name"
                required
                placeholder="Ej. Carlos Mendoza / Vortex C.A."
                class="bg-black border border-[#1f1f24] rounded-lg px-4 py-3 w-full text-white placeholder-[#52525b] outline-none focus:border-[#444] transition-all"
              />
            </div>
            
            <!-- Email -->
            <div>
              <label class="block font-mono text-[10px] uppercase tracking-widest text-[#94a3b8] mb-2" for="email">Correo Electrónico</label>
              <input
                type="email"
                id="email"
                name="email"
                autocomplete="email"
                required
                placeholder="carlos@tuempresa.com"
                class="bg-black border border-[#1f1f24] rounded-lg px-4 py-3 w-full text-white placeholder-[#52525b] outline-none focus:border-[#444] transition-all"
              />
            </div>
            
            <!-- Servicio de Interés -->
            <div>
              <label class="block font-mono text-[10px] uppercase tracking-widest text-[#94a3b8] mb-2" for="service">Servicio de Interés</label>
              <div class="relative">
                <select
                  id="service"
                  name="service"
                  required
                  class="bg-black border border-[#1f1f24] rounded-lg px-4 py-3 w-full text-white placeholder-[#52525b] outline-none focus:border-[#444] transition-all appearance-none cursor-pointer"
                >
                  <option value="" disabled selected class="text-[#52525b]">Selecciona un servicio</option>
                  <option value="desarrollo-web" class="text-white">Desarrollo de Web App</option>
                  <option value="pagina-corporativa" class="text-white">Página Web Corporativa</option>
                  <option value="marca-blanca" class="text-white">Marca Blanca para Agencias</option>
                  <option value="optimizacion" class="text-white">Optimización / Consultoría</option>
                </select>
                <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-3 h-3 text-[#52525b] pointer-events-none" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                </svg>
              </div>
            </div>
            
            <!-- Mensaje -->
            <div>
              <label class="block font-mono text-[10px] uppercase tracking-widest text-[#94a3b8] mb-2" for="message">Mensaje</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                placeholder="Cuéntanos sobre tu proyecto, ideas o consultas..."
                class="bg-black border border-[#1f1f24] rounded-lg px-4 py-3 w-full text-white placeholder-[#52525b] outline-none focus:border-[#444] transition-all resize-none"
              ></textarea>
            </div>
            
            <!-- Submit Button -->
            <button
              type="submit"
              class="bg-white text-black font-semibold text-xs rounded-full hover:bg-neutral-200 transition-all px-6 py-3 w-full flex items-center justify-center gap-2"
            >
              Enviar mensaje
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/>
                <polyline points="12 5 19 12 12 19"/>
              </svg>
            </button>
          </form>
        </div>
      </div>
      
    </div>
  </section>
</BaseLayout>
