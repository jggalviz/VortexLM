---
// src/pages/dashboard/admin/index.astro
// Internal admin panel — exclusive for Vortex Logic team
// SSR protection: verifies es_admin flag on perfiles_clientes
import { supabase } from '../../../lib/supabaseClient';
import SEO from '../../../components/seo/SEO.astro';
import {
  ClienteSaldoEditor,
  ProyectoEstadoEditor,
  InyectarTarea,
  FacturaValidar,
} from '../../../components/dashboard/AdminActions';

// ─── Auth & Admin Verification ───
const { data: sessionData } = await supabase.auth.getSession();
const session = sessionData?.session;

if (!session) {
  return Astro.redirect('/login', 302);
}

const userId = session.user.id;

const { data: perfil, error: perfilError } = await supabase
  .from('perfiles_clientes')
  .select('es_admin, empresa, email')
  .eq('user_id', userId)
  .single();

if (perfilError || !perfil || !perfil.es_admin) {
  return Astro.redirect('/dashboard', 302);
}

// ─── Fetch all clients ───
const { data: clientes, error: clientesError } = await supabase
  .from('perfiles_clientes')
  .select('id, user_id, empresa, email, vcredits_actuales')
  .order('empresa', { ascending: true });

// ─── Fetch all projects with client info ───
const { data: proyectos, error: proyectosError } = await supabase
  .from('proyectos')
  .select('*, perfiles_clientes!inner(empresa)')
  .order('created_at', { ascending: false });

// ─── Fetch all invoices with client info ───
const { data: facturas, error: facturasError } = await supabase
  .from('facturas')
  .select('*, perfiles_clientes!inner(empresa, email)')
  .order('created_at', { ascending: false });

const adminName = perfil.empresa || 'Admin';
const adminEmail = perfil.email || '';
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#000000" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <SEO title="Admin Panel — VortexLM Interno" description="Panel de administración interna de Vortex Logic." type="website" />
    <style>
      *,::before,::after{box-sizing:border-box;border-width:0;border-style:solid}
      html{-webkit-text-size-adjust:100%;tab-size:4;font-family:'Inter','system-ui',sans-serif}
      body{margin:0;background:#000;color:#f7f7f8;overflow-x:hidden}
    </style>
  </head>
  <body class="bg-black min-h-screen">
    <!-- Top bar -->
    <header class="sticky top-0 z-50 bg-[#08080c]/95 backdrop-blur-md border-b border-[#1f1f24]">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-14">
        <div class="flex items-center gap-3">
          <a href="/dashboard" class="flex items-center gap-2 group">
            <svg class="w-5 h-5 text-white transition-transform duration-300 group-hover:rotate-45" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10" class="stroke-neutral-800" />
              <circle cx="12" cy="12" r="5" />
              <circle cx="12" cy="12" r="1" fill="currentColor" />
              <path d="M12 2v3M12 19v3M2 12h3M19 12h3" />
            </svg>
            <span class="text-sm font-semibold tracking-[0.15em] text-white uppercase">Vortex<span class="font-light text-neutral-300">LM</span></span>
          </a>
          <span class="hidden sm:inline-flex items-center gap-1.5 px-2.5 py-0.5 bg-red-500/10 border border-red-500/20 rounded-full text-[10px] font-label-md text-red-400">
            <span class="w-1.5 h-1.5 rounded-full bg-red-400" />
            Admin Interno
          </span>
        </div>
        <div class="flex items-center gap-3">
          <span class="text-xs text-neutral-500 hidden sm:block">{adminEmail}</span>
          <a
            href="/dashboard"
            class="text-[10px] px-3 py-1.5 bg-white/5 border border-white/10 rounded-full text-neutral-400 hover:text-white hover:border-white/30 transition-all"
          >
            Volver al Panel
          </a>
        </div>
      </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-8 lg:py-10 space-y-10">
      <!-- Page header -->
      <div>
        <h1 class="text-xl sm:text-2xl font-heading font-semibold text-white tracking-tight">Panel de Administración</h1>
        <p class="text-sm text-neutral-500 font-body-md mt-1">Gestión centralizada de clientes, proyectos y facturas.</p>
      </div>

      <!-- ════════════════════════════════════════════ -->
      <!-- SECTION 1: Clientes Registrados             -->
      <!-- ════════════════════════════════════════════ -->
      <section>
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-sm font-heading font-semibold text-white">Clientes Registrados</h2>
          {clientes && !clientesError && (
            <span class="text-[10px] font-label-md text-neutral-500 uppercase tracking-wider">{clientes.length} clientes</span>
          )}
        </div>

        {clientesError ? (
          <div class="bg-red-500/10 border border-red-500/20 rounded-xl p-4 text-xs text-red-400">
            Error al cargar clientes: {clientesError.message}
          </div>
        ) : !clientes || clientes.length === 0 ? (
          <div class="bg-[#08080c] border border-[#1f1f24] rounded-xl p-8 text-center">
            <svg class="w-10 h-10 text-neutral-700 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
            </svg>
            <p class="text-sm text-neutral-500 font-body-md">No hay clientes registrados.</p>
          </div>
        ) : (
          <div class="bg-[#08080c] border border-[#1f1f24] rounded-xl overflow-hidden">
            <div class="overflow-x-auto">
              <table class="w-full text-left">
                <thead>
                  <tr class="border-b border-[#1f1f24]">
                    <th class="px-4 py-3 text-[10px] font-label-md text-neutral-500 uppercase tracking-wider">Empresa</th>
                    <th class="px-4 py-3 text-[10px] font-label-md text-neutral-500 uppercase tracking-wider">Correo</th>
                    <th class="px-4 py-3 text-[10px] font-label-md text-neutral-500 uppercase tracking-wider">vCredits</th>
                    <th class="px-4 py-3 text-[10px] font-label-md text-neutral-500 uppercase tracking-wider">Acción</th>
                  </tr>
                </thead>
                <tbody>
                  {clientes.map((cliente) => (
                    <tr class="border-b border-[#1f1f24]/50 hover:bg-white/[0.02] transition-colors">
                      <td class="px-4 py-3 text-sm text-white font-medium">{cliente.empresa}</td>
                      <td class="px-4 py-3 text-sm text-neutral-400 font-body-md">{cliente.email}</td>
                      <td class="px-4 py-3">
                        <span class="text-sm text-white font-medium">{cliente.vcredits_actuales}</span>
                        <span class="text-[10px] text-neutral-600 ml-1">vCredits</span>
                      </td>
                      <td class="px-4 py-3">
                        <ClienteSaldoEditor
                          client:load
                          cliente={cliente}
                          onSaldoUpdated={() => {}}
                        />
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        )}
      </section>

      <!-- ════════════════════════════════════════════ -->
      <!-- SECTION 2: Proyectos Globales               -->
      <!-- ════════════════════════════════════════════ -->
      <section>
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-sm font-heading font-semibold text-white">Proyectos Globales</h2>
          {proyectos && !proyectosError && (
            <span class="text-[10px] font-label-md text-neutral-500 uppercase tracking-wider">{proyectos.length} proyectos</span>
          )}
        </div>

        {proyectosError ? (
          <div class="bg-red-500/10 border border-red-500/20 rounded-xl p-4 text-xs text-red-400">
            Error al cargar proyectos: {proyectosError.message}
          </div>
        ) : !proyectos || proyectos.length === 0 ? (
          <div class="bg-[#08080c] border border-[#1f1f24] rounded-xl p-8 text-center">
            <svg class="w-10 h-10 text-neutral-700 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" />
            </svg>
            <p class="text-sm text-neutral-500 font-body-md">No hay proyectos registrados.</p>
          </div>
        ) : (
          <div class="bg-[#08080c] border border-[#1f1f24] rounded-xl overflow-hidden">
            <div class="overflow-x-auto">
              <table class="w-full text-left">
                <thead>
                  <tr class="border-b border-[#1f1f24]">
                    <th class="px-4 py-3 text-[10px] font-label-md text-neutral-500 uppercase tracking-wider">Proyecto</th>
                    <th class="px-4 py-3 text-[10px] font-label-md text-neutral-500 uppercase tracking-wider">Cliente</th>
                    <th class="px-4 py-3 text-[10px] font-label-md text-neutral-500 uppercase tracking-wider">Estado</th>
                    <th class="px-4 py-3 text-[10px] font-label-md text-neutral-500 uppercase tracking-wider">Progreso</th>
                    <th class="px-4 py-3 text-[10px] font-label-md text-neutral-500 uppercase tracking-wider">Acción</th>
                  </tr>
                </thead>
                <tbody>
                  {proyectos.map((proyecto) => (
                    <tr class="border-b border-[#1f1f24]/50 hover:bg-white/[0.02] transition-colors">
                      <td class="px-4 py-3 text-sm text-white font-medium max-w-[200px] truncate">{proyecto.titulo}</td>
                      <td class="px-4 py-3 text-sm text-neutral-400 font-body-md">{proyecto.perfiles_clientes?.empresa || '—'}</td>
                      <td class="px-4 py-3">
                        <ProyectoEstadoEditor
                          client:load
                          proyecto={{
                            id: proyecto.id,
                            titulo: proyecto.titulo,
                            estado: proyecto.estado || 'En Cola',
                            progreso: proyecto.progreso || 0,
                          }}
                          onEstadoUpdated={() => {}}
                        />
                      </td>
                      <td class="px-4 py-3">
                        <div class="flex items-center gap-2">
                          <div class="w-16 h-1.5 bg-[#1f1f24] rounded-full overflow-hidden">
                            <div
                              class="h-full bg-white rounded-full transition-all"
                              style={`width: ${proyecto.progreso || 0}%`}
                            />
                          </div>
                          <span class="text-[10px] text-neutral-500">{proyecto.progreso || 0}%</span>
                        </div>
                      </td>
                      <td class="px-4 py-3">
                        <InyectarTarea
                          client:load
                          proyectoId={proyecto.id}
                          proyectoNombre={proyecto.titulo}
                          onTareaCreada={() => {}}
                        />
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        )}
      </section>

      <!-- ════════════════════════════════════════════ -->
      <!-- SECTION 3: Facturas Emitidas                -->
      <!-- ════════════════════════════════════════════ -->
      <section>
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-sm font-heading font-semibold text-white">Facturas Emitidas</h2>
          {facturas && !facturasError && (
            <span class="text-[10px] font-label-md text-neutral-500 uppercase tracking-wider">{facturas.length} facturas</span>
          )}
        </div>

        {facturasError ? (
          <div class="bg-red-500/10 border border-red-500/20 rounded-xl p-4 text-xs text-red-400">
            Error al cargar facturas: {facturasError.message}
          </div>
        ) : !facturas || facturas.length === 0 ? (
          <div class="bg-[#08080c] border border-[#1f1f24] rounded-xl p-8 text-center">
            <svg class="w-10 h-10 text-neutral-700 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
            <p class="text-sm text-neutral-500 font-body-md">No hay facturas emitidas.</p>
          </div>
        ) : (
          <div class="bg-[#08080c] border border-[#1f1f24] rounded-xl overflow-hidden">
            <div class="overflow-x-auto">
              <table class="w-full text-left">
                <thead>
                  <tr class="border-b border-[#1f1f24]">
                    <th class="px-4 py-3 text-[10px] font-label-md text-neutral-500 uppercase tracking-wider">Factura</th>
                    <th class="px-4 py-3 text-[10px] font-label-md text-neutral-500 uppercase tracking-wider">Cliente</th>
                    <th class="px-4 py-3 text-[10px] font-label-md text-neutral-500 uppercase tracking-wider">Concepto</th>
                    <th class="px-4 py-3 text-[10px] font-label-md text-neutral-500 uppercase tracking-wider">Monto</th>
                    <th class="px-4 py-3 text-[10px] font-label-md text-neutral-500 uppercase tracking-wider">Estado</th>
                    <th class="px-4 py-3 text-[10px] font-label-md text-neutral-500 uppercase tracking-wider">Validación</th>
                  </tr>
                </thead>
                <tbody>
                  {facturas.map((factura) => (
                    <tr class="border-b border-[#1f1f24]/50 hover:bg-white/[0.02] transition-colors">
                      <td class="px-4 py-3 text-sm text-white font-medium">{factura.numero}</td>
                      <td class="px-4 py-3 text-sm text-neutral-400 font-body-md">{factura.perfiles_clientes?.empresa || '—'}</td>
                      <td class="px-4 py-3 text-sm text-neutral-400 font-body-md max-w-[180px] truncate">{factura.concepto}</td>
                      <td class="px-4 py-3 text-sm text-white font-medium">${Number(factura.monto).toFixed(2)}</td>
                      <td class="px-4 py-3">
                        {factura.estado === 'Pagada' ? (
                          <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-emerald-500/10 border border-emerald-500/20 rounded-full text-[10px] font-label-md text-emerald-500">
                            <span class="w-1 h-1 rounded-full bg-emerald-500" />
                            Pagada
                          </span>
                        ) : factura.estado === 'Vencida' ? (
                          <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-red-500/10 border border-red-500/20 rounded-full text-[10px] font-label-md text-red-500">
                            <span class="w-1 h-1 rounded-full bg-red-500" />
                            Vencida
                          </span>
                        ) : (
                          <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-yellow-500/10 border border-yellow-500/20 rounded-full text-[10px] font-label-md text-yellow-500">
                            <span class="w-1 h-1 rounded-full bg-yellow-500" />
                            Pendiente
                          </span>
                        )}
                      </td>
                      <td class="px-4 py-3">
                        <FacturaValidar
                          client:load
                          factura={{
                            id: factura.id,
                            numero: factura.numero,
                            concepto: factura.concepto,
                            monto: factura.monto,
                            estado: factura.estado,
                            comprobante_pago_url: factura.comprobante_pago_url,
                            fecha_vencimiento: factura.fecha_vencimiento,
                          }}
                          onValidada={() => {}}
                        />
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        )}
      </section>
    </main>
  </body>
</html>
