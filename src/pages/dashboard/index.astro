---
// src/pages/dashboard/index.astro
// Dashboard home — KPI cards, vCredits balance, WhatsApp status, and alerts feed
// Data fetched from Supabase perfiles_clientes table
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { supabase } from '../../lib/supabaseClient';

// Get the authenticated user from the session (session already verified by DashboardLayout)
const { data: sessionData } = await supabase.auth.getSession();
const userId = sessionData?.session?.user?.id;

// Fetch account data from perfiles_clientes table
let datosCuenta = null;
let fetchError = null;

if (userId) {
  const { data, error } = await supabase
    .from('perfiles_clientes')
    .select('*')
    .eq('user_id', userId)
    .single();

  if (error) {
    fetchError = error.message;
  } else {
    datosCuenta = data;
  }
} else {
  fetchError = 'No se pudo identificar al usuario autenticado.';
}
---

<DashboardLayout
  title="Inicio — Panel de Cliente | VortexLM"
  description="Resumen de tu cuenta VortexLM: créditos, estado de WhatsApp y notificaciones."
  activeSection="inicio"
>
  {
    fetchError ? (
      <!-- Error state -->
      <div class="flex flex-col items-center justify-center py-20 text-center">
        <svg class="w-12 h-12 text-red-500/50 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
        </svg>
        <p class="text-sm text-neutral-400 font-body-md mb-2">No se pudieron cargar los datos de tu cuenta.</p>
        <p class="text-xs text-neutral-600 font-body-md">{fetchError}</p>
        <a href="/dashboard" class="mt-4 inline-flex items-center gap-1.5 text-xs text-white font-medium hover:text-neutral-300 transition-colors">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182" />
          </svg>
          Intentar de nuevo
        </a>
      </div>
    ) : !datosCuenta ? (
      <!-- Loading state -->
      <div class="flex flex-col items-center justify-center py-20 text-center">
        <svg class="w-8 h-8 text-neutral-600 animate-spin mb-4" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" />
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z" />
        </svg>
        <p class="text-sm text-neutral-500 font-body-md">Cargando datos de tu cuenta...</p>
      </div>
    ) : (
      <>
        <!-- Page header -->
        <div class="mb-8">
          <h1 class="text-xl sm:text-2xl font-heading font-semibold text-white tracking-tight">
            Bienvenido, <span class="text-neutral-300">{datosCuenta.representante}</span>
          </h1>
          <p class="text-sm text-neutral-500 font-body-md mt-1">{datosCuenta.empresa}</p>
        </div>

        <!-- KPI Cards Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5 mb-8">
          <!-- vCredits Balance -->
          <div class="bg-[#08080c] border border-[#1f1f24] rounded-xl p-5 sm:p-6 hover:border-white/10 transition-colors">
            <div class="flex items-center justify-between mb-4">
              <span class="text-[11px] font-label-md text-neutral-500 uppercase tracking-wider">vCredits Disponibles</span>
              <svg class="w-5 h-5 text-neutral-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <circle cx="12" cy="12" r="10" />
                <circle cx="12" cy="12" r="5" />
                <circle cx="12" cy="12" r="1" fill="currentColor" />
                <path d="M12 2v3M12 19v3M2 12h3M19 12h3" />
              </svg>
            </div>
            <div class="flex items-baseline gap-1.5 mb-3">
              <span class="text-3xl sm:text-4xl font-heading font-bold text-white tracking-tight">{datosCuenta.vcredits_actuales ?? datosCuenta.vCreditsActuales}</span>
              <span class="text-sm text-neutral-500 font-body-md">vCredits</span>
            </div>
            <div class="flex items-center justify-between text-xs text-neutral-500 font-body-md">
              <span>Consumidos: <strong class="text-neutral-400">{datosCuenta.vcredits_consumidos ?? datosCuenta.vCreditsConsumidos}</strong></span>
              <span>Total: <strong class="text-neutral-400">{datosCuenta.vcredits_totales ?? datosCuenta.vCreditsTotales}</strong></span>
            </div>
            <!-- Usage bar -->
            <div class="mt-3 h-1.5 bg-[#1f1f24] rounded-full overflow-hidden">
              <div
                class="h-full bg-white rounded-full transition-all duration-500"
                style={`width: ${((datosCuenta.vcredits_consumidos ?? datosCuenta.vCreditsConsumidos) / (datosCuenta.vcredits_totales ?? datosCuenta.vCreditsTotales)) * 100}%`}
              />
            </div>
            <a
              href="/dashboard/facturacion"
              class="mt-4 inline-flex items-center gap-1.5 text-xs text-white font-medium hover:text-neutral-300 transition-colors"
            >
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
              </svg>
              Recargar vCredits
            </a>
          </div>

          <!-- WhatsApp Connection Status -->
          <div class="bg-[#08080c] border border-[#1f1f24] rounded-xl p-5 sm:p-6 hover:border-white/10 transition-colors">
            <div class="flex items-center justify-between mb-4">
              <span class="text-[11px] font-label-md text-neutral-500 uppercase tracking-wider">WhatsApp Business</span>
              <svg class="w-5 h-5 text-neutral-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155" />
              </svg>
            </div>
            <div class="flex items-center gap-3 mb-3">
              <div class={`w-3 h-3 rounded-full ${datosCuenta.whatsapp_conectado ?? datosCuenta.whatsappConectado ? 'bg-emerald-500 shadow-[0_0_12px_rgba(16,185,129,0.3)]' : 'bg-red-500'}`} />
              <span class="text-sm font-medium text-white">
                {datosCuenta.whatsapp_conectado ?? datosCuenta.whatsappConectado ? 'Conectado' : 'Desconectado'}
              </span>
            </div>
            <p class="text-xs text-neutral-500 font-body-md">
              Número vinculado: <span class="text-neutral-400">{datosCuenta.telefono_whatsapp ?? datosCuenta.telefonoWhatsApp}</span>
            </p>
            <p class="text-xs text-neutral-600 font-body-md mt-1">
              Recibe notificaciones y reporta pagos directamente por WhatsApp.
            </p>
          </div>

          <!-- Quick Stats -->
          <div class="bg-[#08080c] border border-[#1f1f24] rounded-xl p-5 sm:p-6 hover:border-white/10 transition-colors">
            <div class="flex items-center justify-between mb-4">
              <span class="text-[11px] font-label-md text-neutral-500 uppercase tracking-wider">Resumen Rápido</span>
              <svg class="w-5 h-5 text-neutral-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
              </svg>
            </div>
            <div class="space-y-3">
              <div class="flex items-center justify-between text-sm">
                <span class="text-neutral-500 font-body-md">Proyectos activos</span>
                <span class="text-white font-medium">{datosCuenta.proyectos_activos ?? datosCuenta.proyectosActivos ?? 0}</span>
              </div>
              <div class="flex items-center justify-between text-sm">
                <span class="text-neutral-500 font-body-md">Facturas pendientes</span>
                <span class="text-white font-medium">{datosCuenta.facturas_pendientes ?? datosCuenta.facturasPendientes ?? 0}</span>
              </div>
              <div class="flex items-center justify-between text-sm">
                <span class="text-neutral-500 font-body-md">Tasa de consumo</span>
                <span class="text-white font-medium">{Math.round(((datosCuenta.vcredits_consumidos ?? datosCuenta.vCreditsConsumidos) / (datosCuenta.vcredits_totales ?? datosCuenta.vCreditsTotales)) * 100)}%</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Alerts Feed -->
        <div class="bg-[#08080c] border border-[#1f1f24] rounded-xl p-5 sm:p-6">
          <div class="flex items-center justify-between mb-5">
            <h2 class="text-sm font-heading font-semibold text-white">Notificaciones y Alertas</h2>
            <span class="text-[10px] font-label-md text-neutral-500 uppercase tracking-wider">Hoy · {new Date().toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
          </div>
          <div class="space-y-3">
            {
              (datosCuenta.alertas ?? []).length > 0 ? (
                (datosCuenta.alertas ?? []).map((alerta: any) => {
                  const tipo = alerta.tipo;
                  const mensaje = alerta.mensaje;
                  const fecha = alerta.fecha;
                  let iconSvg = '';
                  let borderClass = '';
                  if (tipo === 'warning') {
                    iconSvg = '<path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />';
                    borderClass = 'bg-yellow-500/5 border-yellow-500/20';
                  } else if (tipo === 'success') {
                    iconSvg = '<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />';
                    borderClass = 'bg-emerald-500/5 border-emerald-500/20';
                  } else {
                    iconSvg = '<path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z" />';
                    borderClass = 'bg-white/5 border-white/10';
                  }
                  return (
                    <div class={`flex items-start gap-3 px-4 py-3.5 rounded-lg border ${borderClass}`}>
                      <div class="w-4 h-4 mt-0.5 flex-shrink-0" set:html={iconSvg} />
                      <div class="flex-1 min-w-0">
                        <p class="text-sm text-neutral-300 font-body-md leading-relaxed">{mensaje}</p>
                        <p class="text-xs text-neutral-600 mt-1">{fecha}</p>
                      </div>
                    </div>
                  );
                })
              ) : (
                <p class="text-sm text-neutral-500 font-body-md text-center py-4">No hay notificaciones nuevas.</p>
              )
            }
          </div>
        </div>
      </>
    )
  }
</DashboardLayout>
