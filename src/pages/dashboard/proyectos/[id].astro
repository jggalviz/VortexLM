---
// src/pages/dashboard/proyectos/[id].astro
// Project detail view — header with status badge + progress bar, then ProjectTabs (Archivos, Notas, Tareas)
// Data fetched from Supabase proyectos table by URL param [id]
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import { supabase } from '../../../lib/supabaseClient';
import ProjectTabs from '../../../components/dashboard/ProjectTabs';

const { id } = Astro.params;

// Fetch the project from Supabase by id
let proyecto: Record<string, any> | null = null;
let fetchError: string | null = null;

if (id) {
  const { data, error } = await supabase
    .from('proyectos')
    .select('*')
    .eq('id', id)
    .single();

  if (error) {
    fetchError = error.message;
  } else {
    proyecto = data;
  }
} else {
  fetchError = 'ID de proyecto no proporcionado.';
}

const proyectoValido = proyecto !== null;

let estadoColor = '';
if (proyectoValido) {
  const estado = proyecto!.estado || 'En Cola';
  if (estado === 'Completado') {
    estadoColor = 'bg-emerald-500/10 text-emerald-500 border-emerald-500/20';
  } else if (estado === 'En Desarrollo') {
    estadoColor = 'bg-blue-500/10 text-blue-500 border-blue-500/20';
  } else if (estado === 'Pruebas') {
    estadoColor = 'bg-purple-500/10 text-purple-500 border-purple-500/20';
  } else {
    estadoColor = 'bg-neutral-500/10 text-neutral-400 border-neutral-500/20';
  }
}
---

{proyectoValido ? (
  <DashboardLayout
    title={`${proyecto!.titulo} — Panel de Cliente | VortexLM`}
    description={proyecto!.descripcion || ''}
    activeSection="proyectos"
  >
    <!-- Back link -->
    <a
      href="/dashboard/proyectos"
      class="inline-flex items-center gap-1.5 text-xs text-neutral-500 hover:text-white transition-colors mb-6"
    >
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
      </svg>
      Volver a Mis Proyectos
    </a>

    <!-- Project Header -->
    <div class="bg-[#08080c] border border-[#1f1f24] rounded-xl p-5 sm:p-6 mb-6">
      <div class="flex items-start justify-between mb-4">
        <div class="flex-1 min-w-0 mr-4">
          <div class="flex items-center gap-3 mb-2">
            <h1 class="text-xl sm:text-2xl font-heading font-semibold text-white tracking-tight">{proyecto!.titulo}</h1>
            <span class={`inline-flex items-center px-3 py-0.5 rounded-full text-[11px] font-label-md border ${estadoColor}`}>
              {proyecto!.estado || 'En Cola'}
            </span>
          </div>
          <p class="text-sm text-neutral-500 font-body-md leading-relaxed">{proyecto!.descripcion}</p>
        </div>
      </div>

      <!-- Progress bar -->
      <div class="flex items-center gap-4">
        <div class="flex-1 h-2.5 bg-[#1f1f24] rounded-full overflow-hidden">
          <div
            class="h-full bg-white rounded-full transition-all duration-1000"
            style={`width: ${proyecto!.progreso || 0}%`}
          />
        </div>
        <span class="text-sm text-neutral-500 font-label-md flex-shrink-0">{proyecto!.progreso || 0}% completado</span>
      </div>

      <!-- Stats row (counts from related tables — will be hydrated by ProjectTabs) -->
      <div class="flex items-center gap-6 mt-4 pt-4 border-t border-[#1f1f24]">
        <div class="flex items-center gap-2 text-xs text-neutral-500 font-body-md">
          <svg class="w-4 h-4 text-neutral-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
          </svg>
          <span><strong class="text-neutral-400" id="archivos-count">-</strong> archivos</span>
        </div>
        <div class="flex items-center gap-2 text-xs text-neutral-500 font-body-md">
          <svg class="w-4 h-4 text-neutral-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" />
          </svg>
          <span><strong class="text-neutral-400" id="notas-count">-</strong> notas</span>
        </div>
        <div class="flex items-center gap-2 text-xs text-neutral-500 font-body-md">
          <svg class="w-4 h-4 text-neutral-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span>
            <strong class="text-neutral-400" id="tareas-count">-</strong> tareas completadas
          </span>
        </div>
      </div>
    </div>

    <!-- ProjectTabs (React interactive component) — receives proyectoId for Supabase queries -->
    <div class="bg-[#08080c] border border-[#1f1f24] rounded-xl p-5 sm:p-6">
      <ProjectTabs client:load proyectoId={id!} />
    </div>
  </DashboardLayout>
) : (
  <DashboardLayout
    title="Proyecto no encontrado"
    description="El proyecto solicitado no existe."
    activeSection="proyectos"
  >
    <div class="text-center py-20">
      {fetchError ? (
        <>
          <svg class="w-12 h-12 text-red-500/50 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
          </svg>
          <p class="text-sm text-neutral-400 font-body-md mb-2">Error al cargar el proyecto.</p>
          <p class="text-xs text-neutral-600 font-body-md">{fetchError}</p>
        </>
      ) : (
        <p class="text-neutral-500 font-body-md">Proyecto no encontrado.</p>
      )}
      <a href="/dashboard/proyectos" class="mt-4 inline-flex items-center gap-1.5 text-xs text-white hover:text-neutral-300 transition-colors">
        ← Volver a Mis Proyectos
      </a>
    </div>
  </DashboardLayout>
)}
