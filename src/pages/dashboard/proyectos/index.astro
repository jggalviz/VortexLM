---
// src/pages/dashboard/proyectos/index.astro
// Project list — progress bars per estado, create project button with modal
// Data fetched from Supabase proyectos table
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import { supabase } from '../../../lib/supabaseClient';
import CreateProjectModal from '../../../components/dashboard/CreateProjectModal';

// Get the authenticated user
const { data: sessionData } = await supabase.auth.getSession();
const userId = sessionData?.session?.user?.id;

// Fetch projects from Supabase
let proyectos: any[] = [];
let fetchError: string | null = null;

if (userId) {
  const { data, error } = await supabase
    .from('proyectos')
    .select('*')
    .eq('user_id', userId)
    .order('created_at', { ascending: false });

  if (error) {
    fetchError = error.message;
  } else {
    proyectos = data || [];
  }
} else {
  fetchError = 'No se pudo identificar al usuario autenticado.';
}
---

<DashboardLayout
  title="Mis Proyectos — Panel de Cliente | VortexLM"
  description="Gestiona tus proyectos activos con VortexLM: seguimiento de progreso, archivos y tareas."
  activeSection="proyectos"
>
  {
    fetchError ? (
      <!-- Error state -->
      <div class="flex flex-col items-center justify-center py-20 text-center">
        <svg class="w-12 h-12 text-red-500/50 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
        </svg>
        <p class="text-sm text-neutral-400 font-body-md mb-2">No se pudieron cargar tus proyectos.</p>
        <p class="text-xs text-neutral-600 font-body-md">{fetchError}</p>
        <a href="/dashboard/proyectos" class="mt-4 inline-flex items-center gap-1.5 text-xs text-white font-medium hover:text-neutral-300 transition-colors">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182" />
          </svg>
          Intentar de nuevo
        </a>
      </div>
    ) : (
      <>
        <!-- Page header -->
        <div class="flex items-center justify-between mb-8">
          <div>
            <h1 class="text-xl sm:text-2xl font-heading font-semibold text-white tracking-tight">Mis Proyectos</h1>
            <p class="text-sm text-neutral-500 font-body-md mt-1">{proyectos.length} proyectos en tu cuenta.</p>
          </div>
          <button
            id="create-project-btn"
            class="inline-flex items-center gap-2 px-5 py-2.5 bg-white text-black text-xs font-medium rounded-lg hover:bg-neutral-200 transition-all duration-200 active:scale-[0.97]"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            Nuevo Proyecto
          </button>
        </div>

        <!-- Project Cards -->
        {proyectos.length > 0 ? (
          <div class="space-y-4">
            {proyectos.map((proyecto) => {
              const estado = proyecto.estado || 'En Cola';
              const estadoColor =
                estado === 'Completado'
                  ? 'bg-emerald-500/10 text-emerald-500 border-emerald-500/20'
                  : estado === 'En Desarrollo'
                  ? 'bg-blue-500/10 text-blue-500 border-blue-500/20'
                  : estado === 'Pruebas'
                  ? 'bg-purple-500/10 text-purple-500 border-purple-500/20'
                  : 'bg-neutral-500/10 text-neutral-400 border-neutral-500/20';
              return (
                <a
                  href={`/dashboard/proyectos/${proyecto.id}`}
                  class="block bg-[#08080c] border border-[#1f1f24] rounded-xl p-5 sm:p-6 hover:border-white/10 transition-all duration-300 group"
                >
                  <div class="flex items-start justify-between mb-4">
                    <div class="flex-1 min-w-0 mr-4">
                      <div class="flex items-center gap-3 mb-1.5">
                        <h2 class="text-base font-heading font-semibold text-white group-hover:text-neutral-200 transition-colors">
                          {proyecto.titulo}
                        </h2>
                        <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-label-md border ${estadoColor}`}>
                          {estado}
                        </span>
                      </div>
                      <p class="text-sm text-neutral-500 font-body-md line-clamp-2">{proyecto.descripcion}</p>
                    </div>
                    <svg class="w-5 h-5 text-neutral-600 group-hover:text-white transition-colors flex-shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                    </svg>
                  </div>

                  <!-- Progress bar -->
                  <div class="flex items-center gap-4">
                    <div class="flex-1 h-2 bg-[#1f1f24] rounded-full overflow-hidden">
                      <div
                        class="h-full bg-white rounded-full transition-all duration-700"
                        style={`width: ${proyecto.progreso || 0}%`}
                      />
                    </div>
                    <span class="text-xs text-neutral-500 font-label-md flex-shrink-0">{proyecto.progreso || 0}%</span>
                  </div>

                  <!-- Meta info -->
                  <div class="flex items-center gap-4 mt-3 text-xs text-neutral-600 font-body-md">
                    <span class="flex items-center gap-1">
                      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                      </svg>
                      {(proyecto.archivos ?? []).length} archivos
                    </span>
                    <span class="flex items-center gap-1">
                      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" />
                      </svg>
                      {(proyecto.notas ?? []).length} notas
                    </span>
                    <span class="flex items-center gap-1">
                      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      {(proyecto.tareas_experto ?? proyecto.tareasExperto ?? []).filter((t: any) => t.completada).length}/{(proyecto.tareas_experto ?? proyecto.tareasExperto ?? []).length} tareas
                    </span>
                  </div>
                </a>
              );
            })}
          </div>
        ) : (
          <!-- Empty state -->
          <div class="flex flex-col items-center justify-center py-20 text-center">
            <svg class="w-12 h-12 text-neutral-600 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
            <p class="text-sm text-neutral-400 font-body-md mb-1">Aún no tienes proyectos.</p>
            <p class="text-xs text-neutral-600 font-body-md mb-4">Crea tu primer proyecto para empezar.</p>
            <button
              id="create-project-btn-empty"
              class="inline-flex items-center gap-2 px-5 py-2.5 bg-white text-black text-xs font-medium rounded-lg hover:bg-neutral-200 transition-all duration-200 active:scale-[0.97]"
            >
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
              </svg>
              Crear Proyecto
            </button>
          </div>
        )}

        <!-- CreateProjectModal (self-managed mode — no props needed) -->
        <CreateProjectModal client:load open={false} onClose={() => {}} />
      </>
    )
  }
</DashboardLayout>

<script>
  // Wire up the "Nuevo Proyecto" buttons to open the modal
  const btn = document.getElementById('create-project-btn');
  if (btn) {
    btn.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('open-create-project'));
    });
  }
  const btnEmpty = document.getElementById('create-project-btn-empty');
  if (btnEmpty) {
    btnEmpty.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('open-create-project'));
    });
  }

  // Listen for project refresh event (dispatched by CreateProjectModal after INSERT)
  window.addEventListener('proyectos-refresh', () => {
    // Reload the page to reflect the new project
    window.location.reload();
  });
</script>
