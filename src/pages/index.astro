---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout 
  title="Vortex - Desarrollo Web de Alto Rendimiento y Software a Medida" 
  description="Creamos software robusto y páginas web ultrarrápidas que hacen crecer tu negocio. Jamstack (Astro, Next.js), Supabase y optimización extrema sin plantillas lentas."
>
  <!-- Hero Section (Sección Superior) -->
  <section class="relative pt-36 pb-32 overflow-hidden linear-gradient-bg border-b border-[#1f1f24] px-6 md:px-12">
    <!-- Grid Overlay sutil -->
    <div class="absolute inset-0 linear-grid opacity-30 pointer-events-none"></div>
    
    <div class="max-w-[1200px] mx-auto text-center relative z-10">
      <!-- Resplandor sutil detrás del H1 -->
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-white/[0.015] blur-[120px] rounded-full pointer-events-none"></div>

      <!-- Título Principal (H1) -->
      <h1 class="text-4xl md:text-7xl font-extralight tracking-tight text-white mb-8 leading-[1.08] max-w-4xl mx-auto opacity-95">
        Creamos software robusto y páginas web ultrarrápidas que hacen crecer tu negocio.
      </h1>
      
      <!-- Subtítulo (Párrafo de soporte en gris claro) -->
      <p class="text-base md:text-lg text-[#94a3b8] font-light mb-12 max-w-3xl mx-auto leading-relaxed">
        Desarrollamos con tecnologías de última generación para empresas y agencias que exigen velocidad extrema, seguridad y arquitectura escalable. Sin plantillas pesadas, sin código basura.
      </p>

      <!-- Botones de Acción (CTAs) -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-6 mb-20">
        <a href="#contacto" class="w-full sm:w-auto px-8 py-3 bg-white text-black font-semibold text-xs rounded-full hover:bg-neutral-200 transition-all text-center duration-200 active:scale-95 shadow-[0_0_25px_rgba(255,255,255,0.15)]">
          Agendar una llamada
        </a>
        <a href="#features" class="w-full sm:w-auto px-6 py-3 text-white/80 font-medium text-xs rounded-full hover:text-white flex items-center justify-center gap-1.5 group transition-colors">
          Ver servicios <span class="group-hover:translate-x-1 transition-transform">➔</span>
        </a>
      </div>

      <!-- Elemento Gráfico Central (El gran mockup flotante de entorno de desarrollo) -->
      <div class="relative max-w-5xl mx-auto">
        <!-- Frame de ventana flotante con relieve skeuomórfico y glow de fondo -->
        <div class="linear-card rounded-lg overflow-hidden border border-[#2e2e34] shadow-[0_50px_100px_-20px_rgba(0,0,0,0.98)]">
          <!-- Barra superior simulando MacOS / IDE -->
          <div class="bg-[#08080c] px-4 py-3.5 flex items-center justify-between border-b border-[#1f1f24]">
            <div class="flex items-center gap-2">
              <span class="w-2.5 h-2.5 rounded-full bg-[#ff5f56]/50"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-[#ffbd2e]/50"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-[#27c93f]/50"></span>
            </div>
            <div class="text-[10px] font-mono text-[#94a3b8]/40 flex items-center gap-1.5">
              <span class="material-symbols-outlined text-[10px]">code</span>
              vortex-workspace // src/pages/index.astro
            </div>
            <div class="w-12"></div>
          </div>

          <!-- Entorno de Trabajo de Tres Columnas -->
          <div class="grid grid-cols-1 md:grid-cols-12 min-h-[500px] bg-[#000000] text-left">
            
            <!-- Columna Izquierda: Estructura de carpetas limpia de Astro/Next.js -->
            <div class="col-span-1 md:col-span-3 border-r border-[#1f1f24] bg-[#050507]/60 p-4 font-mono text-[11px] text-[#94a3b8]/80">
              <span class="text-[9px] uppercase tracking-wider text-[#94a3b8]/40 block mb-3 font-semibold">Explorador de Archivos</span>
              <div class="space-y-2">
                <div class="flex items-center gap-2 text-white">
                  <span class="material-symbols-outlined text-xs text-[#94a3b8]">folder_open</span> src/
                </div>
                <div class="pl-4 space-y-1.5 border-l border-[#1f1f24] ml-2">
                  <div class="flex items-center gap-2 text-white/90">
                    <span class="material-symbols-outlined text-xs text-[#94a3b8]">folder</span> components/
                  </div>
                  <div class="pl-4 space-y-1 border-l border-[#1f1f24] ml-2">
                    <div class="text-[#94a3b8] hover:text-white transition-colors cursor-pointer flex items-center gap-1">
                      <span class="material-symbols-outlined text-[10px]">draft</span> Header.astro
                    </div>
                    <div class="text-[#94a3b8] hover:text-white transition-colors cursor-pointer flex items-center gap-1">
                      <span class="material-symbols-outlined text-[10px]">draft</span> Footer.astro
                    </div>
                  </div>
                  <div class="flex items-center gap-2 text-white/90">
                    <span class="material-symbols-outlined text-xs text-[#94a3b8]">folder_open</span> pages/
                  </div>
                  <div class="pl-4 border-l border-[#1f1f24] ml-2">
                    <div class="text-cyan-400 font-medium flex items-center gap-1">
                      <span class="material-symbols-outlined text-[10px]">draft</span> index.astro
                    </div>
                  </div>
                </div>
                <div class="flex items-center gap-2 text-[#94a3b8]">
                  <span class="material-symbols-outlined text-xs">settings</span> tailwind.config.mjs
                </div>
                <div class="flex items-center gap-2 text-[#94a3b8]">
                  <span class="material-symbols-outlined text-xs">settings</span> astro.config.mjs
                </div>
              </div>
            </div>

            <!-- Columna Central: Fragmento de código TypeScript/Astro impecable -->
            <div class="col-span-1 md:col-span-6 p-6 border-r border-[#1f1f24] font-mono text-[11px] leading-relaxed overflow-x-auto text-[#94a3b8]/90">
              <span class="text-[9px] uppercase tracking-wider text-[#94a3b8]/40 block mb-3 font-semibold">Editor de Código</span>
              <div class="space-y-1">
                <div><span class="text-purple-400">import</span> BaseLayout <span class="text-purple-400">from</span> <span class="text-green-300">'../layouts/BaseLayout.astro'</span>;</div>
                <div><span class="text-purple-400">import</span> Button <span class="text-purple-400">from</span> <span class="text-green-300">'../components/ui/Button.tsx'</span>;</div>
                <div class="text-[#94a3b8]/40">// Inicializa la arquitectura ultrarrápida</div>
                <div><span class="text-blue-400">const</span> <span class="text-yellow-200">projectName</span> = <span class="text-green-300">"Vortex Scalable Project"</span>;</div>
                <div><span class="text-blue-400">const</span> <span class="text-yellow-200">pageSpeedScore</span> = <span class="text-yellow-400">100</span>;</div>
                <br />
                <div>&lt;<span class="text-blue-300">BaseLayout</span> title=&#123;projectName&#125;&gt;</div>
                <div class="pl-4">&lt;<span class="text-blue-300">main</span> class=<span class="text-green-300">"jamstack-grid font-light"</span>&gt;</div>
                <div class="pl-8">&lt;<span class="text-blue-300">section</span> id=<span class="text-green-300">"hero"</span>&gt;</div>
                <div class="pl-12">&lt;<span class="text-blue-300">h1</span>&gt;Software robusto que escala&lt;/<span class="text-blue-300">h1</span>&gt;</div>
                <div class="pl-12">&lt;<span class="text-blue-300">Button</span> client:load size=<span class="text-green-300">"sm"</span>&gt;</div>
                <div class="pl-16">Agendar llamada</div>
                <div class="pl-12">&lt;/<span class="text-blue-300">Button</span>&gt;</div>
                <div class="pl-8">&lt;/<span class="text-blue-300">section</span>&gt;</div>
                <div class="pl-4">&lt;/<span class="text-blue-300">main</span>&gt;</div>
                <div>&lt;/<span class="text-blue-300">BaseLayout</span>&gt;</div>
              </div>
            </div>

            <!-- Columna Derecha: Base de datos Supabase minimalista -->
            <div class="col-span-1 md:col-span-3 p-4 bg-[#050507]/30 flex flex-col justify-between">
              <div>
                <span class="text-[9px] uppercase tracking-wider text-[#94a3b8]/40 block mb-3 font-mono font-semibold">Supabase PostgreSQL</span>
                <div class="space-y-3 font-mono text-[10px]">
                  <div class="p-2 border border-[#1f1f24] rounded bg-black/40">
                    <div class="text-white/80 font-bold mb-0.5">Tabla: clients_db</div>
                    <div class="text-[#94a3b8]/60 text-[9px]">3 columns // 1,420 rows</div>
                  </div>
                  <div class="space-y-1.5">
                    <div class="flex justify-between border-b border-[#1f1f24] pb-1">
                      <span class="text-[#94a3b8]/80">uuid</span>
                      <span class="text-cyan-400">pkey</span>
                    </div>
                    <div class="flex justify-between border-b border-[#1f1f24] pb-1">
                      <span class="text-[#94a3b8]/80">empresa_name</span>
                      <span class="text-[#94a3b8]/40">text</span>
                    </div>
                    <div class="flex justify-between border-b border-[#1f1f24] pb-1">
                      <span class="text-[#94a3b8]/80">conversion_rate</span>
                      <span class="text-green-400">float8</span>
                    </div>
                  </div>
                </div>
              </div>

              <!-- SSL Indicator and verification lock -->
              <div class="border-t border-[#1f1f24]/50 pt-3 flex items-center justify-between text-[9px] font-mono text-[#94a3b8]/40">
                <span class="flex items-center gap-1"><span class="w-1.5 h-1.5 rounded-full bg-green-500"></span> Live Node</span>
                <span>SSL Encrypted</span>
              </div>
            </div>

          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Sticky Sub-navigation (Barra fija pequeña en desktop) -->
  <nav class="sticky top-16 z-40 bg-black/80 backdrop-blur-md border-b border-[#1f1f24] hidden md:block">
    <div class="max-w-[1200px] mx-auto px-12 h-10 flex items-center justify-between text-[10px] text-[#94a3b8] font-mono">
      <div class="flex items-center gap-6">
        <a href="#features" class="hover:text-white transition-colors">Características</a>
        <a href="#optimización" class="hover:text-white transition-colors">Optimización SEO</a>
        <a href="#plataformas" class="hover:text-white transition-colors">Aplicaciones a Medida</a>
      </div>
      <div class="flex items-center gap-6">
        <a href="#infraestructura" class="hover:text-white transition-colors">Infraestructura Corporativa</a>
        <a href="#contacto" class="hover:text-white transition-colors">Agendar</a>
      </div>
    </div>
  </nav>

  <!-- Sección de Características Principales (Los 3 bloques con iconos) -->
  <section id="features" class="py-36 px-6 md:px-12 bg-black relative border-b border-[#1f1f24]">
    <div class="max-w-[1200px] mx-auto relative z-10">
      
      <!-- Texto introductorio (Arriba de las tarjetas) -->
      <div class="max-w-4xl mb-24">
        <h2 class="text-2xl md:text-4xl font-light text-white tracking-tight leading-snug">
          Una nueva especie de desarrollo. Diseñado a medida para la era digital. Vortex establece un estándar superior en rendimiento web y aplicaciones escalables.
        </h2>
      </div>

      <!-- 3 bloques con iconos -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-16">
        
        <!-- Bloque 1: Jamstack y SSR -->
        <div class="space-y-6 group">
          <!-- Cubo Isométrico SVG -->
          <div class="w-full aspect-[4/3] linear-card rounded border border-[#1f1f24] bg-[#08080c]/30 flex items-center justify-center p-6 glow-hover transition-all">
            <svg class="w-20 h-20 text-[#94a3b8]/40 group-hover:text-white/80 transition-colors" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M50 15L85 35L50 55L15 35L50 15Z" stroke="currentColor" stroke-width="0.75" stroke-dasharray="2 2"/>
              <path d="M50 55V95" stroke="currentColor" stroke-width="0.75" stroke-dasharray="2 2"/>
              <path d="M50 25L80 42V67L50 85L20 67V42L50 25Z" stroke="currentColor" stroke-width="1.25"/>
              <path d="M50 25V85" stroke="currentColor" stroke-width="1.25"/>
              <path d="M20 42L50 60L80 42" stroke="currentColor" stroke-width="1.25"/>
              <circle cx="50" cy="25" r="2.5" fill="currentColor"/>
              <circle cx="20" cy="42" r="2.5" fill="currentColor"/>
              <circle cx="80" cy="42" r="2.5" fill="currentColor"/>
              <circle cx="50" cy="60" r="2.5" fill="currentColor"/>
              <circle cx="50" cy="85" r="2.5" fill="currentColor"/>
            </svg>
          </div>
          <div>
            <h3 class="text-sm font-medium text-white mb-2.5">Arquitectura Jamstack y SSR</h3>
            <p class="text-xs text-[#94a3b8] leading-relaxed">
              Implementamos el stack moderno con Astro y Next.js. Separamos el frontend del backend para garantizar cargas en menos de un segundo y una seguridad impenetrable.
            </p>
          </div>
        </div>

        <!-- Bloque 2: Supabase y PostgreSQL -->
        <div class="space-y-6 group">
          <!-- Tres Planos Horizontales SVG -->
          <div class="w-full aspect-[4/3] linear-card rounded border border-[#1f1f24] bg-[#08080c]/30 flex items-center justify-center p-6 glow-hover transition-all">
            <svg class="w-20 h-20 text-[#94a3b8]/40 group-hover:text-white/80 transition-colors" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M50 20L80 32L50 44L20 32L50 20Z" stroke="currentColor" stroke-width="1.25"/>
              <path d="M50 40L80 52L50 64L20 52L50 40Z" stroke="currentColor" stroke-width="1"/>
              <path d="M50 60L80 72L50 84L20 72L50 60Z" stroke="currentColor" stroke-width="1.25"/>
              <path d="M50 32V72" stroke="currentColor" stroke-width="0.75" stroke-dasharray="3 3"/>
              <circle cx="50" cy="32" r="2" fill="currentColor"/>
              <circle cx="50" cy="52" r="2" fill="currentColor"/>
              <circle cx="50" cy="72" r="2" fill="currentColor"/>
            </svg>
          </div>
          <div>
            <h3 class="text-sm font-medium text-white mb-2.5">Bases de Datos y Nube Escalable</h3>
            <p class="text-xs text-[#94a3b8] leading-relaxed">
              Conectamos tus sistemas con Supabase y PostgreSQL, desplegando la infraestructura en Vercel. Aplicaciones web preparadas para soportar miles de usuarios concurrentes sin caídas.
            </p>
          </div>
        </div>

        <!-- Bloque 3: WordPress de Ingeniería -->
        <div class="space-y-6 group">
          <!-- Esfera de Nodos Conectados SVG -->
          <div class="w-full aspect-[4/3] linear-card rounded border border-[#1f1f24] bg-[#08080c]/30 flex items-center justify-center p-6 glow-hover transition-all">
            <svg class="w-20 h-20 text-[#94a3b8]/40 group-hover:text-white/80 transition-colors" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M30 45L50 25L70 45L50 65L30 45Z" stroke="currentColor" stroke-width="0.75"/>
              <path d="M50 25V65" stroke="currentColor" stroke-width="0.75"/>
              <path d="M30 45H70" stroke="currentColor" stroke-width="0.75"/>
              <path d="M20 65L50 65" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 2"/>
              <path d="M70 45L85 60" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 2"/>
              <circle cx="50" cy="25" r="4" fill="currentColor"/>
              <circle cx="30" cy="45" r="3.5" fill="currentColor" fill-opacity="0.6"/>
              <circle cx="70" cy="45" r="3.5" fill="currentColor" fill-opacity="0.6"/>
              <circle cx="50" cy="65" r="5" fill="currentColor"/>
              <circle cx="20" cy="65" r="2" fill="currentColor" fill-opacity="0.3"/>
              <circle cx="85" cy="60" r="2" fill="currentColor" fill-opacity="0.3"/>
            </svg>
          </div>
          <div>
            <h3 class="text-sm font-medium text-white mb-2.5">WordPress de Ingeniería</h3>
            <p class="text-xs text-[#94a3b8] leading-relaxed">
              Llevamos WordPress al límite. Diseños premium optimizados a nivel de código puro, sin depender de constructores lentos. Velocidad nativa con la flexibilidad del panel de control clásico.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Bloques de Funcionalidad Detallada (Alternados con padding amplio) -->
  <section id="optimización" class="py-36 px-6 md:px-12 bg-black border-b border-[#1f1f24] relative">
    <div class="max-w-[1200px] mx-auto space-y-44 relative z-10">
      
      <!-- Bloque Detallado 1: Optimización total para Google (Texto Izq, Mockup Der) -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-center">
        <!-- Columna de Texto -->
        <div class="lg:col-span-5 space-y-5">
          <span class="text-[10px] font-mono text-[#94a3b8] uppercase tracking-widest block font-medium">Core Web Vitals</span>
          <h2 class="text-2xl md:text-4xl font-light text-white tracking-tight leading-tight">
            Optimización total para Google.
          </h2>
          <p class="text-sm text-[#94a3b8] font-light leading-relaxed">
            SEO técnico integrado desde la primera línea de código. No dejamos el posicionamiento orgánico al azar; estructuramos tu web con semántica perfecta, datos estructurados y rendimiento Core Web Vitals en verde absoluto.
          </p>
        </div>
        
        <!-- Mockup: Reporte Google PageSpeed Insights de alta fidelidad -->
        <div class="lg:col-span-7">
          <div class="linear-card rounded-lg border border-[#1f1f24] overflow-hidden bg-[#08080c]/50 p-8 shadow-2xl relative">
            <!-- Etiquetas HTML5 semánticas difuminadas al fondo -->
            <div class="absolute inset-0 font-mono text-[8px] text-[#1f1f24] p-6 select-none overflow-hidden leading-relaxed pointer-events-none opacity-20">
              &lt;article&gt;<br />
              &nbsp;&nbsp;&lt;header class="vortex-sem"&gt;<br />
              &nbsp;&nbsp;&nbsp;&nbsp;&lt;h1 itemprop="headline"&gt;Rendimiento Verde&lt;/h1&gt;<br />
              &nbsp;&nbsp;&lt;/header&gt;<br />
              &nbsp;&nbsp;&lt;main itemprop="articleBody"&gt;<br />
              &nbsp;&nbsp;&nbsp;&nbsp;&lt;section&gt;Carga extrema en &lt;100ms&lt;/section&gt;<br />
              &nbsp;&nbsp;&lt;/main&gt;<br />
              &lt;/article&gt;
            </div>

            <div class="flex items-center justify-between border-b border-[#1f1f24] pb-4 mb-6 relative z-10">
              <span class="text-[10px] font-mono text-[#94a3b8] flex items-center gap-1.5">
                <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>
                lighthouse-audit // google-pagespeed
              </span>
              <span class="text-[9px] text-green-400 font-mono">Mobile & Desktop PASS</span>
            </div>

            <!-- PageSpeed Audit Indicators -->
            <div class="grid grid-cols-3 gap-4 relative z-10">
              <!-- Score 1: Rendimiento -->
              <div class="flex flex-col items-center justify-center p-4 border border-green-500/20 bg-green-950/5 rounded-md text-center">
                <div class="relative w-16 h-16 flex items-center justify-center mb-2">
                  <svg class="absolute inset-0 w-full h-full -rotate-90" viewBox="0 0 36 36">
                    <path class="text-[#1f1f24]" stroke-width="2.5" stroke="currentColor" fill="none" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"/>
                    <path class="text-green-500" stroke-dasharray="100, 100" stroke-width="2.5" stroke-linecap="round" stroke="currentColor" fill="none" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"/>
                  </svg>
                  <span class="font-mono text-base font-bold text-green-500">100</span>
                </div>
                <span class="text-[9px] uppercase tracking-wider font-mono text-[#94a3b8]/80">Rendimiento</span>
              </div>

              <!-- Score 2: SEO -->
              <div class="flex flex-col items-center justify-center p-4 border border-green-500/20 bg-green-950/5 rounded-md text-center">
                <div class="relative w-16 h-16 flex items-center justify-center mb-2">
                  <svg class="absolute inset-0 w-full h-full -rotate-90" viewBox="0 0 36 36">
                    <path class="text-[#1f1f24]" stroke-width="2.5" stroke="currentColor" fill="none" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"/>
                    <path class="text-green-500" stroke-dasharray="100, 100" stroke-width="2.5" stroke-linecap="round" stroke="currentColor" fill="none" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"/>
                  </svg>
                  <span class="font-mono text-base font-bold text-green-500">100</span>
                </div>
                <span class="text-[9px] uppercase tracking-wider font-mono text-[#94a3b8]/80">SEO</span>
              </div>

              <!-- Score 3: Prácticas -->
              <div class="flex flex-col items-center justify-center p-4 border border-green-500/20 bg-green-950/5 rounded-md text-center">
                <div class="relative w-16 h-16 flex items-center justify-center mb-2">
                  <svg class="absolute inset-0 w-full h-full -rotate-90" viewBox="0 0 36 36">
                    <path class="text-[#1f1f24]" stroke-width="2.5" stroke="currentColor" fill="none" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"/>
                    <path class="text-green-500" stroke-dasharray="100, 100" stroke-width="2.5" stroke-linecap="round" stroke="currentColor" fill="none" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"/>
                  </svg>
                  <span class="font-mono text-base font-bold text-green-500">100</span>
                </div>
                <span class="text-[9px] uppercase tracking-wider font-mono text-[#94a3b8]/80">Prácticas</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Bloque Detallado 2: Aplicaciones Web a la medida (Mockup Izq, Texto Der) -->
      <div id="plataformas" class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-center">
        <!-- Mockup: CRM/ERP a medida interactivo con crecimiento de línea -->
        <div class="lg:col-span-7 order-2 lg:order-1">
          <div class="linear-card rounded-lg border border-[#1f1f24] overflow-hidden bg-[#08080c]/50 p-6 shadow-2xl">
            <!-- Header -->
            <div class="flex items-center justify-between border-b border-[#1f1f24] pb-4 mb-4">
              <span class="text-[10px] font-mono text-[#94a3b8] flex items-center gap-1.5">
                <span class="w-1.5 h-1.5 rounded-full bg-cyan-500"></span>
                vortex-platform // sales-dashboard
              </span>
              <span class="text-[9px] text-[#94a3b8]/40 font-mono">Actualizado hace un momento</span>
            </div>

            <!-- Financial growth fine-line chart & dark table -->
            <div class="space-y-4">
