---
// src/pages/login.astro
// Basic login page for the B2B Client Portal — uses Supabase Auth
// Redirects to /dashboard on successful login
import SEO from '../components/seo/SEO.astro';
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#000000" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <SEO title="Iniciar Sesión — Portal de Clientes | VortexLM" description="Accede a tu panel de cliente VortexLM para gestionar tus proyectos, facturas y vCredits." type="website" />
    <style>
      *,::before,::after{box-sizing:border-box;border-width:0;border-style:solid}
      html{-webkit-text-size-adjust:100%;tab-size:4;font-family:'Inter','system-ui',sans-serif}
      body{margin:0;background:#000;color:#f7f7f8;min-height:100vh;display:flex;align-items:center;justify-content:center}
    </style>
  </head>
  <body>
    <div class="w-full max-w-sm mx-auto px-4">
      <!-- Logo -->
      <div class="text-center mb-8">
        <a href="/" class="inline-flex items-center gap-2 group">
          <svg class="w-6 h-6 text-white transition-transform duration-300 group-hover:rotate-45" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10" class="stroke-neutral-800" />
            <circle cx="12" cy="12" r="5" />
            <circle cx="12" cy="12" r="1" fill="currentColor" />
            <path d="M12 2v3M12 19v3M2 12h3M19 12h3" />
          </svg>
          <span class="text-lg font-semibold tracking-[0.15em] text-white uppercase">Vortex<span class="font-light text-neutral-300">LM</span></span>
        </a>
        <p class="text-sm text-neutral-500 font-body-md mt-3">Portal de Clientes B2B</p>
      </div>

      <!-- Login Card -->
      <div class="bg-[#08080c] border border-[#1f1f24] rounded-xl p-6">
        <h1 class="text-base font-heading font-semibold text-white mb-1">Iniciar Sesión</h1>
        <p class="text-xs text-neutral-500 font-body-md mb-6">Ingresa con tu correo electrónico registrado.</p>

        <form id="login-form" class="space-y-4">
          <!-- Email -->
          <div>
            <label for="email" class="block text-xs text-neutral-400 font-body-md mb-1.5">Correo electrónico</label>
            <input
              id="email"
              type="email"
              autocomplete="email"
              placeholder="tu@correo.com"
              required
              class="w-full px-4 py-2.5 bg-black border border-[#1f1f24] rounded-lg text-sm text-white placeholder-neutral-600 focus:outline-none focus:border-white/30 transition-colors"
            />
          </div>

          <!-- Password -->
          <div>
            <label for="password" class="block text-xs text-neutral-400 font-body-md mb-1.5">Contraseña</label>
            <input
              id="password"
              type="password"
              autocomplete="current-password"
              placeholder="••••••••"
              required
              class="w-full px-4 py-2.5 bg-black border border-[#1f1f24] rounded-lg text-sm text-white placeholder-neutral-600 focus:outline-none focus:border-white/30 transition-colors"
            />
          </div>

          <!-- Error message -->
          <div id="login-error" class="hidden text-xs text-red-400 bg-red-500/10 border border-red-500/20 rounded-lg px-3 py-2"></div>

          <!-- Submit -->
          <button
            type="submit"
            id="login-submit"
            class="w-full px-5 py-2.5 bg-white text-black text-sm font-medium rounded-lg hover:bg-neutral-200 transition-all duration-200 active:scale-[0.98] disabled:opacity-50 disabled:cursor-not-allowed"
          >
            Acceder
          </button>
        </form>

        <p class="text-xs text-neutral-600 font-body-md text-center mt-6">
          ¿No tienes cuenta? <a href="/" class="text-white hover:text-neutral-300 transition-colors">Contáctanos</a>
        </p>
      </div>
    </div>

    <script type="module">
      import { supabase } from '../lib/supabaseClient';

      const form = document.getElementById('login-form');
      const emailInput = document.getElementById('email');
      const passwordInput = document.getElementById('password');
      const submitBtn = document.getElementById('login-submit');
      const errorEl = document.getElementById('login-error');

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        errorEl.classList.add('hidden');
        submitBtn.disabled = true;
        submitBtn.textContent = 'Ingresando...';

        const email = emailInput.value.trim();
        const password = passwordInput.value;

        try {
          const { data, error } = await supabase.auth.signInWithPassword({
            email,
            password,
          });

          if (error) {
            throw error;
          }

          // Success — redirect to dashboard
          window.location.href = '/dashboard';
        } catch (err) {
          errorEl.textContent = err.message || 'Error al iniciar sesión. Verifica tus credenciales.';
          errorEl.classList.remove('hidden');
          submitBtn.disabled = false;
          submitBtn.textContent = 'Acceder';
        }
      });
    </script>
  </body>
</html>
