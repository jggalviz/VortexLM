---
import BaseLayout from '../layouts/BaseLayout.astro';
const isLanding = true;
---

<BaseLayout title="Partner Tecnológico B2B para Startups y Empresas | VortexLM" isLanding={isLanding}>
  <main class="bg-neutral-950 text-white">

    <!-- HERO SECTION -->
    <section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-neutral-950 px-6">
      <!-- Grid overlay -->
      <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.03)_1px,transparent_1px)] bg-[size:64px_64px] [mask-image:radial-gradient(ellipse_80%_50%_at_50%_0%,#000_70%,transparent_110%)]"></div>
      <!-- Glow orb -->
      <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-gradient-to-b from-white/5 via-white/[0.02] to-transparent rounded-full blur-3xl pointer-events-none"></div>
      
      <div class="relative z-10 max-w-5xl mx-auto text-center pt-32 pb-24">
        <span class="inline-block px-3 py-1.5 border border-neutral-800 rounded-full text-[10px] font-mono uppercase tracking-widest text-neutral-500 mb-8">Partner Tecnológico</span>
        <h1 class="text-4xl md:text-7xl font-extralight tracking-tight text-white mb-8 leading-[1.08] max-w-4xl mx-auto opacity-95">
          Partner Tecnológico en Remoto para Startups y Empresas en<br/>
          <span class="text-neutral-400">Madrid y Barcelona.</span>
        </h1>
        <p class="text-sm md:text-base text-neutral-400 max-w-3xl mx-auto mb-12 leading-relaxed font-light">
          Desarrollo de software a medida, aplicaciones SaaS y migraciones críticas a Next.js / Astro. Escalabilidad garantizada, código limpio y rendimiento de nivel superior bajo estándares de ciberseguridad.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="https://wa.me/15072190951?text=Hola%20VortexLM,%20vengo%20de%20la%20landing%20B2B%20y%20me%20gustar%C3%ADa%20agendar%20una%20consultor%C3%ADa%20t%C3%A9cnica." target="_blank" class="w-full sm:w-auto px-8 py-3 bg-white text-black font-semibold text-xs rounded-full hover:bg-neutral-200 transition-all text-center duration-200 active:scale-95 shadow-[0_0_25px_rgba(255,255,255,0.15)]">
            Hablar con un Ingeniero Senior
          </a>
          <a href="/contacto" class="w-full sm:w-auto px-8 py-3 border border-neutral-800 text-neutral-300 font-medium text-xs rounded-full hover:bg-neutral-900 transition-all text-center duration-200">
            Ver Casos de Éxito →
          </a>
        </div>
      </div>
    </section>

    <!-- TRUST BAR -->
    <section class="border-t border-b border-neutral-900 py-8 bg-neutral-950/50">
      <div class="max-w-6xl mx-auto px-6">
        <p class="text-[10px] font-mono uppercase tracking-widest text-neutral-600 text-center mb-6">Especialistas en</p>
        <div class="flex flex-wrap items-center justify-center gap-8 md:gap-16 text-neutral-700">
          <span class="text-xs font-mono tracking-widest">STARTUPS</span>
          <span class="text-xs font-mono tracking-widest">SaaS</span>
          <span class="text-xs font-mono tracking-widest">FINTECH</span>
          <span class="text-xs font-mono tracking-widest">E-COMMERCE</span>
          <span class="text-xs font-mono tracking-widest">ENTERPRISE</span>
        </div>
      </div>
    </section>

    <!-- 3-COLUMN SERVICES -->
    <section class="py-32 px-6 md:px-12 bg-black border-b border-neutral-900">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-20">
          <span class="inline-block px-3 py-1.5 border border-neutral-800 rounded-full text-[10px] font-mono uppercase tracking-widest text-neutral-500 mb-6">Capacidades Técnicas</span>
          <h2 class="text-3xl md:text-5xl font-light text-white mb-6 tracking-tight">Ingeniería de primer nivel<br/><span class="text-neutral-400">para tu negocio</span></h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-16">
          <!-- Card 1 -->
          <div class="flex flex-col">
            <div class="w-full aspect-[4/3] linear-card rounded border border-neutral-900 bg-neutral-950/30 flex items-center justify-center p-6 glow-hover transition-all mb-8">
              <div class="text-center">
                <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-white/5 border border-neutral-800 flex items-center justify-center">
                  <svg class="w-7 h-7 text-neutral-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                </div>
              </div>
            </div>
            <h3 class="text-sm font-medium text-white mb-2.5">Performance Estricto (100/100)</h3>
            <p class="text-xs text-neutral-400 leading-relaxed">Eliminamos la pérdida de leads optimizando Core Web Vitals al máximo. Puntuaciones perfectas en Lighthouse y PageSpeed Insights garantizadas.</p>
          </div>
          <!-- Card 2 -->
          <div class="flex flex-col">
            <div class="w-full aspect-[4/3] linear-card rounded border border-neutral-900 bg-neutral-950/30 flex items-center justify-center p-6 glow-hover transition-all mb-8">
              <div class="text-center">
                <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-white/5 border border-neutral-800 flex items-center justify-center">
                  <svg class="w-7 h-7 text-neutral-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
                </div>
              </div>
            </div>
            <h3 class="text-sm font-medium text-white mb-2.5">Stack Moderno y Escalable</h3>
            <p class="text-xs text-neutral-400 leading-relaxed">Astro, Next.js, React, Node.js, TypeScript. Arquitecturas limpias con SSR, ISR y Edge Functions para máxima velocidad y escalabilidad.</p>
          </div>
          <!-- Card 3 -->
          <div class="flex flex-col">
            <div class="w-full aspect-[4/3] linear-card rounded border border-neutral-900 bg-neutral-950/30 flex items-center justify-center p-6 glow-hover transition-all mb-8">
              <div class="text-center">
                <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-white/5 border border-neutral-800 flex items-center justify-center">
                  <svg class="w-7 h-7 text-neutral-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                </div>
              </div>
            </div>
            <h3 class="text-sm font-medium text-white mb-2.5">Ciberseguridad y Compliance</h3>
            <p class="text-xs text-neutral-400 leading-relaxed">Desarrollo con estándares OWASP, cifrado SSL/TLS, autenticación segura y cumplimiento GDPR para operar en Europa sin riesgos.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- DETAIL BLOCK 1: Capacidad Técnica -->
    <section class="py-32 px-6 md:px-12 bg-black border-b border-neutral-900">
      <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16 md:gap-24 items-center">
        <div>
          <span class="inline-block px-3 py-1.5 border border-neutral-800 rounded-full text-[10px] font-mono uppercase tracking-widest text-neutral-500 mb-6">Capacidad Técnica</span>
          <h2 class="text-3xl md:text-4xl font-light text-white mb-6 tracking-tight leading-[1.1]">Un equipo de ingeniería<br/><span class="text-neutral-400">para tu proyecto</span></h2>
          <p class="text-sm text-neutral-400 leading-relaxed font-light mb-6">
            Actuamos como tu departamento de tecnología externo. Desde la arquitectura inicial hasta el despliegue en producción, te acompañamos con ingenieros senior que dominan las tecnologías más demandadas del mercado.
          </p>
          <ul class="space-y-3">
            <li class="flex items-start gap-3 text-xs text-neutral-400">
              <svg class="w-4 h-4 text-neutral-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span>Equipo senior con experiencia en startups y enterprise</span>
            </li>
            <li class="flex items-start gap-3 text-xs text-neutral-400">
              <svg class="w-4 h-4 text-neutral-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span>Comunicación diaria vía Slack / Discord / WhatsApp</span>
            </li>
            <li class="flex items-start gap-3 text-xs text-neutral-400">
              <svg class="w-4 h-4 text-neutral-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span>Entregas semanales con CI/CD y despliegue continuo</span>
            </li>
          </ul>
        </div>
        <div class="w-full aspect-[4/3] linear-card rounded border border-neutral-900 bg-neutral-950/30 flex items-center justify-center p-8 glow-hover transition-all">
          <div class="text-center text-neutral-700">
            <svg class="w-16 h-16 mx-auto mb-4 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"/></svg>
            <p class="text-[10px] font-mono uppercase tracking-widest">CI/CD Pipeline Integrado</p>
          </div>
        </div>
      </div>
    </section>

    <!-- DETAIL BLOCK 2: Metodología Ágil -->
    <section class="py-32 px-6 md:px-12 bg-black border-b border-neutral-900">
      <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16 md:gap-24 items-center">
        <div class="order-2 md:order-1 w-full aspect-[4/3] linear-card rounded border border-neutral-900 bg-neutral-950/30 flex items-center justify-center p-8 glow-hover transition-all">
          <div class="text-center text-neutral-700">
            <svg class="w-16 h-16 mx-auto mb-4 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
            <p class="text-[10px] font-mono uppercase tracking-widest">Metodología Ágil</p>
          </div>
        </div>
        <div class="order-1 md:order-2">
          <span class="inline-block px-3 py-1.5 border border-neutral-800 rounded-full text-[10px] font-mono uppercase tracking-widest text-neutral-500 mb-6">Metodología Ágil</span>
          <h2 class="text-3xl md:text-4xl font-light text-white mb-6 tracking-tight leading-[1.1]">Trabajamos con sprints<br/><span class="text-neutral-400">resultados cada 2 semanas</span></h2>
          <p class="text-sm text-neutral-400 leading-relaxed font-light mb-6">
            Metodología Scrum adaptada al trabajo remoto. Planificamos en sprints de dos semanas con demos al final de cada ciclo. Tendrás visibilidad total del progreso y capacidad de ajustar prioridades en tiempo real.
          </p>
          <ul class="space-y-3">
            <li class="flex items-start gap-3 text-xs text-neutral-400">
              <svg class="w-4 h-4 text-neutral-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span>Sprints de 2 semanas con entregas funcionales</span>
            </li>
            <li class="flex items-start gap-3 text-xs text-neutral-400">
              <svg class="w-4 h-4 text-neutral-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span>Demos semanales y reportes de avance</span>
            </li>
            <li class="flex items-start gap-3 text-xs text-neutral-400">
              <svg class="w-4 h-4 text-neutral-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span>Roadmap transparente con milestones definidos</span>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- FAQ SECTION -->
    <section class="py-32 px-6 md:px-12 bg-black border-b border-neutral-900">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-16">
          <span class="inline-block px-3 py-1.5 border border-neutral-800 rounded-full text-[10px] font-mono uppercase tracking-widest text-neutral-500 mb-6">FAQ</span>
          <h2 class="text-3xl md:text-4xl font-light text-white tracking-tight">Preguntas Frecuentes</h2>
        </div>
        <div class="space-y-4">
          <details class="group border border-neutral-900 rounded-lg overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-5 text-sm font-medium text-white cursor-pointer hover:bg-neutral-900/30 transition-colors list-none">
              ¿Cuál es el modelo de contratación?
              <svg class="w-4 h-4 text-neutral-500 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-xs text-neutral-400 leading-relaxed">
              Ofrecemos modelos flexibles: dedicación full-time por hora/mes, proyectos con presupuesto fijo, o retainers mensuales para mantenimiento y soporte continuo. Nos adaptamos a tus necesidades.
            </div>
          </details>
          <details class="group border border-neutral-900 rounded-lg overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-5 text-sm font-medium text-white cursor-pointer hover:bg-neutral-900/30 transition-colors list-none">
              ¿Cómo funciona la comunicación con la diferencia horaria?
              <svg class="w-4 h-4 text-neutral-500 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-xs text-neutral-400 leading-relaxed">
              Trabajamos en horario compatible con Europa (GMT-4 / Venezuela). Nuestro equipo está disponible desde las 8:00 AM hasta las 6:00 PM (hora local), con solapamiento directo con horario laboral europeo. Garantizamos respuesta en menos de 2 horas hábiles.
            </div>
          </details>
          <details class="group border border-neutral-900 rounded-lg overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-5 text-sm font-medium text-white cursor-pointer hover:bg-neutral-900/30 transition-colors list-none">
              ¿Qué tecnologías dominan?
              <svg class="w-4 h-4 text-neutral-500 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-xs text-neutral-400 leading-relaxed">
              Astro, Next.js, React, Node.js, TypeScript, Tailwind CSS, PostgreSQL, Prisma, Vercel, AWS, Docker, y más. Evaluamos tu stack y te recomendamos la mejor arquitectura para tu proyecto.
            </div>
          </details>
          <details class="group border border-neutral-900 rounded-lg overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-5 text-sm font-medium text-white cursor-pointer hover:bg-neutral-900/30 transition-colors list-none">
              ¿Cuál es el timeline típico de un proyecto?
              <svg class="w-4 h-4 text-neutral-500 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-xs text-neutral-400 leading-relaxed">
              Un MVP funcional puede estar listo en 4 a 6 semanas. Proyectos más complejos como plataformas SaaS enterprise pueden tomar de 3 a 6 meses. Durante la consultoría inicial definimos un roadmap detallado con hitos claros.
            </div>
          </details>
        </div>
      </div>
    </section>

    <!-- CONTACT FORM SECTION -->
    <section id="contacto-form" class="py-32 px-6 md:px-12 bg-black">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-12">
          <span class="inline-block px-3 py-1.5 border border-neutral-800 rounded-full text-[10px] font-mono uppercase tracking-widest text-neutral-500 mb-6">Contacto</span>
          <h2 class="text-3xl md:text-4xl font-light text-white mb-4 tracking-tight">Solicita una consultoría gratuita</h2>
          <p class="text-sm text-neutral-400 font-light">Cuéntanos sobre tu proyecto y te enviaremos una propuesta técnica en menos de 48 horas.</p>
        </div>
        <form id="contact-form-partner" class="linear-card p-8 rounded-lg border border-neutral-900 bg-neutral-950/40 text-left space-y-6">
          <input type="hidden" name="service" value="partner-tecnologico-b2b" />
          <div>
            <label class="block text-[10px] font-mono text-neutral-400 uppercase tracking-wider mb-2 font-medium">Nombre completo</label>
            <input type="text" name="name" required placeholder="Tu nombre" class="w-full bg-black border border-neutral-900 rounded px-4 py-3 text-xs text-white placeholder-neutral-700 focus:outline-none focus:border-neutral-600 transition-colors" />
          </div>
          <div>
            <label class="block text-[10px] font-mono text-neutral-400 uppercase tracking-wider mb-2 font-medium">Correo electrónico</label>
            <input type="email" name="email" required placeholder="tu@empresa.com" class="w-full bg-black border border-neutral-900 rounded px-4 py-3 text-xs text-white placeholder-neutral-700 focus:outline-none focus:border-neutral-600 transition-colors" />
          </div>
          <div>
            <label class="block text-[10px] font-mono text-neutral-400 uppercase tracking-wider mb-2 font-medium">Empresa (opcional)</label>
            <input type="text" name="company" placeholder="Nombre de tu empresa" class="w-full bg-black border border-neutral-900 rounded px-4 py-3 text-xs text-white placeholder-neutral-700 focus:outline-none focus:border-neutral-600 transition-colors" />
          </div>
          <div>
            <label class="block text-[10px] font-mono text-neutral-400 uppercase tracking-wider mb-2 font-medium">Cuéntanos sobre tu proyecto</label>
            <textarea name="message" required rows="4" placeholder="Describe tu proyecto, stack tecnológico actual, objetivos y requerimientos..." class="w-full bg-black border border-neutral-900 rounded px-4 py-3 text-xs text-white placeholder-neutral-700 focus:outline-none focus:border-neutral-600 transition-colors resize-none"></textarea>
          </div>
          <button type="submit" class="w-full py-3 bg-white text-black font-semibold text-xs rounded hover:bg-neutral-200 transition-colors duration-200">
            Enviar Solicitud
          </button>
          <p id="form-status-partner" class="text-xs text-center hidden"></p>
        </form>
      </div>
    </section>

  </main>
</BaseLayout>

<script>
  document.getElementById('contact-form-partner')?.addEventListener('submit', async function(e) {
    e.preventDefault();
    const form = e.target;
    const status = document.getElementById('form-status-partner');
    const btn = form.querySelector('button[type="submit"]');
    const originalText = btn.textContent;
    btn.textContent = 'Enviando...';
    btn.disabled = true;
    status.classList.add('hidden');
    try {
      const formData = new FormData(form);
      const res = await fetch('/api/contact', { method: 'POST', body: formData });
      const data = await res.json();
      if (res.ok) {
        status.textContent = '✅ ¡Solicitud enviada! Te contactaremos en menos de 48 horas.';
        status.classList.remove('hidden', 'text-red-400');
        status.classList.add('text-green-400');
        form.reset();
      } else {
        throw new Error(data.error || 'Error al enviar');
      }
    } catch (err) {
      status.textContent = '❌ Error al enviar. Intenta de nuevo o escríbenos a info@vortexlm.com';
      status.classList.remove('hidden', 'text-green-400');
      status.classList.add('text-red-400');
    }
    btn.textContent = originalText;
    btn.disabled = false;
  });
</script>
