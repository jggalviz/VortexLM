---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Agencia de Diseño Web en Caracas | Vortex Logic"
  description="Agencia boutique de diseño web y desarrollo a medida en Caracas. Transformamos marcas con interfaces UI/UX de alto impacto, velocidad extrema y optimización SEO."
  isLocalBusiness={true}
>
  <!-- ─── HERO ───────────────────────────────────────────────────── -->
  <section class="relative pt-36 pb-32 overflow-hidden linear-gradient-bg border-b border-[#1f1f24] px-6 md:px-12">
    <div class="absolute inset-0 linear-grid opacity-30 pointer-events-none"></div>
    <div class="max-w-[1200px] mx-auto text-center relative z-10">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-white/[0.015] blur-[120px] rounded-full pointer-events-none"></div>

      <h1 class="text-4xl md:text-7xl font-extralight tracking-tight text-white mb-8 leading-[1.08] max-w-4xl mx-auto opacity-95">
        Agencia de Diseño Web en Caracas: Interfaces de Alto Impacto y Conversión
      </h1>

      <p class="text-base md:text-lg text-[#cbd5e1] font-light mb-12 max-w-3xl mx-auto leading-relaxed">
        Somos una agencia boutique de diseño web y desarrollo a medida. Creamos experiencias 
        digitales que transforman marcas: interfaces UI/UX impecables, velocidad extrema y 
        estrategia SEO integrada desde el primer boceto en Figma hasta el despliegue final.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-6 mb-20">
        <a href="#contacto" class="w-full sm:w-auto px-8 py-3 bg-white text-black font-semibold text-xs rounded-full hover:bg-neutral-200 transition-all text-center duration-200 active:scale-95 shadow-[0_0_25px_rgba(255,255,255,0.15)]">
          Iniciar Proyecto con la Agencia
        </a>
        <a href="#metodologia" class="w-full sm:w-auto px-6 py-3 text-white/90 font-medium text-xs rounded-full hover:text-white flex items-center justify-center gap-1.5 group transition-colors">
          Nuestra metodología <span class="group-hover:translate-x-1 transition-transform">➔</span>
        </a>
      </div>

      <!-- Mockup de editor de diseño UI/UX estilo Figma -->
      <div class="relative max-w-5xl mx-auto">
        <div class="linear-card rounded-lg overflow-hidden border border-[#2e2e34] shadow-[0_50px_100px_-20px_rgba(0,0,0,0.98)]">
          <div class="bg-[#08080c] px-4 py-3.5 flex items-center justify-between border-b border-[#1f1f24]">
            <div class="flex items-center gap-2">
              <span class="w-2.5 h-2.5 rounded-full bg-[#ff5f56]/50"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-[#ffbd2e]/50"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-[#27c93f]/50"></span>
            </div>
            <div class="text-[10px] font-mono text-[#cbd5e1]/40 flex items-center gap-1.5">
              <span class="material-symbols-outlined text-[10px]">frame</span>
              vortex-design // Landing Page Wireframe
            </div>
            <div class="w-12"></div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-12 min-h-[440px] bg-[#000000] text-left">
            <!-- Panel izquierdo: capas / layers -->
            <div class="col-span-1 md:col-span-3 p-4 border-r border-[#1f1f24] bg-[#050507]/60">
              <div class="text-[9px] uppercase tracking-wider text-[#cbd5e1]/40 mb-3 font-mono font-semibold">Capas</div>
              <div class="space-y-1.5 font-mono text-[10px]">
                <div class="flex items-center gap-1.5 text-white/90">
                  <span class="w-3 h-3 rounded border border-[#1f1f24] bg-purple-500/20"></span>
                  Hero Section
                </div>
                <div class="flex items-center gap-1.5 text-[#cbd5e1] pl-4">
                  <span class="w-3 h-3 rounded border border-[#1f1f24] bg-cyan-500/20"></span>
                  Navbar
                </div>
                <div class="flex items-center gap-1.5 text-white/90">
                  <span class="w-3 h-3 rounded border border-[#1f1f24] bg-cyan-500/20"></span>
                  Features Grid
                </div>
                <div class="flex items-center gap-1.5 text-[#cbd5e1] pl-4">
                  <span class="w-3 h-3 rounded border border-[#1f1f24] bg-green-500/20"></span>
                  Card Component
                </div>
                <div class="flex items-center gap-1.5 text-white/90">
                  <span class="w-3 h-3 rounded border border-[#1f1f24] bg-purple-500/20"></span>
                  Testimonios
                </div>
                <div class="flex items-center gap-1.5 text-white/90">
                  <span class="w-3 h-3 rounded border border-[#1f1f24] bg-orange-500/20"></span>
                  Contact Form
                </div>
                <div class="flex items-center gap-1.5 text-[#cbd5e1]">
                  <span class="w-3 h-3 rounded border border-[#1f1f24] bg-[#1f1f24]"></span>
                  Footer
                </div>
              </div>
              <div class="mt-4 pt-4 border-t border-[#1f1f24]/50">
                <div class="text-[9px] font-mono text-[#cbd5e1]/40">Componentes: 12</div>
                <div class="text-[9px] font-mono text-[#cbd5e1]/40">Estilos: Tailwind</div>
              </div>
            </div>

            <!-- Panel central: wireframe visual -->
            <div class="col-span-1 md:col-span-6 p-6 border-r border-[#1f1f24]">
              <div class="text-[9px] uppercase tracking-wider text-[#cbd5e1]/40 mb-3 font-mono font-semibold">Lienzo de diseño</div>

              <!-- Simulación de wireframe con grids y guías -->
              <div class="border border-[#1f1f24] rounded-lg p-4 bg-[#050507]/40 relative">
                <!-- Guías de alineación verticales -->
                <div class="absolute inset-0 flex justify-between pointer-events-none px-8">
                  <div class="w-px h-full bg-purple-500/10"></div>
                  <div class="w-px h-full bg-purple-500/10"></div>
                  <div class="w-px h-full bg-purple-500/10"></div>
                  <div class="w-px h-full bg-purple-500/10"></div>
                </div>

                <div class="space-y-3 relative z-10">
                  <!-- Barra de navegación -->
                  <div class="flex items-center justify-between p-2 border border-[#1f1f24]/60 rounded">
                    <div class="flex gap-2">
                      <div class="w-16 h-2 rounded bg-white/10"></div>
                      <div class="w-12 h-2 rounded bg-[#1f1f24]"></div>
                      <div class="w-14 h-2 rounded bg-[#1f1f24]"></div>
                    </div>
                    <div class="w-20 h-2 rounded bg-white/15"></div>
                  </div>

                  <!-- Hero block -->
                  <div class="p-4 border border-[#1f1f24]/60 rounded text-center">
                    <div class="w-3/4 h-4 rounded bg-white/10 mx-auto mb-2"></div>
                    <div class="w-1/2 h-2 rounded bg-[#1f1f24] mx-auto mb-3"></div>
                    <div class="flex justify-center gap-2">
                      <div class="w-24 h-4 rounded bg-white/15"></div>
                      <div class="w-20 h-4 rounded border border-[#1f1f24]/60"></div>
                    </div>
                  </div>

                  <!-- Features grid -->
                  <div class="grid grid-cols-3 gap-2">
                    <div class="p-2 border border-[#1f1f24]/60 rounded">
                      <div class="w-full h-8 rounded bg-[#1f1f24]/40 mb-1"></div>
                      <div class="w-3/4 h-1.5 rounded bg-[#1f1f24]"></div>
                    </div>
                    <div class="p-2 border border-[#1f1f24]/60 rounded">
                      <div class="w-full h-8 rounded bg-[#1f1f24]/40 mb-1"></div>
                      <div class="w-3/4 h-1.5 rounded bg-[#1f1f24]"></div>
                    </div>
                    <div class="p-2 border border-[#1f1f24]/60 rounded">
                      <div class="w-full h-8 rounded bg-[#1f1f24]/40 mb-1"></div>
                      <div class="w-3/4 h-1.5 rounded bg-[#1f1f24]"></div>
                    </div>
                  </div>

                  <!-- Footer -->
                  <div class="flex justify-between p-2 border border-[#1f1f24]/60 rounded">
                    <div class="w-20 h-1.5 rounded bg-[#1f1f24]"></div>
                    <div class="w-16 h-1.5 rounded bg-[#1f1f24]"></div>
                  </div>
                </div>
              </div>

              <!-- Indicadores de especificaciones de diseño -->
              <div class="flex gap-3 mt-3 text-[9px] font-mono text-[#cbd5e1]/40">
                <span>12-column grid</span>
                <span>Auto layout</span>
                <span>Constraints</span>
                <span>Variants</span>
              </div>
            </div>

            <!-- Panel derecho: propiedades de diseño -->
            <div class="col-span-1 md:col-span-3 p-4 bg-[#050507]/30 font-mono text-[10px]">
              <div class="text-[9px] uppercase tracking-wider text-[#cbd5e1]/40 mb-3 font-semibold">Propiedades</div>
              <div class="space-y-3">
                <div>
                  <div class="text-[#cbd5e1]/60 mb-1">Frame</div>
                  <div class="p-2 border border-[#1f1f24] rounded bg-black/40">
                    <div class="flex justify-between">
                      <span class="text-[#cbd5e1]/60">W</span>
                      <span class="text-white">1440px</span>
                    </div>
                    <div class="flex justify-between">
                      <span class="text-[#cbd5e1]/60">H</span>
                      <span class="text-white">auto</span>
                    </div>
                  </div>
                </div>
                <div>
                  <div class="text-[#cbd5e1]/60 mb-1">Paleta</div>
                  <div class="flex gap-1.5">
                    <div class="w-5 h-5 rounded-full bg-black border border-[#1f1f24]"></div>
                    <div class="w-5 h-5 rounded-full bg-white border border-[#1f1f24]"></div>
                    <div class="w-5 h-5 rounded-full bg-[#cbd5e1] border border-[#1f1f24]"></div>
                    <div class="w-5 h-5 rounded-full bg-purple-500 border border-[#1f1f24]"></div>
                    <div class="w-5 h-5 rounded-full bg-cyan-500 border border-[#1f1f24]"></div>
                  </div>
                </div>
                <div>
                  <div class="text-[#cbd5e1]/60 mb-1">Tipografía</div>
                  <div class="p-2 border border-[#1f1f24] rounded bg-black/40">
                    <div class="text-white text-xs">Inter Variable</div>
                    <div class="text-[#cbd5e1]/40 text-[9px]">Light 300 · Regular 400 · Medium 500</div>
                  </div>
                </div>
                <div class="pt-2 border-t border-[#1f1f24]/50">
                  <div class="text-[#cbd5e1]/40 text-[9px]">Export: .astro / .tsx</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── METODOLOGÍA DE TRABAJO ─────────────────────────────────── -->
  <section id="metodologia" class="py-36 px-6 md:px-12 bg-black relative border-b border-[#1f1f24]">
    <div class="max-w-[1200px] mx-auto relative z-10">
      <div class="max-w-4xl mb-24">
        <span class="text-[10px] font-mono text-[#cbd5e1] uppercase tracking-widest block mb-3 font-medium">Metodologías</span>
        <h2 class="text-2xl md:text-4xl font-light text-white tracking-tight leading-snug">
          De la estrategia al despliegue. Un proceso diseñado para crear resultados medibles.
        </h2>
      </div>

      <!-- Timeline vertical estilizada -->
      <div class="relative max-w-4xl mx-auto">
        <!-- Línea central -->
        <div class="absolute left-[19px] top-0 bottom-0 w-px bg-gradient-to-b from-purple-500/40 via-cyan-500/40 to-green-500/40"></div>

        <div class="space-y-24">
          <!-- Fase 1: Estrategia -->
          <div class="relative pl-14">
            <div class="absolute left-[10px] w-[20px] h-[20px] rounded-full bg-purple-500/20 border-2 border-purple-500 flex items-center justify-center">
              <span class="w-2 h-2 rounded-full bg-purple-500"></span>
            </div>
            <div class="linear-card rounded-lg border border-[#1f1f24] bg-[#08080c]/40 p-6 lg:p-8 glow-hover transition-all">
              <div class="flex items-center gap-3 mb-4">
                <span class="text-[10px] font-mono text-purple-400 uppercase tracking-widest font-medium">Fase 1</span>
                <span class="text-[10px] font-mono text-[#cbd5e1]/40">Duración aprox: 1 semana</span>
              </div>
              <h3 class="text-lg md:text-xl font-light text-white tracking-tight mb-3">Estrategia y UI/UX — Prototipado en Figma</h3>
              <p class="text-xs text-[#cbd5e1] font-light leading-relaxed mb-4">
                Investigamos tu industria, analizamos a tu competencia en Caracas y definimos 
                la arquitectura de información ideal. Creamos wireframes y prototipos 
                interactivos en Figma con toda la jerarquía visual, flujo de navegación y 
                diseño responsive para móvil, tablet y escritorio. Cada decisión de diseño 
                está respaldada por principios de conversión y usabilidad.
              </p>
              <ul class="space-y-1.5 text-[10px] text-[#cbd5e1] font-mono">
                <li class="flex items-center gap-2"><span class="text-purple-400">→</span> Research & benchmark competitivo</li>
                <li class="flex items-center gap-2"><span class="text-purple-400">→</span> Wireframes de alta fidelidad</li>
                <li class="flex items-center gap-2"><span class="text-purple-400">→</span> Prototipo interactivo navegable</li>
                <li class="flex items-center gap-2"><span class="text-purple-400">→</span> Sistema de diseño (colores, tipografía, componentes)</li>
              </ul>
            </div>
          </div>

          <!-- Fase 2: Desarrollo -->
          <div class="relative pl-14">
            <div class="absolute left-[10px] w-[20px] h-[20px] rounded-full bg-cyan-500/20 border-2 border-cyan-500 flex items-center justify-center">
              <span class="w-2 h-2 rounded-full bg-cyan-500"></span>
            </div>
            <div class="linear-card rounded-lg border border-[#1f1f24] bg-[#08080c]/40 p-6 lg:p-8 glow-hover transition-all">
              <div class="flex items-center gap-3 mb-4">
                <span class="text-[10px] font-mono text-cyan-400 uppercase tracking-widest font-medium">Fase 2</span>
                <span class="text-[10px] font-mono text-[#cbd5e1]/40">Duración aprox: 2-3 semanas</span>
              </div>
              <h3 class="text-lg md:text-xl font-light text-white tracking-tight mb-3">Desarrollo de Alto Rendimiento (Astro + React)</h3>
              <p class="text-xs text-[#cbd5e1] font-light leading-relaxed mb-4">
                Convertimos los prototipos en código limpio y ultrarrápido con Astro, React 
                y Tailwind CSS. Implementamos animaciones sutiles, transiciones de página 
                instantáneas y carga progresiva de imágenes. Cada componente se construye 
                con TypeScript estricto, accesibilidad ARIA y optimización para Core Web Vitals.
              </p>
              <ul class="space-y-1.5 text-[10px] text-[#cbd5e1] font-mono">
                <li class="flex items-center gap-2"><span class="text-cyan-400">→</span> Desarrollo basado en componentes</li>
                <li class="flex items-center gap-2"><span class="text-cyan-400">→</span> Islands Architecture (cero JS innecesario)</li>
                <li class="flex items-center gap-2"><span class="text-cyan-400">→</span> Optimización de imágenes y fuentes</li>
                <li class="flex items-center gap-2"><span class="text-cyan-400">→</span> Responsive testing en 20+ dispositivos</li>
              </ul>
            </div>
          </div>

          <!-- Fase 3: SEO y Lanzamiento -->
          <div class="relative pl-14">
            <div class="absolute left-[10px] w-[20px] h-[20px] rounded-full bg-green-500/20 border-2 border-green-500 flex items-center justify-center">
              <span class="w-2 h-2 rounded-full bg-green-500"></span>
            </div>
            <div class="linear-card rounded-lg border border-[#1f1f24] bg-[#08080c]/40 p-6 lg:p-8 glow-hover transition-all">
              <div class="flex items-center gap-3 mb-4">
                <span class="text-[10px] font-mono text-green-400 uppercase tracking-widest font-medium">Fase 3</span>
                <span class="text-[10px] font-mono text-[#cbd5e1]/40">Duración aprox: 1 semana</span>
              </div>
              <h3 class="text-lg md:text-xl font-light text-white tracking-tight mb-3">Optimización SEO y Lanzamiento</h3>
              <p class="text-xs text-[#cbd5e1] font-light leading-relaxed mb-4">
                Antes del lanzamiento, auditamos cada página con herramientas profesionales: 
                etiquetas meta, datos estructurados Schema.org, Open Graph, archivo robots.txt, 
                sitemap XML y rendimiento Lighthouse. Desplegamos en Vercel con SSL 
                automatizado y monitoreo continuo. Tu web sale al mundo con la máxima 
                velocidad y el mejor posicionamiento posible.
              </p>
              <ul class="space-y-1.5 text-[10px] text-[#cbd5e1] font-mono">
                <li class="flex items-center gap-2"><span class="text-green-400">→</span> SEO técnico completo (meta tags, Schema, OG)</li>
                <li class="flex items-center gap-2"><span class="text-green-400">→</span> Core Web Vitals optimizado (Lighthouse 95+)</li>
                <li class="flex items-center gap-2"><span class="text-green-400">→</span> Deploy en Vercel Edge + SSL + CDN</li>
                <li class="flex items-center gap-2"><span class="text-green-400">→</span> Google Search Console + Analytics configurado</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── SERVICIOS DE AGENCIA ───────────────────────────────────── -->
  <section class="py-36 px-6 md:px-12 bg-black border-b border-[#1f1f24] relative">
    <div class="max-w-[1200px] mx-auto relative z-10">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="text-[10px] font-mono text-[#cbd5e1] uppercase tracking-widest block mb-3 font-medium">Servicios</span>
        <h2 class="text-3xl md:text-5xl font-light text-white tracking-tight">Todo lo que necesitas para brillar en digital</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Servicio 1 -->
        <div class="linear-card rounded-lg border border-[#1f1f24] bg-[#08080c]/40 p-6 glow-hover transition-all min-h-[200px]">
          <div class="space-y-3">
            <span class="material-symbols-outlined text-lg text-purple-400">palette</span>
            <h3 class="text-sm font-medium text-white">Diseño UI/UX</h3>
            <p class="text-[10px] text-[#cbd5e1] leading-relaxed">
              Interfaces modernas, intuitivas y centradas en el usuario. Prototipado en Figma, 
              sistemas de diseño y pruebas de usabilidad antes de escribir una línea de código.
            </p>
          </div>
        </div>

        <!-- Servicio 2 -->
        <div class="linear-card rounded-lg border border-[#1f1f24] bg-[#08080c]/40 p-6 glow-hover transition-all min-h-[200px]">
          <div class="space-y-3">
            <span class="material-symbols-outlined text-lg text-cyan-400">code</span>
            <h3 class="text-sm font-medium text-white">Desarrollo Web</h3>
            <p class="text-[10px] text-[#cbd5e1] leading-relaxed">
              Sitios corporativos, landing pages y plataformas web con Astro, React, Next.js 
              y el stack Jamstack más moderno. Carga en milisegundos y SEO nativo.
            </p>
          </div>
        </div>

        <!-- Servicio 3 -->
        <div class="linear-card rounded-lg border border-[#1f1f24] bg-[#08080c]/40 p-6 glow-hover transition-all min-h-[200px]">
          <div class="space-y-3">
            <span class="material-symbols-outlined text-lg text-green-400">trending_up</span>
            <h3 class="text-sm font-medium text-white">Estrategia SEO</h3>
            <p class="text-[10px] text-[#cbd5e1] leading-relaxed">
              Auditoría técnica, investigación de keywords locales en Caracas, optimización 
              on-page, datos estructurados y Google My Business integrado.
            </p>
          </div>
        </div>

        <!-- Servicio 4 -->
        <div class="linear-card rounded-lg border border-[#1f1f24] bg-[#08080c]/40 p-6 glow-hover transition-all min-h-[200px]">
          <div class="space-y-3">
            <span class="material-symbols-outlined text-lg text-orange-400">speed</span>
            <h3 class="text-sm font-medium text-white">Optimización de Rendimiento</h3>
            <p class="text-[10px] text-[#cbd5e1] leading-relaxed">
              Transformamos sitios lentos en experiencias ultrarrápidas. Core Web Vitals, 
              compresión de assets, lazy loading y CDN global.
            </p>
          </div>
        </div>

        <!-- Servicio 5 -->
        <div class="linear-card rounded-lg border border-[#1f1f24] bg-[#08080c]/40 p-6 glow-hover transition-all min-h-[200px]">
          <div class="space-y-3">
            <span class="material-symbols-outlined text-lg text-pink-400">smartphone</span>
            <h3 class="text-sm font-medium text-white">PWAs y Apps Web</h3>
            <p class="text-[10px] text-[#cbd5e1] leading-relaxed">
              Aplicaciones web progresivas con funcionamiento offline, notificaciones push 
              y experiencia de app nativa sin pasar por app stores.
            </p>
          </div>
        </div>

        <!-- Servicio 6 -->
        <div class="linear-card rounded-lg border border-[#1f1f24] bg-[#08080c]/40 p-6 glow-hover transition-all min-h-[200px]">
          <div class="space-y-3">
            <span class="material-symbols-outlined text-lg text-yellow-400">support</span>
            <h3 class="text-sm font-medium text-white">Mantenimiento y Soporte</h3>
            <p class="text-[10px] text-[#cbd5e1] leading-relaxed">
              Planes de mantenimiento mensual con actualizaciones, backups, monitoreo 24/7 
              y soporte prioritario por Slack o WhatsApp.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── BLOQUE DETALLADO: PROCESO DE DISEÑO ────────────────────── -->
  <section class="py-36 px-6 md:px-12 bg-black border-b border-[#1f1f24] relative">
    <div class="max-w-[1200px] mx-auto space-y-44 relative z-10">

      <!-- Bloque: Diseño UI/UX -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-center">
        <div class="lg:col-span-5 space-y-5">
          <span class="text-[10px] font-mono text-[#cbd5e1] uppercase tracking-widest block font-medium">UI/UX Design</span>
          <h2 class="text-2xl md:text-4xl font-light text-white tracking-tight leading-tight">
            Cada píxel cuenta. Diseñamos experiencias que cautivan y convierten.
          </h2>
          <p class="text-sm text-[#cbd5e1] font-light leading-relaxed">
            Nuestro proceso de diseño comienza con la investigación profunda de tu audiencia 
            en Caracas. Definimos la personalidad de tu marca, creamos moodboards, 
            diseñamos sistemas de componentes reutilizables y prototipamos cada interacción. 
            No diseñamos para que se vea bonito: diseñamos para que tu negocio venda más.
          </p>
          <ul class="space-y-2 text-xs text-[#cbd5e1] font-light">
            <li class="flex items-center gap-2">
              <span class="material-symbols-outlined text-sm text-green-400">check_circle</span>
              Prototipos interactivos en Figma con feedback del cliente
            </li>
            <li class="flex items-center gap-2">
