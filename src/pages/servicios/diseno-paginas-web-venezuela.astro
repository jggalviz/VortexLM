---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Diseño de Páginas Web en Venezuela | Alta Velocidad | Vortex Logic"
  description="Agencia de desarrollo y diseño web en Venezuela. Creamos plataformas digitales y páginas web profesionales de carga instantánea listas para vender."
  isLocalBusiness={false}
>
  <!-- ─── HERO ───────────────────────────────────────────────────── -->
  <section class="relative pt-36 pb-32 overflow-hidden linear-gradient-bg border-b border-[#1f1f24] px-6 md:px-12">
    <div class="absolute inset-0 linear-grid opacity-30 pointer-events-none"></div>
    <div class="max-w-[1200px] mx-auto text-center relative z-10">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-white/[0.015] blur-[120px] rounded-full pointer-events-none"></div>

      <h1 class="text-4xl md:text-7xl font-extralight tracking-tight text-white mb-8 leading-[1.08] max-w-4xl mx-auto opacity-95">
        Diseño de Páginas Web en Venezuela con Rendimiento Premium
      </h1>

      <p class="text-base md:text-lg text-[#cbd5e1] font-light mb-12 max-w-3xl mx-auto leading-relaxed">
        Creamos sitios web ultrarrápidos que cargan en milisegundos incluso en conexiones 3G. 
        Optimizados para el ecosistema digital venezolano: pasarelas de pago internacionales, 
        integraciones contables y delivery. Tu negocio en todo el país, sin fronteras.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-6 mb-20">
        <a href="#contacto" class="w-full sm:w-auto px-8 py-3 bg-white text-black font-semibold text-xs rounded-full hover:bg-neutral-200 transition-all text-center duration-200 active:scale-95 shadow-[0_0_25px_rgba(255,255,255,0.15)]">
          Cotizar Proyecto Nacional
        </a>
        <a href="#ventajas" class="w-full sm:w-auto px-6 py-3 text-white/90 font-medium text-xs rounded-full hover:text-white flex items-center justify-center gap-1.5 group transition-colors">
          Ventajas nacionales <span class="group-hover:translate-x-1 transition-transform">➔</span>
        </a>
      </div>

      <!-- Mockup: Mapa CDN + gráfico de rendimiento comparativo -->
      <div class="relative max-w-5xl mx-auto">
        <div class="linear-card rounded-lg overflow-hidden border border-[#2e2e34] shadow-[0_50px_100px_-20px_rgba(0,0,0,0.98)]">
          <div class="bg-[#08080c] px-4 py-3.5 flex items-center justify-between border-b border-[#1f1f24]">
            <div class="flex items-center gap-2">
              <span class="w-2.5 h-2.5 rounded-full bg-[#ff5f56]/50"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-[#ffbd2e]/50"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-[#27c93f]/50"></span>
            </div>
            <div class="text-[10px] font-mono text-[#cbd5e1]/40 flex items-center gap-1.5">
              <span class="material-symbols-outlined text-[10px]">globe</span>
              vortex-cdn // edge-regions:latam
            </div>
            <div class="w-12"></div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-12 min-h-[420px] bg-[#000000] text-left">
            <!-- Panel izquierdo: Mapa de distribución CDN -->
            <div class="col-span-1 md:col-span-7 p-6 border-r border-[#1f1f24]">
              <div class="text-[9px] uppercase tracking-wider text-[#cbd5e1]/40 mb-4 font-mono font-semibold">Red de Distribución Global (CDN)</div>
              <!-- Mapa simulado con puntos de presencia -->
              <div class="relative border border-[#1f1f24] rounded-lg bg-[#050507]/40 p-6 h-[260px] overflow-hidden">
                <!-- Líneas de conexión horizontales simulando mapa -->
                <svg class="absolute inset-0 w-full h-full opacity-20" viewBox="0 0 400 200" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M50 100 Q120 30 200 60 T350 80" stroke="#6366f1" stroke-width="0.5" stroke-dasharray="3 3"/>
                  <path d="M50 100 Q130 150 220 120 T360 100" stroke="#22d3ee" stroke-width="0.5" stroke-dasharray="3 3"/>
                  <path d="M50 100 Q110 160 200 170 T340 150" stroke="#22d3ee" stroke-width="0.5" stroke-dasharray="3 3"/>
                  <circle cx="50" cy="100" r="4" fill="#6366f1" opacity="0.8"/>
                  <circle cx="120" cy="70" r="3" fill="#22d3ee" opacity="0.6"/>
                  <circle cx="200" cy="60" r="3" fill="#22d3ee" opacity="0.6"/>
                  <circle cx="280" cy="55" r="2.5" fill="#22d3ee" opacity="0.5"/>
                  <circle cx="350" cy="80" r="3" fill="#22d3ee" opacity="0.6"/>
                  <circle cx="130" cy="130" r="2.5" fill="#22d3ee" opacity="0.5"/>
                  <circle cx="220" cy="120" r="3" fill="#22d3ee" opacity="0.6"/>
                  <circle cx="310" cy="110" r="2.5" fill="#22d3ee" opacity="0.5"/>
                </svg>
                <!-- Nodo central Venezuela -->
                <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-10">
                  <div class="w-20 h-20 rounded-full bg-purple-500/10 border-2 border-purple-500/40 flex items-center justify-center animate-pulse">
                    <div class="w-10 h-10 rounded-full bg-purple-500/20 border border-purple-500/60 flex items-center justify-center">
                      <span class="material-symbols-outlined text-sm text-purple-400">bolt</span>
                    </div>
                  </div>
                </div>
                <!-- Etiquetas de ciudades -->
                <div class="absolute top-4 left-6 text-[8px] font-mono text-[#cbd5e1]/60">Miami</div>
                <div class="absolute top-3 right-12 text-[8px] font-mono text-[#cbd5e1]/60">São Paulo</div>
                <div class="absolute bottom-6 left-8 text-[8px] font-mono text-[#cbd5e1]/60">Bogotá</div>
                <div class="absolute bottom-4 right-8 text-[8px] font-mono text-[#cbd5e1]/60">Buenos Aires</div>
                <div class="absolute top-1/2 left-3 -translate-y-1/2 text-[8px] font-mono text-purple-400/80">Venezuela</div>
              </div>
              <div class="flex justify-between mt-2 text-[8px] font-mono text-[#cbd5e1]/40">
                <span>Edge nodes: 100+</span>
                <span>Latencia promedio: 18ms</span>
                <span>Uptime: 99.99%</span>
              </div>
            </div>

            <!-- Panel derecho: Comparativa de rendimiento -->
            <div class="col-span-1 md:col-span-5 p-6 bg-[#050507]/30 font-mono text-[10px]">
              <div class="text-[9px] uppercase tracking-wider text-[#cbd5e1]/40 mb-4 font-semibold">Rendimiento Comparativo</div>
              <div class="space-y-5">
                <!-- WordPress tradicional -->
                <div>
                  <div class="flex justify-between items-center mb-1.5">
                    <span class="text-[#cbd5e1]/80">Sitio Tradicional (WordPress)</span>
                    <span class="text-red-400">6.2s</span>
                  </div>
                  <div class="w-full h-3 bg-[#1f1f24] rounded-full overflow-hidden">
                    <div class="w-full h-full bg-red-500/30 rounded-full" style="width: 95%"></div>
                  </div>
                  <div class="flex justify-between text-[8px] text-[#cbd5e1]/40 mt-0.5">
                    <span>Lighthouse: 42</span>
                    <span>3G: 8.4s</span>
                  </div>
                </div>

                <!-- Vortex Optimizado -->
                <div>
                  <div class="flex justify-between items-center mb-1.5">
                    <span class="text-green-400">Vortex LM (Astro + Jamstack)</span>
                    <span class="text-green-400">0.8s</span>
                  </div>
                  <div class="w-full h-3 bg-[#1f1f24] rounded-full overflow-hidden">
                    <div class="h-full bg-green-500/40 rounded-full" style="width: 8%"></div>
                  </div>
                  <div class="flex justify-between text-[8px] text-[#cbd5e1]/40 mt-0.5">
                    <span>Lighthouse: 100</span>
                    <span>3G: 1.2s</span>
                  </div>
                </div>

                <!-- Métricas adicionales -->
                <div class="border-t border-[#1f1f24]/50 pt-3 space-y-1.5">
                  <div class="flex justify-between">
                    <span class="text-[#cbd5e1]/60">First Contentful Paint</span>
                    <span class="text-green-400">0.3s</span>
                  </div>
                  <div class="flex justify-between">
                    <span class="text-[#cbd5e1]/60">Time to Interactive</span>
                    <span class="text-green-400">0.6s</span>
                  </div>
                  <div class="flex justify-between">
                    <span class="text-[#cbd5e1]/60">Cumulative Layout Shift</span>
                    <span class="text-green-400">0.02</span>
                  </div>
                  <div class="flex justify-between border-t border-[#1f1f24]/50 pt-1.5">
                    <span class="text-[#cbd5e1]/40">vs WordPress promedio</span>
                    <span class="text-green-500">8x ms rápido</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── VENTAJAS NACIONALES ────────────────────────────────────── -->
  <section id="ventajas" class="py-36 px-6 md:px-12 bg-black relative border-b border-[#1f1f24]">
    <div class="max-w-[1200px] mx-auto relative z-10">
      <div class="max-w-4xl mb-24">
        <span class="text-[10px] font-mono text-[#cbd5e1] uppercase tracking-widest block mb-3 font-medium">Ventajas Nacionales</span>
        <h2 class="text-2xl md:text-4xl font-light text-white tracking-tight leading-snug">
          Tu web funcionando a máxima velocidad desde cualquier estado de Venezuela, 
          incluso en conexiones 3G con ancho de banda limitado.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-16">
        <!-- Ventaja 1: Velocidad en conexiones lentas -->
        <div class="space-y-6 group">
          <div class="w-full aspect-[4/3] linear-card rounded border border-[#1f1f24] bg-[#08080c]/30 flex items-center justify-center p-6 glow-hover transition-all">
            <svg class="w-20 h-20 text-[#cbd5e1]/40 group-hover:text-white/80 transition-colors" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M20 50L40 35V65L20 50Z" stroke="currentColor" stroke-width="1.25"/>
              <path d="M40 50L60 35V65L40 50Z" stroke="currentColor" stroke-width="1.25"/>
              <path d="M60 50L80 35V65L60 50Z" stroke="currentColor" stroke-width="1.25"/>
              <circle cx="40" cy="35" r="2.5" fill="currentColor"/>
              <circle cx="60" cy="35" r="2.5" fill="currentColor"/>
              <circle cx="40" cy="65" r="2.5" fill="currentColor"/>
              <circle cx="60" cy="65" r="2.5" fill="currentColor"/>
              <path d="M15 55L20 50L25 55" stroke="currentColor" stroke-width="0.75" stroke-linecap="round"/>
              <path d="M75 55L80 50L85 55" stroke="currentColor" stroke-width="0.75" stroke-linecap="round"/>
            </svg>
          </div>
          <div>
            <h3 class="text-sm font-medium text-white mb-2.5">Carga Instantánea en 3G/4G/5G</h3>
            <p class="text-xs text-[#cbd5e1] leading-relaxed">
              Astro genera HTML estático que pesa 90% menos que un sitio WordPress tradicional. 
              Tu web carga en menos de 1 segundo incluso en conexiones móviles lentas de 
              cualquier estado del país. Primer paint en 0.3s gracias al CSS crítico inline 
              y la arquitectura Jamstack.
            </p>
            <ul class="space-y-1 mt-3 text-[10px] text-[#cbd5e1] font-mono">
              <li class="flex items-center gap-1.5"><span class="text-green-400">→</span> HTML estático servido desde CDN</li>
              <li class="flex items-center gap-1.5"><span class="text-green-400">→</span> JavaScript mínimo y diferido</li>
              <li class="flex items-center gap-1.5"><span class="text-green-400">→</span> Imágenes WebP con lazy loading</li>
            </ul>
          </div>
        </div>

        <!-- Ventaja 2: Integraciones locales -->
        <div class="space-y-6 group">
          <div class="w-full aspect-[4/3] linear-card rounded border border-[#1f1f24] bg-[#08080c]/30 flex items-center justify-center p-6 glow-hover transition-all">
            <svg class="w-20 h-20 text-[#cbd5e1]/40 group-hover:text-white/80 transition-colors" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="20" y="30" width="60" height="50" rx="4" stroke="currentColor" stroke-width="1.25"/>
              <path d="M20 45H80" stroke="currentColor" stroke-width="0.75"/>
              <path d="M30 30V20H70V30" stroke="currentColor" stroke-width="0.75"/>
              <circle cx="40" cy="60" r="3" fill="currentColor" fill-opacity="0.5"/>
              <circle cx="55" cy="60" r="3" fill="currentColor" fill-opacity="0.5"/>
              <path d="M35 68L40 72L50 62" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <div>
            <h3 class="text-sm font-medium text-white mb-2.5">Integraciones para el Mercado Venezolano</h3>
            <p class="text-xs text-[#cbd5e1] leading-relaxed">
              Conectamos tu web con las plataformas que usa tu negocio en Venezuela: 
              pasarelas de pago internacionales (PayPal, Stripe, MercadoPago), sistemas 
              de facturación electrónica (Seniat, IVA), plataformas de delivery locales 
              y CRMs adaptados al mercado nacional. Todo integrado en un solo ecosistema.
            </p>
            <ul class="space-y-1 mt-3 text-[10px] text-[#cbd5e1] font-mono">
              <li class="flex items-center gap-1.5"><span class="text-green-400">→</span> Pasarelas: PayPal, Stripe, MercadoPago, Zelle</li>
              <li class="flex items-center gap-1.5"><span class="text-green-400">→</span> Facturación electrónica Seniat/IVA</li>
              <li class="flex items-center gap-1.5"><span class="text-green-400">→</span> Catálogos con inventario en tiempo real</li>
            </ul>
          </div>
        </div>

        <!-- Ventaja 3: Alcance nacional -->
        <div class="space-y-6 group">
          <div class="w-full aspect-[4/3] linear-card rounded border border-[#1f1f24] bg-[#08080c]/30 flex items-center justify-center p-6 glow-hover transition-all">
            <svg class="w-20 h-20 text-[#cbd5e1]/40 group-hover:text-white/80 transition-colors" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="50" cy="50" r="35" stroke="currentColor" stroke-width="0.75" stroke-dasharray="2 2"/>
              <path d="M50 15V85" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 2"/>
              <path d="M15 50H85" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 2"/>
              <circle cx="50" cy="50" r="8" stroke="currentColor" stroke-width="1.25"/>
              <circle cx="50" cy="50" r="3" fill="currentColor"/>
              <circle cx="35" cy="30" r="2" fill="currentColor" fill-opacity="0.4"/>
              <circle cx="70" cy="35" r="2" fill="currentColor" fill-opacity="0.4"/>
              <circle cx="30" cy="65" r="2" fill="currentColor" fill-opacity="0.4"/>
              <circle cx="68" cy="68" r="2" fill="currentColor" fill-opacity="0.4"/>
            </svg>
          </div>
          <div>
            <h3 class="text-sm font-medium text-white mb-2.5">Presencia Digital en Todo el País</h3>
            <p class="text-xs text-[#cbd5e1] leading-relaxed">
              Sin importar si tu negocio está en Caracas, Maracaibo, Valencia, Barquisimeto, 
              Maracay o cualquier ciudad del país. Tu web estará disponible para clientes 
              en toda Venezuela con la misma velocidad y calidad. Servidores edge de Vercel 
              aseguran latencia mínima desde cualquier ubicación.
            </p>
            <ul class="space-y-1 mt-3 text-[10px] text-[#cbd5e1] font-mono">
              <li class="flex items-center gap-1.5"><span class="text-green-400">→</span> CDN global con nodos en Latinoamérica</li>
              <li class="flex items-center gap-1.5"><span class="text-green-400">→</span> Soporte remoto desde cualquier estado</li>
              <li class="flex items-center gap-1.5"><span class="text-green-400">→</span> Consultoría online sin necesidad de presencial</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── BLOQUE DETALLADO: TECNOLOGÍA PARA VENEZUELA ────────────── -->
  <section class="py-36 px-6 md:px-12 bg-black border-b border-[#1f1f24] relative">
    <div class="max-w-[1200px] mx-auto space-y-44 relative z-10">

      <!-- Bloque: Stack optimizado para conexiones lentas -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-center">
        <div class="lg:col-span-5 space-y-5">
          <span class="text-[10px] font-mono text-[#cbd5e1] uppercase tracking-widest block font-medium">Tecnología Adaptativa</span>
          <h2 class="text-2xl md:text-4xl font-light text-white tracking-tight leading-tight">
            Diseñado para el internet venezolano. Velocidad donde otros se quedan cargando.
          </h2>
          <p class="text-sm text-[#cbd5e1] font-light leading-relaxed">
            En Venezuela, la velocidad de internet puede variar drásticamente según el 
            operador y la región. Por eso construimos con Astro: genera HTML estático 
            ultraligero que se sirve desde 100+ servidores alrededor del mundo. 
            Mientras un sitio tradicional pesa 3-5MB y tarda 8 segundos en cargar, 
            tu web Vortex pesa menos de 200KB y carga en menos de 1 segundo. 
            Así de simple.
          </p>
          <ul class="space-y-2 text-xs text-[#cbd5e1] font-light">
            <li class="flex items-center gap-2">
              <span class="material-symbols-outlined text-sm text-green-400">check_circle</span>
              Compresión Brotli + HTML estático pre-renderizado
            </li>
            <li class="flex items-center gap-2">
              <span class="material-symbols-outlined text-sm text-green-400">check_circle</span>
              Imágenes WebP con calidad adaptativa por conexión
            </li>
            <li class="flex items-center gap-2">
              <span class="material-symbols-outlined text-sm text-green-400">check_circle</span>
              Service worker para modo offline parcial
            </li>
            <li class="flex items-center gap-2">
              <span class="material-symbols-outlined text-sm text-green-400">check_circle</span>
              Carga priorizada de contenido crítico (Critical CSS)
            </li>
          </ul>
        </div>

        <div class="lg:col-span-7">
          <div class="linear-card rounded-lg border border-[#1f1f24] overflow-hidden bg-[#08080c]/50 p-8 shadow-2xl relative">
            <div class="absolute inset-0 font-mono text-[8px] text-[#1f1f24] p-6 select-none overflow-hidden leading-relaxed pointer-events-none opacity-20">
              Conexión: 3G (1.5 Mbps)<br />
              Carga total: 187 KB<br />
              Tiempo: 0.8s<br />
              vs WordPress: 4.2 MB → 8.4s
            </div>

            <div class="flex items-center justify-between border-b border-[#1f1f24] pb-4 mb-6 relative z-10">
              <span class="text-[10px] font-mono text-[#cbd5e1] flex items-center gap-1.5">
                <span class="w-1.5 h-1.5 rounded-full bg-cyan-500"></span>
                performance // venezuela-benchmark
              </span>
              <span class="text-[9px] text-[#cbd5e1]/40 font-mono">Simulado 3G</span>
            </div>

            <!-- Indicadores de rendimiento -->
            <div class="grid grid-cols-2 gap-4 relative z-10">
              <div class="p-4 border border-[#1f1f24] rounded bg-black/40">
                <span class="text-[10px] font-mono text-cyan-400 block mb-1">Peso Total</span>
                <span class="text-2xl font-light text-white">187KB</span>
                <span class="text-[10px] text-[#cbd5e1]/60 block">vs 4.2MB WordPress</span>
              </div>
              <div class="p-4 border border-[#1f1f24] rounded bg-black/40">
                <span class="text-[10px] font-mono text-cyan-400 block mb-1">Tiempo 3G</span>
                <span class="text-2xl font-light text-white">0.8s</span>
                <span class="text-[10px] text-[#cbd5e1]/60 block">vs 8.4s WordPress</span>
              </div>
              <div class="p-4 border border-[#1f1f24] rounded bg-black/40">
                <span class="text-[10px] font-mono text-cyan-400 block mb-1">Lighthouse</span>
                <span class="text-2xl font-light text-white">100</span>
                <span class="text-[10px] text-[#cbd5e1]/60 block">Puntuación perfecta</span>
              </div>
              <div class="p-4 border border-[#1f1f24] rounded bg-black/40">
                <span class="text-[10px] font-mono text-cyan-400 block mb-1">Uptime</span>
                <span class="text-2xl font-light text-white">99.99%</span>
                <span class="text-[10px] text-[#cbd5e1]/60 block">SLA Vercel Edge</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Bloque: Integraciones Comerciales -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-center">
        <div class="lg:col-span-7 order-2 lg:order-1">
          <div class="linear-card rounded-lg border border-[#1f1f24] overflow-hidden bg-[#08080c]/50 p-6 shadow-2xl">
            <div class="flex items-center justify-between border-b border-[#1f1f24] pb-4 mb-4">
              <span class="text-[10px] font-mono text-[#cbd5e1] flex items-center gap-1.5">
                <span class="w-1.5 h-1.5 rounded-full bg-purple-500"></span>
                integrations // venezuela-ecosystem
              </span>
              <span class="text-[9px] text-[#cbd5e1]/40 font-mono">API Ready</span>
            </div>

            <!-- Grid de integraciones -->
            <div class="grid grid-cols-2 gap-3 py-4 relative z-10">
              <div class="p-3 border border-[#1f1f24] rounded bg-black/40 flex items-center gap-2">
                <span class="material-symbols-outlined text-sm text-blue-400">payments</span>
                <div>
                  <div class="text-[10px] text-white/90">PayPal / Stripe</div>
                  <div class="text-[8px] text-[#cbd5e1]/40">Pasarelas globales</div>
                </div>
              </div>
              <div class="p-3 border border-[#1f1f24] rounded bg-black/40 flex items-center gap-2">
                <span class="material-symbols-outlined text-sm text-green-400">account_balance</span>
                <div>
                  <div class="text-[10px] text-white/90">MercadoPago</div>
                  <div class="text-[8px] text-[#cbd5e1]/40">Pag. Latinoamérica</div>
                </div>
              </div>
              <div class="p-3 border border-[#1f1f24] rounded bg-black/40 flex items-center gap-2">
                <span class="material-symbols-outlined text-sm text-yellow-400">receipt_long</span>
                <div>
                  <div class="text-[10px] text-white/90">Facturación Seniat</div>
                  <div class="text-[8px] text-[#cbd5e1]/40">IVA / CF Legal</div>
                </div>
              </div>
              <div class="p-3 border border-[#1f1f24] rounded bg-black/40 flex items-center gap-2">
                <span class="material-symbols-outlined text-sm text-orange-400">local_shipping</span>
                <div>
                  <div class="text-[10px] text-white/90">Delivery / Logística</div>
