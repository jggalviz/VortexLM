---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Expertos en Desarrollo Web con Astro, React y Next.js | Vortex" description="Engineering frontend del futuro: Interfaces ultra-fluidas y rendimiento extremo.">
  <main class="py-36 px-6 md:px-12 bg-black min-h-screen">
    <div class="max-w-4xl mx-auto">
      <p class="font-mono text-[10px] uppercase tracking-widest text-[#94a3b8] mb-6">SOLUCIONES</p>
      <h1 class="font-extralight text-4xl md:text-5xl lg:text-6xl tracking-tight text-white mb-6">Engineering frontend del futuro: Interfaces ultra-fluidas y rendimiento extremo.</h1>
    </div>
  </main>
</BaseLayout>
