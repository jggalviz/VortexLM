---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Diseño Web de Alta Velocidad y Optimización Core Web Vitals | Vortex" description="Páginas web que cargan al instante. Optimizadas para convertir visitas en clientes.">
  <main class="py-36 px-6 md:px-12 bg-black min-h-screen">
    <div class="max-w-4xl mx-auto">
      <p class="font-mono text-[10px] uppercase tracking-widest text-[#94a3b8] mb-6">SOLUCIONES</p>
      <h1 class="font-extralight text-4xl md:text-5xl lg:text-6xl tracking-tight text-white mb-6">Páginas web que cargan al instante. Optimizadas para convertir visitas en clientes.</h1>
    </div>
  </main>
</BaseLayout>
