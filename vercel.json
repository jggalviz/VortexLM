{
  "headers": [
    {
      "source": "/(.*)\\.(avif|webp|png|jpg|jpeg|svg|css|js)$",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/~partytown/partytown-sw.js",
      "destination": "https://unpkg.com/@builder.io/partytown@0.10.2/lib/partytown-sw.js"
    },
    {
      "source": "/partytown/partytown-sw.js",
      "destination": "https://unpkg.com/@builder.io/partytown@0.10.2/lib/partytown-sw.js"
    }
  ]
}
